{% comment %}
  Snippet: Ingredients Link
  Usage: {% render 'c-ingredients-link', anchor_id: "ingredients" %}
{% endcomment %}

<p class="c-ingredients-link">
  <a href="#{{ anchor_id | default: 'ingredients' }}" onclick="document.getElementById('{{ anchor_id | default: 'ingredients' }}')?.scrollIntoView({behavior: 'smooth'}); return false;">INGREDIENTS →</a>
</p>

{% stylesheet %}
  .c-ingredients-link {
    display: block;
    width: 100%;
    margin: 12px 0;
  }

  .c-ingredients-link a {
    font-size: 13px;
    font-weight: 600;
    color: #002C41;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.3px;
    display: inline-flex;
    align-items: center;
    gap: 4px;
    transition: opacity 0.2s ease;
  }

  .c-ingredients-link a:hover {
    opacity: 0.7;
  }
{% endstylesheet %}
