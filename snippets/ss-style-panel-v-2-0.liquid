    if width != blank
      assign color = settings.border_color
      assign placement = settings.border_placement
      assign radius = settings.border_radius
      if radius != blank
        assign style_list = style_list | append: '--ss-style-panel-border-radius: ' | append: radius | append: 'px;'
      endif

      assign top = 'none'
      assign bottom = 'none'
      assign left = 'none'
      assign right = 'none'

      case placement
        when 'all'
          assign top = 'solid ' | append: width | append: 'px ' | append: color | append: ';'
          assign bottom = 'solid ' | append: width | append: 'px ' | append: color | append: ';'
          assign left = 'solid ' | append: width | append: 'px ' | append: color | append: ';'
          assign right = 'solid ' | append: width | append: 'px ' | append: color | append: ';'
        when 'top'
          assign top = 'solid ' | append: width | append: 'px ' | append: color | append: ';'
        when 'bottom'
          assign bottom = 'solid ' | append: width | append: 'px ' | append: color | append: ';'
        when 'left'
          assign left = 'solid ' | append: width | append: 'px ' | append: color | append: ';'
        when 'right'
          assign right = 'solid ' | append: width | append: 'px ' | append: color | append: ';'
        when 'top-bottom'
          assign top = 'solid ' | append: width | append: 'px ' | append: color | append: ';'
          assign bottom = 'solid ' | append: width | append: 'px ' | append: color | append: ';'
        when 'left-right'
          assign left = 'solid ' | append: width | append: 'px ' | append: color | append: ';'
          assign right = 'solid ' | append: width | append: 'px ' | append: color | append: ';'
      endcase

      assign style_list = style_list | append: '--ss-style-panel-border-top: ' | append: top | append: ';'
      assign style_list = style_list | append: '--ss-style-panel-border-bottom: ' | append: bottom | append: ';'
      assign style_list = style_list | append: '--ss-style-panel-border-left: ' | append: left | append: ';'
      assign style_list = style_list | append: '--ss-style-panel-border-right: ' | append: right | append: ';'
    endif
  endif

  # Absolute Positioning
  if type == blank or type contains 'absolute-positioning' and settings['ss-position'] != 'inherit'
    assign style_list = style_list | append: '--ss-style-panel-position: ' | append: settings['ss-position'] | append: ';'
    assign style_list = style_list | append: '--ss-style-panel-transform: translate(-50%, -50%);'

    if settings.desktop_position_x != blank
      assign style_list = style_list | append: '--ss-style-panel-floating-position-x: ' | append: settings.desktop_position_x | append: ';'
    endif
    if settings.desktop_position_y != blank
      assign style_list = style_list | append: '--ss-style-panel-floating-position-y: ' | append: settings.desktop_position_y | append: ';'
    endif
    if settings.z_index != blank
      assign style_list = style_list | append: '--ss-style-panel-floating-z-index: ' | append: settings.z_index | append: ';'
    endif

    # Mobile
    if settings.mobile_position_x != blank
      assign style_list = style_list | append: '--ss-style-panel-floating-position-x-mobile: ' | append: settings.mobile_position_x | append: ';'
    elsif settings.desktop_position_x != blank
      assign style_list = style_list | append: '--ss-style-panel-floating-position-x-mobile: ' | append: settings.desktop_position_x | append: ';'
    endif
    if settings.mobile_position_y != blank
      assign style_list = style_list | append: '--ss-style-panel-floating-position-y-mobile: ' | append: settings.mobile_position_y | append: ';'
    elsif settings.desktop_position_y != blank
      assign style_list = style_list | append: '--ss-style-panel-floating-position-y-mobile: ' | append: settings.desktop_position_y | append: ';'
    endif
  endif

  # Positioning
  if type == blank or type contains 'position'
    # Reset the position values
    assign style_list = style_list | append: '--ss-style-position-panel-position-type: relative;'

    assign top = settings['top-position'] | default: 'unset'
    assign right = settings['right-position'] | default: 'unset'
    assign bottom = settings['bottom-position'] | default: 'unset'
    assign left = settings['left-position'] | default: 'unset'

    assign style_list = style_list | append: '--ss-style-position-panel-top: ' | append: top | append: ';'
    assign style_list = style_list | append: '--ss-style-position-panel-right: ' | append: right | append: ';'
    assign style_list = style_list | append: '--ss-style-position-panel-bottom: ' | append: bottom | append: ';'
    assign style_list = style_list | append: '--ss-style-position-panel-left: ' | append: left | append: ';'
    assign style_list = style_list | append: '--ss-style-position-panel-top-mobile: ' | append: top | append: ';'
    assign style_list = style_list | append: '--ss-style-position-panel-right-mobile: ' | append: right | append: ';'
    assign style_list = style_list | append: '--ss-style-position-panel-bottom-mobile: ' | append: bottom | append: ';'
    assign style_list = style_list | append: '--ss-style-position-panel-left-mobile: ' | append: left | append: ';'

    # Desktop
    if settings.position_custom
      # Positioning
      assign style_list = style_list | append: '--ss-style-position-panel-z-index: ' | append: settings['position-z-index'] | append: ';'

      # Position Type
      assign position_type = settings['position-type'] | default: 'relative'
      assign style_list = style_list | append: '--ss-style-position-panel-position-type: ' | append: position_type | append: ';'
      if position_type == 'absolute'
        assign style_list = style_list | append: '--ss-style-position-panel-transform: translate(-50%, -50%);'
      endif

      # Position Location
      assign position_unit = settings['position-unit']
      if position_unit == 'custom'
        assign position_top = settings['position-top-custom']
        assign style_list = style_list | append: '--ss-style-position-panel-top: ' | append: position_top | append: ';'
        assign position_right = settings['position-right-custom']
        assign style_list = style_list | append: '--ss-style-position-panel-right: ' | append: position_right | append: ';'
        assign position_bottom = settings['position-bottom-custom']
        assign style_list = style_list | append: '--ss-style-position-panel-bottom: ' | append: position_bottom | append: ';'
        assign position_left = settings['position-left-custom']
        assign style_list = style_list | append: '--ss-style-position-panel-left: ' | append: position_left | append: ';'
      else
        assign position_top = settings['position-top']
        assign style_list = style_list | append: '--ss-style-position-panel-top: ' | append: position_top | append: settings.position_unit | append: ';'
        assign position_right = settings['position-right']
        assign style_list = style_list | append: '--ss-style-position-panel-right: ' | append: position_right | append: settings.position_unit | append: ';'
        assign position_bottom = settings['position-bottom']
        assign style_list = style_list | append: '--ss-style-position-panel-bottom: ' | append: position_bottom | append: settings.position_unit | append: ';'
        assign position_left = settings['position-left']
        assign style_list = style_list | append: '--ss-style-position-panel-left: ' | append: position_left | append: settings.position_unit | append: ';'
      endif
    endif

    # Mobile
    if settings.position_custom_mobile
      # Positioning

      assign style_list = style_list | append: '--ss-style-position-panel-z-index-mobile: ' | append: settings['position-z-index-mobile'] | append: ';'

      # Position Type
      assign position_type_mobile = settings['position-type-mobile'] | default: position_type
      assign style_list = style_list | append: '--ss-style-position-panel-position-type-mobile: ' | append: position_type_mobile | append: ';'
      if position_type_mobile == 'absolute'
        assign style_list = style_list | append: '--ss-style-position-panel-transform-mobile: translate(-50%, -50%);'
      endif

      # Position Location
      assign position_unit_mobile = settings['position-unit-mobile']
      if position_unit_mobile == 'custom'
        assign position_top_mobile = settings['position-top-mobile-custom']
        assign style_list = style_list | append: '--ss-style-position-panel-top-mobile: ' | append: position_top_mobile | append: ';'
        assign position_right_mobile = settings['position-right-mobile-custom']
        assign style_list = style_list | append: '--ss-style-position-panel-right-mobile: ' | append: position_right_mobile | append: ';'
        assign position_bottom_mobile = settings['position-bottom-mobile-custom']
        assign style_list = style_list | append: '--ss-style-position-panel-bottom-mobile: ' | append: position_bottom_mobile | append: ';'
        assign position_left_mobile = settings['position-left-mobile-custom']
        assign style_list = style_list | append: '--ss-style-position-panel-left-mobile: ' | append: position_left_mobile | append: ';'
      else
        assign position_top_mobile = settings['position-top-mobile']
        assign style_list = style_list | append: '--ss-style-position-panel-top-mobile: ' | append: position_top_mobile | append: settings.position_unit_mobile | append: ';'
        assign position_right_mobile = settings['position-right-mobile']
        assign style_list = style_list | append: '--ss-style-position-panel-right-mobile: ' | append: position_right_mobile | append: settings.position_unit_mobile | append: ';'
        assign position_bottom_mobile = settings['position-bottom-mobile']
        assign style_list = style_list | append: '--ss-style-position-panel-bottom-mobile: ' | append: position_bottom_mobile | append: settings.position_unit_mobile | append: ';'
        assign position_left_mobile = settings['position-left-mobile']
        assign style_list = style_list | append: '--ss-style-position-panel-left-mobile: ' | append: position_left_mobile | append: settings.position_unit_mobile | append: ';'
      endif
    endif
  endif

  # Shadow
  if type == blank or type contains 'shadow'
    assign style_list = style_list | append: '--ss-style-shadow-panel-box-shadow: none;'
    if settings.enable_box_shadow
      if settings.box_shadow != blank
        assign style_list = style_list | append: '--ss-style-shadow-panel-box-shadow: ' | append: settings.box_shadow | append: ';'
      endif
    endif
  endif
-%}
{%- liquid
  # ------------------------------------------------------------
  # Return the CSS variables for the style tag
  # ------------------------------------------------------------
  echo style_list
-%}
