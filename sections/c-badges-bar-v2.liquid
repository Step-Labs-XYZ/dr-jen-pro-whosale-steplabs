{%- comment -%}
  Section: Badges Bar v2
  Description: Sección de badges de confianza editable con flexibilidad para agregar tantos badges como se desee.
  sl-id: sl-section-badges-bar-v2
  Figma: (pending)
{%- endcomment -%}


{%- comment -%} ===== Styles ===== {%- endcomment -%}
{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700;800&display=swap');

  /* =========================================
     RAÍZ DE SECCIÓN — variables CSS
     ========================================= */
  #c-badges-{{ section.id }} {
    --cb-bg:              {{ section.settings.bg_color }};
    --cb-badge-icon:      {{ section.settings.badge_icon_color }};
    --cb-badge-text:      {{ section.settings.badge_text_color }};
    --cb-badges-bg:       {{ section.settings.badges_bg_color }};

    font-family: 'Raleway', sans-serif;
    background-color: var(--cb-bg);
    width: 100%;
  }

  /* =========================================
     CONTAINER
     ========================================= */
  #c-badges-{{ section.id }} .c-badges__container {
    max-width: 1440px;
    margin: 0 auto;
    padding-top: {{ section.settings.pad_top_mob }}px;
    padding-bottom: {{ section.settings.pad_bot_mob }}px;
    padding-left: 20px;
    padding-right: 20px;
  }

  /* =========================================
     BARRA DE BADGES
     ========================================= */
  #c-badges-{{ section.id }} .c-badges__wrap {
    background-color: var(--cb-badges-bg);
    border-radius: 12px;
    padding: 50px 20px;
  }

  #c-badges-{{ section.id }} .c-badges__list {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
    justify-content: center;
    gap: 24px;
  }

  #c-badges-{{ section.id }} .c-badges__badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-align: center;
    background-color: #ffffff;
    border-radius: 12px;
    padding: 20px 24px;
  }

  #c-badges-{{ section.id }} .c-badges__badge-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--cb-badge-icon);
    flex-shrink: 0;
  }

  #c-badges-{{ section.id }} .c-badges__badge-icon svg,
  #c-badges-{{ section.id }} .c-badges__badge-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  #c-badges-{{ section.id }} .c-badges__badge-text {
    font-size: 14px;
    font-weight: 700;
    color: var(--cb-badge-text);
    line-height: 1.3;
    margin: 0;
  }


  /* =========================================
     MOBILE
     ========================================= */
  @media (max-width: 899px) {
    #c-badges-{{ section.id }} .c-badges__wrap {
      background-color: var(--cb-badges-bg);
      border-radius: 12px;
      padding: 50px 20px;
      margin: 15px;
    }

    #c-badges-{{ section.id }} .c-badges__list {
      display: flex;
      flex-direction: column;
      flex-wrap: wrap;
      justify-content: center;
      gap: 24px;
    }

    #c-badges-{{ section.id }} .c-badges__badge-icon {
      margin-top: 10px;
    }

    #c-badges-{{ section.id }} .c-badges__badge-text {
      font-size: 14px;
      font-weight: 700;
      color: var(--cb-badge-text);
      line-height: 1.3;
      margin: 0;
      margin-bottom: 10px;
    }
  }


  /* =========================================
     BREAKPOINT 768px — TABLET / DESKTOP
     ========================================= */
  @media (min-width: 768px) {
    #c-badges-{{ section.id }} .c-badges__container {
      padding-top: {{ section.settings.pad_top_desk }}px;
      padding-bottom: {{ section.settings.pad_bot_desk }}px;
      padding-left: 50px;
      padding-right: 50px;
    }

    #c-badges-{{ section.id }} .c-badges__wrap {
      padding: 0px;
    }

    #c-badges-{{ section.id }} .c-badges__list {
      flex-direction: row;
      flex-wrap: nowrap;
      gap: 44px;
    }

    #c-badges-{{ section.id }} .c-badges__badge {
      flex: 1;
      min-width: 0;
    }

    #c-badges-{{ section.id }} .c-badges__badge-text {
      font-size: 15px;
    }
  }

  /* =========================================
     BREAKPOINT 1200px — WIDE DESKTOP
     ========================================= */
  @media (min-width: 1200px) {
    #c-badges-{{ section.id }} .c-badges__badge {
      width: 120px;
    }
  }

  /* =========================================
     BREAKPOINT 1980px — ULTRA WIDE
     ========================================= */
  @media (min-width: 1980px) {
    #c-badges-{{ section.id }} .c-badges__container {
      max-width: 1600px;
    }
  }
{%- endstyle -%}

{%- comment -%} ===== HTML ===== {%- endcomment -%}
<section
  id="c-badges-{{ section.id }}"
  class="c-badges"
  data-sl-id="sl-section-badges-bar-v2"
  data-section-id="{{ section.id }}"
  {%- if section.settings.sl_anchor_id != blank %} data-anchor="{{ section.settings.sl_anchor_id }}"{% endif %}
>
  <div class="c-badges__container">
    {%- if section.blocks.size > 0 -%}
      <div class="c-badges__wrap">
        <div class="c-badges__list">
          {%- for block in section.blocks -%}
            <div class="c-badges__badge" {{ block.shopify_attributes }}>

              <div class="c-badges__badge-icon">
                {%- if block.settings.svg_code != blank -%}
                  {{ block.settings.svg_code }}
                {%- elsif block.settings.icon_image != blank -%}
                  <img
                    src="{{ block.settings.icon_image | image_url: width: 80 }}"
                    alt="{{ block.settings.text | escape }}"
                    width="40"
                    height="40"
                    loading="lazy"
                  >
                {%- endif -%}
              </div>

              {%- if block.settings.text != blank -%}
                <p class="c-badges__badge-text">{{ block.settings.text | escape }}</p>
              {%- endif -%}

            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}
  </div>
</section>

{%- comment -%} ===== Schema ===== {%- endcomment -%}
{% schema %}
{
  "name": "C Badges Bar v2",
  "tag": "section",
  "class": "c-badges-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "sl_anchor_id",
      "label": "ID de ancla (anchor)",
      "info": "Identificador para scroll-to o enlaces directos a esta sección. Ej: badges-confianza"
    },
    {
      "type": "header",
      "content": "── Colores ──"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo de la sección",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "badge_icon_color",
      "label": "Color de iconos en badges",
      "default": "#002C41"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Color de texto en badges",
      "default": "#002C41"
    },
    {
      "type": "color",
      "id": "badges_bg_color",
      "label": "Fondo de la barra de badges",
      "default": "#f8f8f6"
    },
    {
      "type": "header",
      "content": "── Espaciado ──"
    },
    {
      "type": "range",
      "id": "pad_top_mob",
      "label": "Padding superior mobile",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "pad_bot_mob",
      "label": "Padding inferior mobile",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "pad_top_desk",
      "label": "Padding superior desktop",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_bot_desk",
      "label": "Padding inferior desktop",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge de confianza",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Imagen del ícono",
          "info": "Sube un PNG/SVG. Tiene prioridad sobre el código SVG."
        },
        {
          "type": "textarea",
          "id": "svg_code",
          "label": "Código SVG del ícono (alternativo)",
          "info": "Pega aquí el código SVG si no usas imagen."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texto del badge",
          "default": "Badge Label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "C Badges Bar v2",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "text": "Clinically Proven Protection"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "Dentist Developed & Approved"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "Over 360,000 Cleaner Smiles"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "100% Proven Ingredients"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "Made in USA"
          }
        }
      ]
    }
  ]
}
{% endschema %}