{%- comment -%}
  Section: Study Chart
  Description: Sección de dos columnas con contenido de texto a la izquierda y una gráfica de barras editable a la derecha, más una barra de badges de confianza en la parte inferior.
  sl-id: sl-section-study-chart-v1
  Figma: (pending)
{%- endcomment -%}


{%- comment -%} ===== Styles ===== {%- endcomment -%}
{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Raleway:wght@300;400;500;600;700;800&display=swap');

  /* =========================================
     RAÍZ DE SECCIÓN — variables CSS
     ========================================= */
  #c-study-chart-{{ section.id }} {
    --csc-bg:              {{ section.settings.bg_color }};
    --csc-heading:         {{ section.settings.color_heading }};
    --csc-body:            {{ section.settings.color_body }};
    --csc-chart-bg:        {{ section.settings.chart_bg_color }};
    --csc-badge-icon:      {{ section.settings.badge_icon_color }};
    --csc-badge-text:      {{ section.settings.badge_text_color }};
    --csc-badges-bg:       {{ section.settings.badges_bg_color }};

    font-family: 'Raleway', sans-serif;
    background-color: var(--csc-bg);
    width: 100%;
  }

  /* =========================================
     CONTAINER
     ========================================= */
  #c-study-chart-{{ section.id }} .c-study-chart__container {
    max-width: 1400px;
    margin: 0 auto;
    padding-top: {{ section.settings.pad_top_mob }}px;
    padding-bottom: {{ section.settings.pad_bot_mob }}px;
    padding-left: 20px;
    padding-right: 20px;
  }

  /* =========================================
     MAIN 2-COLUMNAS
     ========================================= */
  #c-study-chart-{{ section.id }} .c-study-chart__main {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /* =========================================
     COLUMNA IZQUIERDA — CONTENIDO
     ========================================= */
  #c-study-chart-{{ section.id }} .c-study-chart__content {
    display: flex;
    flex-direction: column;
  }

  #c-study-chart-{{ section.id }} .c-study-chart__heading {
    font-size: 28px;
    font-weight: 600; /* Medium — igual que c-clinically-backed */
    color: var(--csc-heading);
    line-height: 1.15;
    margin: 0 0 16px 0;
    font-family: 'Raleway', sans-serif !important;
  }

  #c-study-chart-{{ section.id }} .c-study-chart__subheading {
    font-size: 15px;
    font-weight: 600;
    color: #000;
    line-height: 120%;
    margin: 0 0 20px 0;
  }

  #c-study-chart-{{ section.id }} .c-study-chart__subtitle {
    font-size: 16px;
    font-weight: 700;
    color: #000;
    line-height: 1.3;
    margin: 0 0 12px 0;
  }

  #c-study-chart-{{ section.id }} .c-study-chart__body {
    font-size: 14px;
    font-weight: 400;
    color: var(--csc-body);
    line-height: 120%;
    margin: 0;
  }

  #c-study-chart-{{ section.id }} .c-study-chart__body p {
    margin: 0;
  }

  /* =========================================
     COLUMNA DERECHA — GRÁFICA
     ========================================= */
  #c-study-chart-{{ section.id }} .c-study-chart__chart-wrap {
    background-color: var(--csc-chart-bg);
    border-radius: 12px;
    padding: 0px;
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  #c-study-chart-{{ section.id }} .c-study-chart__chart-image {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px;
  }

  /* =========================================
     BARRA DE BADGES
     ========================================= */
  #c-study-chart-{{ section.id }} .c-study-chart__badges-wrap {
    background-color: var(--csc-badges-bg);
    border-radius: 12px;
    margin-top: 64px;
    padding: 24px 20px;
  }

  #c-study-chart-{{ section.id }} .c-study-chart__badges {
    display: flex;
    flex-direction: row;
    flex-wrap: wrap;
    justify-content: center;
    gap: 44px;
  }

  #c-study-chart-{{ section.id }} .c-study-chart__badge {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    text-align: center;
    flex: 1 1 100px;
    min-width: 90px;
    background-color: #ffffff;
    border-radius: 12px;
    padding: 20px 24px;
  }

  #c-study-chart-{{ section.id }} .c-study-chart__badge-icon {
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--csc-badge-icon);
    flex-shrink: 0;
  }

  #c-study-chart-{{ section.id }} .c-study-chart__badge-icon svg,
  #c-study-chart-{{ section.id }} .c-study-chart__badge-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  #c-study-chart-{{ section.id }} .c-study-chart__badge-text {
    font-size: 14px;
    font-weight: 700;
    color: var(--csc-badge-text);
    line-height: 1.3;
    margin: 0;
  }


  /* =========================================
     MOBILE
     ========================================= */

    @media (max-width: 899px) {

  /* =========================================
     BARRA DE BADGES
     ========================================= */
  #c-study-chart-{{ section.id }} .c-study-chart__badges-wrap {
    background-color: var(--csc-badges-bg);
    border-radius: 12px;
    margin-top: 0px;
    padding: 50px 20px;
   }

   #c-study-chart-{{ section.id }} .c-study-chart__badges {
    display: flex;
    flex-direction: column;
    flex-wrap: wrap;
    justify-content: center;
    gap: 44px;
    }

   #c-study-chart-{{ section.id }} .c-study-chart__badges-wrap {
    margin: 15px;
    }

  #c-study-chart-{{ section.id }}  .c-study-chart__badge-icon {
    margin-top: 10px !important;
  }
  #c-study-chart-template--27137343389972__c_study_chart_Q4qdUp .c-study-chart__badge-text {
    font-size: 14px;
    font-weight: 700;
    color: var(--csc-badge-text);
    line-height: 1.3;
    margin: 0;
    margin-bottom: 20px !important;
}

}


  /* =========================================
     BREAKPOINT 768px — TABLET / DESKTOP
     ========================================= */
  @media (min-width: 768px) {
    #c-study-chart-{{ section.id }} .c-study-chart__container {
      padding-top: {{ section.settings.pad_top_desk }}px;
      padding-bottom: {{ section.settings.pad_bot_desk }}px;
      padding-left: 50px;
      padding-right: 50px;
    }


    #c-study-chart-{{ section.id }} .c-study-chart__main {
      flex-direction: row;
      align-items: flex-start;
      gap: 56px;
    }

    #c-study-chart-{{ section.id }} .c-study-chart__content {
      flex: 1;
    }

    #c-study-chart-{{ section.id }} .c-study-chart__chart-wrap {
      flex: 1.1;
      padding: 10px;
    }

    #c-study-chart-{{ section.id }} .c-study-chart__heading {
      font-size: 34px;
      font-weight: 500;
    }

    #c-study-chart-{{ section.id }} .c-study-chart__subheading {
      font-size: 24px;
    }

    #c-study-chart-{{ section.id }} .c-study-chart__subtitle {
      font-size: 24px;
    }

    #c-study-chart-{{ section.id }} .c-study-chart__body {
      font-size: 20px;
    }

    #c-study-chart-{{ section.id }} .c-study-chart__chart-image {
      width: 90%;
      height: auto;
      display: block;
      align-self: center;
      border-radius: 8px;
    }

    #c-study-chart-{{ section.id }} .c-study-chart__badges {
      flex-wrap: nowrap;
    }

    #c-study-chart-{{ section.id }} .c-study-chart__badge {
      flex: 1;
      min-width: 0;
    }

    #c-study-chart-{{ section.id }} .c-study-chart__badge-text {
      font-size: 15px;
    }

    #c-study-chart-{{ section.id }} .c-study-chart__badges-wrap {
      padding: 0px;
    }
  }

  /* =========================================
     BREAKPOINT 1200px — WIDE DESKTOP
     ========================================= */
  @media (min-width: 1200px) {
    #c-study-chart-{{ section.id }} .c-study-chart__heading {
      font-size: 48px;
      font-weight: 600;
    }

    #c-study-chart-{{ section.id }} .c-study-chart__badge {
      width: 120px;
    }
  }

  /* =========================================
     BREAKPOINT 1980px — ULTRA WIDE
     ========================================= */
  @media (min-width: 1980px) {
    #c-study-chart-{{ section.id }} .c-study-chart__container {
      max-width: 1600px;
    }

    #c-study-chart-{{ section.id }} .c-study-chart__heading {
      font-size: 48px;
    }
  }
{%- endstyle -%}

{%- comment -%} ===== HTML ===== {%- endcomment -%}
<section
  id="c-study-chart-{{ section.id }}"
  class="c-study-chart"
  data-sl-id="sl-section-study-chart-v1"
  data-section-id="{{ section.id }}"
  {%- if section.settings.sl_anchor_id != blank %} data-anchor="{{ section.settings.sl_anchor_id }}"{% endif %}
>
  <div class="c-study-chart__container">

    {%- comment -%} ── MAIN: 2 columnas ── {%- endcomment -%}
    <div class="c-study-chart__main">

      {%- comment -%} COLUMNA IZQUIERDA: Contenido de texto {%- endcomment -%}
      <div class="c-study-chart__content">
        {%- if section.settings.heading != blank -%}
          <h2 class="c-study-chart__heading">{{ section.settings.heading | escape }}</h2>
        {%- endif -%}

        {%- if section.settings.subheading != blank -%}
          <p class="c-study-chart__subheading">{{ section.settings.subheading | escape }}</p>
        {%- endif -%}

        {%- if section.settings.subtitle != blank -%}
          <p class="c-study-chart__subtitle">{{ section.settings.subtitle | escape }}</p>
        {%- endif -%}

        {%- if section.settings.body_text != blank -%}
          <div class="c-study-chart__body">{{ section.settings.body_text }}</div>
        {%- endif -%}
      </div>

      {%- comment -%} COLUMNA DERECHA: Gráfica de barras {%- endcomment -%}
      <div class="c-study-chart__chart-wrap">

        {%- if section.settings.chart_image != blank -%}
          <img
            class="c-study-chart__chart-image"
            src="{{ section.settings.chart_image | image_url: width: 900 }}"
            alt="{{ section.settings.chart_image.alt | default: 'Study chart' | escape }}"
            width="{{ section.settings.chart_image.width }}"
            height="{{ section.settings.chart_image.height }}"
            loading="lazy"
          >
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'c-study-chart__chart-image' }}
        {%- endif -%}

      </div>{%- comment -%} /.c-study-chart__chart-wrap {%- endcomment -%}
    </div>{%- comment -%} /.c-study-chart__main {%- endcomment -%}

    {%- comment -%} ── BARRA DE BADGES ── {%- endcomment -%}
    {%- if section.blocks.size > 0 -%}
      <div class="c-study-chart__badges-wrap">
        <div class="c-study-chart__badges">
          {%- for block in section.blocks -%}
            <div class="c-study-chart__badge" {{ block.shopify_attributes }}>

              <div class="c-study-chart__badge-icon">
                {%- if block.settings.svg_code != blank -%}
                  {{ block.settings.svg_code }}
                {%- elsif block.settings.icon_image != blank -%}
                  <img
                    src="{{ block.settings.icon_image | image_url: width: 80 }}"
                    alt="{{ block.settings.text | escape }}"
                    width="40"
                    height="40"
                    loading="lazy"
                  >
                {%- else -%}
                  {%- comment -%} Ícono genérico fallback {%- endcomment -%}
                  <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                    <circle cx="20" cy="20" r="18" stroke="currentColor" stroke-width="2"/>
                    <path d="M13 20l5 5 9-9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                {%- endif -%}
              </div>

              {%- if block.settings.text != blank -%}
                <p class="c-study-chart__badge-text">{{ block.settings.text | escape }}</p>
              {%- endif -%}

            </div>
          {%- endfor -%}
        </div>
      </div>
    {%- endif -%}

  </div>{%- comment -%} /.c-study-chart__container {%- endcomment -%}
</section>

{%- comment -%} ===== Schema ===== {%- endcomment -%}
{% schema %}
{
  "name": "C Badges Bar v2",
  "tag": "section",
  "class": "c-study-chart-wrapper",
  "settings": [
    {
      "type": "text",
      "id": "sl_anchor_id",
      "label": "ID de ancla (anchor)",
      "info": "Identificador para scroll-to o enlaces directos a esta sección. Ej: estudio-clinico"
    },
    {
      "type": "header",
      "content": "── Contenido izquierdo ──"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título principal",
      "default": "What Does Your Patients Enamel Really Need in Your Fluoride Toothpaste?"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subtítulo descriptivo",
      "default": "The answer is easy: Optimal cavity protection and remineralization"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Subtítulo en negrita",
      "default": "The 10% Premium Difference"
    },
    {
      "type": "richtext",
      "id": "body_text",
      "label": "Texto del cuerpo",
      "default": "<p>In a Pilot Study conducted in December 2023, Dr. Jen's Super Paste (10% Nanohydroxyapatite, 0.22% fluoride, and xylitol) was tested against a high-prescription fluoride toothpaste containing 5000 ppm. Dr. Jen's Super Paste delivered six times higher levels of remineralization.</p>"
    },
    {
      "type": "header",
      "content": "── Gráfica de barras ──"
    },
    {
      "type": "image_picker",
      "id": "chart_image",
      "label": "Imagen de la gráfica"
    },
    {
      "type": "header",
      "content": "── Colores ──"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Fondo de la sección",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "color_heading",
      "label": "Color de títulos",
      "default": "#002C41"
    },
    {
      "type": "color",
      "id": "color_body",
      "label": "Color de texto del cuerpo",
      "default": "#4b5563"
    },
    {
      "type": "color",
      "id": "chart_bg_color",
      "label": "Fondo del área de la gráfica",
      "default": "#f2f2f0"
    },
    {
      "type": "color",
      "id": "badge_icon_color",
      "label": "Color de iconos en badges",
      "default": "#002C41"
    },
    {
      "type": "color",
      "id": "badge_text_color",
      "label": "Color de texto en badges",
      "default": "#002C41"
    },
    {
      "type": "color",
      "id": "badges_bg_color",
      "label": "Fondo de la barra de badges",
      "default": "#f8f8f6"
    },
    {
      "type": "header",
      "content": "── Espaciado ──"
    },
    {
      "type": "range",
      "id": "pad_top_mob",
      "label": "Padding superior mobile",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "pad_bot_mob",
      "label": "Padding inferior mobile",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "default": 60
    },
    {
      "type": "range",
      "id": "pad_top_desk",
      "label": "Padding superior desktop",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "pad_bot_desk",
      "label": "Padding inferior desktop",
      "min": 0,
      "max": 148,
      "step": 4,
      "unit": "px",
      "default": 80
    }
  ],
  "blocks": [
    {
      "type": "badge",
      "name": "Badge de confianza",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Imagen del ícono",
          "info": "Sube un PNG/SVG. Tiene prioridad sobre el código SVG."
        },
        {
          "type": "textarea",
          "id": "svg_code",
          "label": "Código SVG del ícono (alternativo)",
          "info": "Pega aquí el código SVG si no usas imagen. Si ambos están vacíos se muestra un ícono genérico."
        },
        {
          "type": "text",
          "id": "text",
          "label": "Texto del badge",
          "default": "Badge Label"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "C Badges Bar v2",
      "blocks": [
        {
          "type": "badge",
          "settings": {
            "text": "Clinically Proven Protection"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "Dentist Developed & Approved"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "Over 360,000 Cleaner Smiles"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "100% Proven Ingredients"
          }
        },
        {
          "type": "badge",
          "settings": {
            "text": "Made in USA"
          }
        }
      ]
    }
  ]
}
{% endschema %}
