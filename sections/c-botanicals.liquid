<div id="c-botanicals-{{ section.id }}" class="c-botanicals" data-section-id="{{ section.id }}">
  <div class="c-botanicals__container">
    
    <div class="c-botanicals__header">
      {%- if section.settings.subheading != blank -%}
        <p class="c-botanicals__subheading">{{ section.settings.subheading }}</p>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="c-botanicals__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="c-botanicals__slider-wrapper">
      <div class="c-botanicals__track" id="c-track-{{ section.id }}">
        {%- for block in section.blocks -%}
          <div class="c-botanicals__card" {{ block.shopify_attributes }}>
            <div class="c-botanicals__card-image">
              {%- if block.settings.image != blank -%}
                <img 
                  src="{{ block.settings.image | image_url: width: 800 }}" 
                  alt="{{ block.settings.title | escape }}"
                  loading="lazy"
                >
              {%- else -%}
                <div class="c-botanicals__placeholder">
                  <svg width="100%" height="100%" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <rect width="200" height="200" fill="#E5E5E5"/>
                    <text x="50%" y="50%" text-anchor="middle" fill="#999" font-size="14">Image</text>
                  </svg>
                </div>
              {%- endif -%}
            </div>

            <div class="c-botanicals__card-content">
              <h3 class="c-botanicals__card-title">
                {{ block.settings.title }}
                {%- if block.settings.scientific_name != blank -%}
                  <span class="c-botanicals__card-subtitle">{{ block.settings.scientific_name }}</span>
                {%- endif -%}
              </h3>
              {%- if block.settings.description != blank -%}
                <p class="c-botanicals__card-desc">{{ block.settings.description }}</p>
              {%- endif -%}
            </div>
          </div>
        {%- endfor -%}
      </div>
    </div>

    <div class="c-botanicals__dots" id="c-dots-{{ section.id }}">
      {%- for block in section.blocks -%}
        <button class="c-botanicals__dot {% if forloop.first %}active{% endif %}" aria-label="Slide {{ forloop.index }}"></button>
      {%- endfor -%}
    </div>

  </div>
</div>

<style>
  /* Importación de fuentes base */
  @import url('https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Playfair+Display:ital,wght@1,400;1,500&display=swap');

  #c-botanicals-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    overflow: hidden;
  }

  /* El contenedor ocupa 100% para poder "sangrar" a los lados */
  #c-botanicals-{{ section.id }} .c-botanicals__container {
    max-width: 100%; 
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  /* Padding dinámico para centrar elementos a 1320px máx, pero permitiendo sangrado */
  #c-botanicals-{{ section.id }} .c-botanicals__header,
  #c-botanicals-{{ section.id }} .c-botanicals__dots {
    padding-left: max(40px, calc((100vw - 1320px) / 2));
    padding-right: max(40px, calc((100vw - 1320px) / 2));
  }

  /* --- HEADER --- */
  #c-botanicals-{{ section.id }} .c-botanicals__header {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #c-botanicals-{{ section.id }} .c-botanicals__subheading {
    margin: 0;
    color: {{ section.settings.subheading_color }};
    font-size: {{ section.settings.subheading_size_desktop }}px;
    font-weight: {{ section.settings.subheading_weight }};
    font-family: 'Playfair Display', Georgia, serif !important;
    font-style: {% if section.settings.subheading_italic %}italic{% else %}normal{% endif %};
  }

  #c-botanicals-{{ section.id }} .c-botanicals__heading {
    margin: 0;
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size_desktop }}px;
    font-weight: {{ section.settings.heading_weight }};
    font-family: 'Raleway', sans-serif;
    line-height: 1.2;
  }

  /* --- SLIDER TRACK --- */
  #c-botanicals-{{ section.id }} .c-botanicals__slider-wrapper {
    width: 100%;
    position: relative;
  }

  #c-botanicals-{{ section.id }} .c-botanicals__track {
    display: flex;
    gap: {{ section.settings.card_gap_desktop }}px;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none; 
    -ms-overflow-style: none;
    padding-bottom: 20px;
    
    padding-left: max(40px, calc((100vw - 1320px) / 2));
    padding-right: max(40px, calc((100vw - 1320px) / 2));
    scroll-padding-left: max(40px, calc((100vw - 1320px) / 2));
  }

  #c-botanicals-{{ section.id }} .c-botanicals__track::-webkit-scrollbar {
    display: none;
  }

  /* --- CARDS --- */
  #c-botanicals-{{ section.id }} .c-botanicals__card {
    flex: 0 0 {{ section.settings.card_width_desktop }}px;
    height: {{ section.settings.card_height_desktop }}px;
    position: relative;
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    scroll-snap-align: start;
    background: transparent;
    display: flex;
    flex-direction: column;
  }

  #c-botanicals-{{ section.id }} .c-botanicals__card-image {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  #c-botanicals-{{ section.id }} .c-botanicals__card-image img,
  #c-botanicals-{{ section.id }} .c-botanicals__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  /* --- FROSTED GLASS CONTENT CON EFECTO FADE-OUT ARRIBA --- */
  #c-botanicals-{{ section.id }} .c-botanicals__card-content {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    
    /* Damos más padding arriba para que el desvanecimiento no se coma el texto */
    padding: 30px 32px 36px 32px; 
    z-index: 2;
    background: #ffffffdb;
    
    /* El blur nativo */
    backdrop-filter: blur({{ section.settings.blur_intensity }}px);
    -webkit-backdrop-filter: blur({{ section.settings.blur_intensity }}px);
  

    display: flex;
    flex-direction: column;
    gap: 12px;
    
    /* Borde redondeado sólo abajo */
    border-bottom-left-radius: {{ section.settings.card_radius }}px;
    border-bottom-right-radius: {{ section.settings.card_radius }}px;
  }

  #c-botanicals-{{ section.id }} .c-botanicals__card-title {
    margin: 0;
    font-family: 'Raleway', sans-serif;
    color: {{ section.settings.title_color }};
    font-size: {{ section.settings.title_size_desktop }}px;
    font-weight: {{ section.settings.title_weight }};
    line-height: 1.1;
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 6px;
    letter-spacing: -0.5px;
  }

  #c-botanicals-{{ section.id }} .c-botanicals__card-subtitle {
    color: var(--Dark-Green, {{ section.settings.subtitle_color }});
    font-family: var(--Body, "Test Söhne"), sans-serif;
    font-size: var(--Text-X-Small, {{ section.settings.subtitle_size_desktop }}px);
    font-weight: {{ section.settings.subtitle_weight }};
    font-style: {% if section.settings.subtitle_italic %}italic{% else %}normal{% endif %};
    line-height: 140%;
    letter-spacing: 0.36px;
  }

  #c-botanicals-{{ section.id }} .c-botanicals__card-desc {
    margin: 0;
    font-family: 'Raleway', sans-serif;
    color: {{ section.settings.desc_color }};
    font-size: {{ section.settings.desc_size_desktop }}px;
    font-weight: {{ section.settings.desc_weight }};
    line-height: 1.45;
  }

  /* --- DOTS --- */
  #c-botanicals-{{ section.id }} .c-botanicals__dots {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    gap: 8px;
    margin-top: -10px;
  }

  #c-botanicals-{{ section.id }} .c-botanicals__dot:nth-last-child(-n+3) {
    display: none;
  }

  #c-botanicals-{{ section.id }} .c-botanicals__dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: {{ section.settings.dot_color | color_modify: 'alpha', 0.4 }};
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  #c-botanicals-{{ section.id }} .c-botanicals__dot.active {
    width: 32px;
    border-radius: 10px;
    background-color: {{ section.settings.dot_color }};
  }

  /* --- RESPONSIVE (MÓVIL) --- */
  @media screen and (max-width: 768px) {
    #c-botanicals-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    #c-botanicals-{{ section.id }} .c-botanicals__container {
      gap: 30px;
    }

    #c-botanicals-{{ section.id }} .c-botanicals__header,
    #c-botanicals-{{ section.id }} .c-botanicals__dots {
      padding-left: 20px;
      padding-right: 20px;
    }

    /* Tipografía Móvil */
    #c-botanicals-{{ section.id }} .c-botanicals__subheading {
      font-size: {{ section.settings.subheading_size_mobile }}px;
    }

    #c-botanicals-{{ section.id }} .c-botanicals__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
    }

    #c-botanicals-{{ section.id }} .c-botanicals__card-title {
      font-size: {{ section.settings.title_size_mobile }}px;
    }

    #c-botanicals-{{ section.id }} .c-botanicals__card-subtitle {
      font-size: {{ section.settings.subtitle_size_mobile }}px;
    }

    #c-botanicals-{{ section.id }} .c-botanicals__card-desc {
      font-size: {{ section.settings.desc_size_mobile }}px;
    }

    /* Cards Móvil */
    #c-botanicals-{{ section.id }} .c-botanicals__track {
      gap: {{ section.settings.card_gap_mobile }}px;
      padding-left: 20px;
      padding-right: 20px; 
      scroll-padding-left: 20px;
    }

    #c-botanicals-{{ section.id }} .c-botanicals__card {
      flex: 0 0 {{ section.settings.card_width_mobile }}vw;
      height: {{ section.settings.card_height_mobile }}px;
    }

    #c-botanicals-{{ section.id }} .c-botanicals__card-content {
      /* Ajustamos el desvanecimiento para móvil */
      padding: 28px 20px 28px 20px; 
    }

    #c-botanicals-{{ section.id }} .c-botanicals__dots {
      display: flex;
      justify-content: center;
      margin-top: 0;
    }

    #c-botanicals-{{ section.id }} .c-botanicals__dot:nth-last-child(-n+3) {
      display: inline-block;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('c-botanicals-{{ section.id }}');
    if (!section) return;

    const track = section.querySelector('#c-track-{{ section.id }}');
    const dots = section.querySelectorAll('#c-dots-{{ section.id }} .c-botanicals__dot');
    const cards = section.querySelectorAll('.c-botanicals__card');

    if (!track || dots.length === 0 || cards.length === 0) return;

    // Actualizar dots según el scroll
    track.addEventListener('scroll', () => {
      let scrollLeft = track.scrollLeft;
      let cardWidth = cards[0].offsetWidth;
      let gap = parseInt(window.getComputedStyle(track).gap) || 0;
      
      let activeIndex = Math.round(scrollLeft / (cardWidth + gap));
      
      dots.forEach((dot, index) => {
        if (index === activeIndex) {
          dot.classList.add('active');
        } else {
          dot.classList.remove('active');
        }
      });
    });

    // Click en los dots para scrollear
    dots.forEach((dot, index) => {
      dot.addEventListener('click', () => {
        let cardWidth = cards[0].offsetWidth;
        let gap = parseInt(window.getComputedStyle(track).gap) || 0;
        track.scrollTo({
          left: index * (cardWidth + gap),
          behavior: 'smooth'
        });
      });
    });
  });
</script>

