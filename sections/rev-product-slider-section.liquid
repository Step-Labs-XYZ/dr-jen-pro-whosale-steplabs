<div id="rev-product-slider-{{ section.id }}" class="rev-product-slider-section">
 <div class="container">
  <div class="rev-carousel-heading-container">
    <h2 class="rev-carousel-heading">{{ section.settings.heading }}</h2>
    <a href="{{ section.settings.button_url }}" class="rev-carousel-button">
      {{ section.settings.button_text }}
    </a>
  </div>
  
  <div class="rev-product-carousel">
    {% assign products = section.settings.products %}
    {% if section.settings.collection %}
      {% assign products = section.settings.collection.products %}
    {% endif %}
    {% assign limited_products = products %}
    {% for product in limited_products limit: section.settings.limit_products %}
      <div class="rev-product-item">
        <a href="{{ product.url }}">
          <div class="product-image-container">
            <img src="{{ product.featured_image | img_url: '600x600' }}" alt="{{ product.title }}">
            <!-- Add to Cart Button Icon -->
            {%- if product.variants.size >= 1 -%}
        {%- capture form_id -%}product_form_{{ section.id }}_{{ block.id }}_{{ product.id }}_{% increment product_form_index %}{%- endcapture -%}
        {%- form 'product', product, is: 'product-form', id: form_id, class: 'product-item__quick-form--visible' -%}
          <input type="hidden" name="quantity" value="1">
          <input type="hidden" name="id" value="{{ product.first_available_variant.id }}">
          <input type="hidden" name="properties[_compare_price]" value="{{ product.compare_at_price }}" />
          <!-- <button is="loader-button" type="submit" class="button button--outline button--text button--full {% if section.settings.desktop_products_per_row >= 5 %}button--small{% endif %} hidden-touch">{{ 'collection.product.add_to_cart_short' | t }}</button> -->
          <button type="submit" class="button add-to-cart-button  button--text ">
            {% render 'add-to-cart-icon' %}
          </button>
        {%- endform -%}
      {%- endif -%}
          </div>
        </a>
        <div class="product-details">
         <p class="title">{{ product.title }}</p>
        <!-- Okendo Review Stars -->
        <div class="okendo-stars">
           {%- render 'product-rating', product: product -%}
        </div>
        <!-- Price Range -->
        <div class="price-range">
          {% if product.price_varies %}
            <span>{{ product.price_min | money }} - {{ product.price_max | money }}</span>
          {% else %}
            <span>{{ product.price | money }}</span>
          {% endif %}
        </div>
        </div>
      </div>
    {% endfor %}
  </div>
<div class="button-mob">
   <a class="mobile-only" href="{{ section.settings.button_url }}" class="rev-carousel-button">
      {{ section.settings.button_text }}
    </a>
</div>
 </div>
</div>

