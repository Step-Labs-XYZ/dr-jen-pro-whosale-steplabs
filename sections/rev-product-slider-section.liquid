 <script>
    // Select all buttons with the class 'add-to-cart-button'
    const buttons = document.querySelectorAll('.rev-product-slider-section .add-to-cart-button');

    // Function to lock button text
    function lockButtonContent(button, originalContent) {
        // Add event listeners to prevent any changes on various events
        button.addEventListener('click', () => {
            button.innerHTML = originalContent;
        });

        button.addEventListener('input', () => {
            button.innerHTML = originalContent;
        });

        button.addEventListener('DOMSubtreeModified', () => {
            if (button.innerHTML !== originalContent) {
                button.innerHTML = originalContent;
            }
        });
    }

    // Loop through each button and lock its content
    buttons.forEach((button) => {
        const originalContent = button.innerHTML;

        // Lock the content on page load
        lockButtonContent(button, originalContent);

        // Ensure the content is locked even after changes by using a MutationObserver
        const observer = new MutationObserver(function (mutationsList) {
            mutationsList.forEach(function (mutation) {
                if (mutation.type === 'childList') {
                    // Revert back to original content if changed
                    if (button.innerHTML !== originalContent) {
                        button.innerHTML = originalContent;
                    }
                }
            });
        });

        // Start observing each button for changes
        observer.observe(button, { childList: true, subtree: true });
    });
</script>

{% schema %}
{
  "name": "Rev Product Slider",
  "settings": [
    {
      "type": "collection",
      "id": "collection",
      "label": "Select Collection"
    },
    {
      "type": "product_list",
      "id": "products",
      "label": "Select Products",
      "limit": 12
    },
    {
      "type": "range",
      "id": "limit_products",
      "label": "Limit Products",
      "default": 6,
      "min": 6,
      "max":12
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button URL"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Button Text",
      "default": "Shop Now"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Text Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_bg_color",
      "label": "Button Background Color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button Text Color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    {
      "name": "Rev Product Slider",
      "category": "Custom"
    }
  ]
}
{% endschema %}