<!-- Script -->
<script>
  document.querySelectorAll('#rev-accordion-egg .accordion-header').forEach(function(header) {
    header.addEventListener('click', function() {
      // Close all other accordion items
      document.querySelectorAll('#rev-accordion-egg .accordion-content').forEach(function(content) {
        content.style.display = 'none';
      });

      document.querySelectorAll('#rev-accordion-egg .accordion-icon').forEach(function(icon) {
        icon.textContent = '+';
      });

      // Toggle the clicked accordion
      var content = header.nextElementSibling;
      var icon = header.querySelector('.accordion-icon');
      if (content.style.display === 'block') {
        content.style.display = 'none';
        icon.textContent = '+';
      } else {
        content.style.display = 'block';
        icon.textContent = '-';
      }
    });
  });
</script>
{% schema %}
{
  "name": "Rev Accordion Section egg",
  "settings": [
    {
      "type": "image_picker",
      "id": "bg_image_desktop",
      "label": "Background Image for Desktop"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "BG Color",
      "default": "#ffffff"
    },
    {
      "type": "image_picker",
      "id": "bottom_left_image",
      "label": "Bottom Left Image"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Frequently Asked Questions"
    },
      {
      "type": "color",
      "id": "hd_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
  ],
  "blocks": [
    {
      "type": "accordion_block",
      "name": "Accordion Block",
      "settings": [
        {
          "type": "text",
          "id": "accordion_question",
          "label": "Accordion Question (Heading)"
        },
        {
          "type": "richtext",
          "id": "accordion_answer",
          "label": "Accordion Answer"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text Color",
          "default": "#000000"
        }

      ]
    }
  ],
  "presets": [
    {
      "name": "Rev Accordion Section Egg",
      "category": "Custom Sections"
    }
  ]
}
{% endschema %}