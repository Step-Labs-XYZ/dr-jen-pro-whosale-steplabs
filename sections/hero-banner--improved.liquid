<style>
@media (min-width: 1024px) {
.hero-banner--improved{
background-image:url('{{section.settings.desktop_image | img_url:'master'}}')  
}  
}
</style>
{{ 'hero-banner--improved.css' | asset_url | stylesheet_tag }}

<div class="hero-banner--improved">
    <div class="hero__banner--mobile">
    <img src="{{section.settings.mobile_image | img_url:'master'}}"  class="" />    
    </div>
    <div class="container">
        <div class="hero__wrapper">          
          <h1 class="hero__heading">
            {{section.settings.heading}}
          </h1>
          <p class="hero__desc">
            {{section.settings.subheading}}
          </p>
          <a href="{{section.settings.button_link}}" class="button button--primary imageAbButton btn--dj hero__cta" style="background-color: {{section.settings.button_color}};">
            {{section.settings.button_text}}
          </a>
        </div>
    </div>
</div>


{% schema %}
{
   "name": "Hero banner - improved",
    "class": "ss--hero-banner--improved",
    "tag": "section",
   "settings" : [
    {
        "type": "text",
        "id": "heading",
        "label": "Heading"
    },
    {
        "type": "select",
        "id": "heading_size",
        "label": "Heading Font Size",
        "options": [
          {
            "value": "3.5vw",
            "label": "3.5vw"
            },
            {
            "value": "5vw",
            "label": "5vw"
            },
            {
            "value": "5.5vw",
            "label": "5.5vw"
            },            
            {
            "value": "6vw",
            "label": "6vw"
            },
            {
            "value": "6.5vw",
            "label": "6.5vw"
            },            
            {
            "value": "7vw",
            "label": "7vw"
            },
            {
            "value": "7.5vw",
            "label": "7.5vw"
            },            
            {
            "value": "8vw",
            "label": "8vw"
            },
            {
            "value": "8.5vw",
            "label": "8.5vw"
            },            
            {
            "value": "9vw",
            "label": "9vw"
            },
            {
            "value": "9.5vw",
            "label": "9.5vw"
            },            
            {
            "value": "10vw",
            "label": "10vw"
            }                          
        ],
        "default": "3.5vw"

    },
    {
        "type": "textarea",
        "id": "subheading",
        "label": "Sub Heading"
    },
    {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
    },
    {
        "type": "text",
        "id": "button_text",
        "label": "Button Text"
    },
    {
        "type": "color",
        "id": "button_color",
        "label": "Button Color",
        "default": "#df477f"
    },
    {
        "type": "header",
        "content": "Homepage Banner Images"
    },
    {
        "type": "image_picker",
        "id": "desktop_image",
        "label": "Desktop Image"
    },
    {
        "type": "image_picker",
        "id": "mobile_image",
        "label": "Mobile Image"
    },
    {
        "type": "select",
        "id": "height_selector",
        "label": "Mobile Image Height",
        "options": [
          {
            "value": "small",
            "label": "Small 612px"
          },
          {
            "value": "large",
            "label": "Large 812px"
          }
        ]
    }
   ],
   "presets": [
    {
        "name": "Hero banner - improved"
    }
   ]
}
{% endschema %}