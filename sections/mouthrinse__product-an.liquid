

<div class="container--ss">
    <div class="row--ss row--mouthrinse__variant">     
      {% for variant in all_products["mouth-rinse"].variants %}
       <div class="col--ss">
            <div class="mouthrinse__variant" data-title="{{ variant.title }}">
              {% assign discount_percentage = variant.compare_at_price | minus: variant.price | times: 100.0 | divided_by: variant.compare_at_price | round: '0' | append: '%' %}
              {% assign variant_id = variant.id %}
                <div class="variant--visual">
                    {% if variant.compare_at_price %}
                      {% if variant.title == '2 Pack' %}
                      <div class="variant__ribbon pack--two">
                          <h5>
                              <span>MOST POPULAR - </span>Save {{ discount_percentage }}
                          </h5>
                      </div>
                      {% else %}
                      <div class="variant__ribbon pack--four">
                          <h5>
                              <span>BEST VALUE - </span>Save {{ discount_percentage }}
                          </h5>
                      </div>
                        {% endif %}
                    {% endif %}
                    <div class="variant__image">
                        <img src="{{ variant.image | image_url }}" alt="">
                    </div>
                </div>
                <div class="variant--details">
                    <h5 class="variant__title">
                      {{ all_products["mouth-rinse"].title }} - {{ variant.title }}
                    </h5>
                    <p class="variant__content">
                      {{ variant.metafields.custom.quantity_and_contains }}
                    </p>
