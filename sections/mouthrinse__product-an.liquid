                    </div>
                    {% if variant.compare_at_price %}
                      <h5 class="variant__price price--compare-at">
                        {{ variant.compare_at_price | money_with_currency }}
                      </h5>
                    {% endif %}
                    <h5 class="variant__price price--selling">
                      {{ variant.price | money_with_currency }}
                    </h5>
                    {% if variant.compare_at_price %}
                      <h6 class="variant__discount">
                          Save {{ discount_percentage }}
                      </h6>
                    {% endif %}
                    <div class="cta__wrapper">
                      {% if variant.inventory_management %}
                        {% if variant.inventory_quantity > 0 %}
                          <a href="/cart/add?id={{ variant_id }}&quantity=1" class="btn--dj btn--mouthrinse is--cranberry is--rounded has--border has--shadow">
                              Add to Cart
                          </a>
                        {% else %}
                          <a href="" class="btn--dj btn--mouthrinse is--rounded has--border has--shadow is--disabled">
                              Sold Out
                          </a>
                        {% endif %}
                      {% else %}
                        <button data-variant-id="{{ variant_id }}" data-price-max="{% if variant.compare_at_price > 0 %}{{ variant.compare_at_price }}{% else %}0{% endif %}" class="btn--dj btn--mouthrinse is--cranberry is--rounded has--border has--shadow">
                          Add to Cart
                        </button>
                      {% endif %}
                        <h5 class="note--moneyback">
                            30-DAY MONEY BACK GUARANTEE
                        </h5>
                    </div>
                </div>
            </div>
        </div>
      {% endfor %}
    </div>
</div>

{% schema %}
  {
    "name": "Mouthrinse variants",
    "class": "section__padding mouthrinse__product ss--mouthrinse__product-an",
    "tag": "section",
    "settings": [],
    "presets": [
      {
        "name": "Mouthrinse variants",
        "category": "Mouthrinse page"
      }
    ]
  }
{% endschema %}

{% stylesheet %}
{% endstylesheet %}

{% javascript %}
{% endjavascript %}

<script>
  document.addEventListener('click', function (e) {
    if(e.target.classList.contains('btn--mouthrinse')){
      let variant_id = e.target.dataset.variantId;
      let price_max = e.target.dataset.priceMax;
      let formData = {
      'items': [{
          'id': variant_id,
          'quantity': 1,
          'properties': {
            '_compare_price': price_max
        }
      }]
      }
 console.log(formData, price_max)
      fetch(window.Shopify.routes.root + 'cart/add.js', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json'
      },
      body: JSON.stringify(formData)
      })
      .then(response => {
        window.goCart.fetchAndOpenCart();
      })
      .catch((error) => {
        console.error('Error:', error);
      });
    }

  })
</script>