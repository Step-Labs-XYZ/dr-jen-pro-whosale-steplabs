<style>
.purpose_container{
    width: calc(50% - 60px);
    padding: 40px 80px;
}
.template-floss-wholesale .purpose_container{
    padding: 40px 25px 40px 80px;
}
.purpose_container h3{
  font-size: 26px;
}
.feature_wholesale_container{
display: flex;
flex-wrap: wrap;
column-gap: 60px;
padding: 0 0 50px;
}
.template-mouth-rinse-pdp .feature_wholesale_container{
padding: 0;
}
.feature_wholesale_container .features ul{
display: grid;
grid-template-columns: 1fr 1fr;
column-gap: 40px;
padding: 0 40px 20px 117px;
}
.icons_features__container{
display: grid;
grid-template-columns: 1fr 1fr 1fr;
background: #F9F9F9;
padding: 20px 100px 0 0
}
.icons_features__container p{
color: #2D3852;
max-width: 150px;
font-size: 14px;
text-align: center
}
.icon_f{
text-align: center;
display: flex;
flex-flow: column;
align-items: center;
}
.ingrediente_f{
width: 50%;
background: #EEFDFF;
padding: 45px;
}
.features h3{
padding-left: 80px;
font-size: 26px;
margin: 0;
}
.features{
width: 100%;
background: #F9F9FA;
display: grid;
grid-template-columns: 1fr 1fr;
padding: 30px 0;
}
.ingrediente_f h3{
font-size: 26px;
margin: 0;
}
.feature_for_mobile .icon_f{
    padding: 0;
}
/* Style the buttons inside the tab */
.tab button {
  background-color: #2D3852;
  color: #fff;
  font-weight: 600;
  border: none;
  outline: none;
  cursor: pointer;
  padding: 14px 16px;
  transition: 0.3s;
  font-size: 17px;
}

/* Create an active/current tablink class */
.tab button.active {
 color: #8CD3CF;
}

/* Style the tab content */
.tabcontent {
  display: none;
  padding: 6px 20px;
}
.feature_for_mobile .icons_features__container{
    width: 100%;
}
@media screen and (min-width: 999px) {
    .feature_for_mobile{
        display: none;
    }
    .feature_wholesale_container{
        display: flex;
    }
}
@media screen and (max-width: 1000px) {
    .feature_for_mobile{
        display: block;
    }
    .feature_for_mobile .tab{
        display: flex;
    }
    .purpose_container{
        display: none;
    }
    .icons_features__container{
        padding: 20px 7px;
    }
    .icons_features__container p{
        font-size: 12px;
    }
    .feature_wholesale_container .features, .feature_wholesale_container .ingrediente_f{
        display: none !important;
    }
    .feature_for_mobile #Features ul{
        display: grid;
        grid-template-columns: repeat(2, 1fr);
        column-gap: 25px;
        padding: 15px 20px;
    }
    .feature_for_mobile .tabcontent{
        font-size: 12px;
        padding-bottom: 15px;
    }
    .feature_for_mobile .tab button{
        margin-bottom: 15px;
    }
    .tablinks{
        width: 50%;
        text-align: center;
    }
    .feature_for_mobile button:first-child{
    border-right: 1px solid #fff;
    }
    .feature_for_mobile button:nth-child(2){
    border-right: 1px solid #fff;
    }
}
</style>
<script>

function opentab(evt, cityName) {
  var i, tabcontent, tablinks;
  tabcontent = document.getElementsByClassName("tabcontent");
  for (i = 0; i < tabcontent.length; i++) {
    tabcontent[i].style.display = "none";
  }
  tablinks = document.getElementsByClassName("tablinks");
  for (i = 0; i < tablinks.length; i++) {
    tablinks[i].className = tablinks[i].className.replace(" active", "");
  }
  document.getElementById(cityName).style.display = "block";
  evt.currentTarget.className += " active";
}

// Get the element with id="defaultOpen" and click on it
document.getElementById("defaultOpen").click();
</script>

