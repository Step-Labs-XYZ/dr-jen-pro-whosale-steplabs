<style>
  .homepage-1x4 .section__sub-heading{
    max-width: 55ch;
    margin-inline: auto;
    margin-block-end: 40px;
  }
  .homepage-1x4 .section__heading + .section__sub-heading{
    margin-block-start: 40px;
  }
</style>

<div class="container">
<div class="homepage-1x4">
    {% if section.settings.heading != blank %}
        <h3 class="section__heading">{{section.settings.heading}}</h3>
    {% endif %}

    {% if section.settings.subheading != '' %}
      <h4 class="section__sub-heading">
        {{section.settings.subheading}}
      </h4>
    {% endif %}

    <div class="homepage-1x4-icons">
        {% for block in section.blocks %}

            <div class="icon">
                <img src="{{block.settings.image | img_url: '200x'}}">
                {% if block.settings.title != blank  %}
                    <h5 class="content__title">{{ block.settings.title }}</h5>
                {% endif %}
                {% if block.settings.info != blank  %}
                  <p>{{ block.settings.info }}</p>
                {% endif %}
            </div>
            
        {% endfor %}
    </div>
</div>
</div>

{% schema %}
{
   "name": "Features icon - improved",
    "tag": "section",
  "class": "ss--features-icon--improved section__padding",
   "settings" : [

    {
        "type": "text",
        "id": "heading",
        "label": "Heading",
        "default": "Dr Jen Natural Toothpaste is like no other."
    },

    {
        "type": "richtext",
        "id": "subheading",
        "label": "Sub Heading",
        "default": "<p>Introducing our uniquely crafted natural toothpaste, created by a real dentist using nourishing & natural ingredients, and  proven to remineralize tooth enamel to prevent decay.</p>"
    },
    {
        "type": "textarea",
        "id": "override_css",
        "label": "CSS Override"
    }
   ],

   "blocks" : [
    {
        "name": "Icon Block",
        "type": "Icon-Block",
        "limit" : 4,
        "settings": [
            {
                "type": "image_picker",
                "id": "image",
                "label": "Icon"
            },
            {
                "type": "text",
                "id": "title",
                "label": "Icon Title"
            },
            {
                "type": "textarea",
                "id": "info",
                "label": "Icon Information"
            }
        ]
    }
   ],

   "presets": [
    {
        "name": "Features icon - improved"
    }
   ]
}
{% endschema %}