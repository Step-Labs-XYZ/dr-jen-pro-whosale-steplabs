            {% when 'variant_cards' %}
              {%- assign target_option = block.settings.option_name | downcase | strip -%}
              {%- assign cards_option = nil -%}
              {%- for option in product.options_with_values -%}
                {%- assign current_option = option.name | downcase | strip -%}
                {%- if current_option == target_option -%}
                  {%- assign cards_option = option -%}
                  {%- break -%}
                {%- endif -%}
              {%- endfor -%}
              {%- if cards_option == nil -%}
                {%- if product.options_with_values.size > 1 -%}
                  {%- assign cards_option = product.options_with_values[1] -%}
                {%- else -%}
                  {%- assign cards_option = product.options_with_values[0] -%}
                {%- endif -%}
              {%- endif -%}
              {%- if cards_option != nil and cards_option.values.size > 0 -%}
                <div class="c-prod__variant-group c-prod__variant-group--cards" data-cards-option-position="{{ cards_option.position }}" {{ block.shopify_attributes }}>
                  <div class="c-prod__option-name">{{ cards_option.name }}</div>
                  <div class="c-prod__cards">
                    {%- for value in cards_option.values -%}
                      {%- assign _card_pos_idx = cards_option.position | minus: 1 -%}
                      {%- assign _card_variant = nil -%}
                      {%- for v in product.variants -%}
                        {%- if v.options[_card_pos_idx] == value -%}
                          {%- assign _card_variant = v -%}
                          {%- break -%}
                        {%- endif -%}
                      {%- endfor -%}
                      {%- assign _card_pack_part = value | split: ' pack' | first | split: '(' | last | strip -%}
                      {%- assign _card_uc = _card_pack_part | plus: 0 -%}
                      {%- assign card_img = product.featured_image -%}
                      {%- for variant in product.variants -%}
                        {%- if variant.options contains value and variant.image -%}
                          {%- assign card_img = variant.image -%}
                          {%- break -%}
                        {%- endif -%}
                      {%- endfor -%}

                      <input type="radio" class="c-prod__radio js-variant-radio-{{ section.id }}" 
                             name="option-{{ cards_option.position }}" 
                             id="card-{{ section.id }}-{{ cards_option.position }}-{{ forloop.index }}" 
                             value="{{ value | escape }}" data-position="{{ cards_option.position }}"
                             {% if cards_option.selected_value == value %}checked{% endif %}>
                      
                      <label class="c-prod__card-label" for="card-{{ section.id }}-{{ cards_option.position }}-{{ forloop.index }}">
                        {% if forloop.index == 2 and block.settings.badge_2 != blank %}
                          <div
                            class="c-prod__card-badge"
                            data-badge-default="{{ block.settings.badge_2 | escape }}"
                            data-badge-orange="{{ block.settings.badge_2_orange_mango | escape }}"
                            data-badge-tpl-default="{{ block.settings.badge_2 | escape }}"
                            data-badge-tpl-orange="{{ block.settings.badge_2_orange_mango | escape }}"
                          >{{ block.settings.badge_2 }}</div>
                        {% endif %}
                        {% if forloop.index == 3 and block.settings.badge_3 != blank %}
                          <div
                            class="c-prod__card-badge"
                            style="background:#002C41; color:#fff;"
                            data-badge-default="{{ block.settings.badge_3 | escape }}"
                            data-badge-orange="{{ block.settings.badge_3_orange_mango | escape }}"
                            data-badge-tpl-default="{{ block.settings.badge_3 | escape }}"
                            data-badge-tpl-orange="{{ block.settings.badge_3_orange_mango | escape }}"
                          >{{ block.settings.badge_3 }}</div>
                        {% endif %}
                        {%- if _card_variant and block.settings.unit_label != blank -%}
                          <span class="c-prod__card-per-unit js-card-per-unit-{{ section.id }}" data-card-value="{{ value | escape }}" data-cards-opt-pos="{{ cards_option.position }}" data-unit-count="{{ _card_uc }}" data-unit-label="{{ block.settings.unit_label | escape }}">{{ block.settings.unit_label }}</span>
                        {%- endif -%}
                        <img src="{{ card_img | image_url: width: 150 }}" class="c-prod__card-img" alt="{{ value }}" data-default-src="{{ card_img | image_url: width: 150 }}">
                        <span class="c-prod__card-name">{{ value }}</span>
                        {%- if _card_variant -%}
                          <span class="c-prod__card-price js-card-price-{{ section.id }}" data-card-value="{{ value | escape }}" data-cards-opt-pos="{{ cards_option.position }}">{{ _card_variant.price | money }}</span>
                        {%- endif -%}
                      </label>
                    {%- endfor -%}
                  </div>
                </div>
              {%- endif -%}

            {% when 'subscription_offer_card' %}
              <div class="c-prod__sub-offer" {{ block.shopify_attributes }}>
                <div class="c-prod__sub-offer-media">
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 500 }}"
                      alt="{{ block.settings.title | escape }}"
                      loading="lazy"
                    >
                  {%- elsif product.featured_image != blank -%}
                    <img
                      src="{{ product.featured_image | image_url: width: 500 }}"
                      alt="{{ product.title | escape }}"
                      loading="lazy"
                    >
                  {%- endif -%}
                </div>
                <div class="c-prod__sub-offer-content">
                  <p class="c-prod__sub-offer-title">{{ block.settings.title }}</p>
                  {%- if block.settings.save_text != blank -%}
                    <p class="c-prod__sub-offer-save">{{ block.settings.save_text }}</p>
                  {%- endif -%}
                  <div class="c-prod__sub-offer-price-row">
                    <span class="c-prod__sub-offer-price">{{ block.settings.price_text }}</span>
                    {%- if block.settings.compare_price_text != blank -%}
                      <span class="c-prod__sub-offer-compare">{{ block.settings.compare_price_text }}</span>
                    {%- endif -%}
                  </div>
                </div>
                <div class="c-prod__sub-offer-cta-wrap">
                  <a href="{{ block.settings.cta_url | default: '#' }}" class="c-prod__sub-offer-cta">
                    {{ block.settings.cta_text }}
                    <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
                      <path d="M5 12H19" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
                      <path d="M12 5L19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </a>
                </div>
              </div>

            {% when 'product_upsell_card' %}
              {%- assign upsell_product = block.settings.product -%}
              {%- assign upsell_variant = upsell_product.selected_or_first_available_variant -%}
              {%- assign upsell_selling_plan_allocation = upsell_variant.selling_plan_allocations | first -%}
              {%- assign upsell_selling_plan_id = '' -%}
              {%- if upsell_selling_plan_allocation != blank and upsell_selling_plan_allocation.selling_plan != blank -%}
                {%- assign upsell_selling_plan_id = upsell_selling_plan_allocation.selling_plan.id -%}
              {%- endif -%}
              <div class="c-prod__sub-offer c-prod__sub-offer--upsell" {{ block.shopify_attributes }}>
                <div class="c-prod__sub-offer-media">
                  {%- if block.settings.image != blank -%}
                    <img
                      src="{{ block.settings.image | image_url: width: 500 }}"
                      alt="{{ block.settings.title | default: upsell_product.title | escape }}"
                      loading="lazy"
                    >
                  {%- endif -%}
                </div>
                <div class="c-prod__sub-offer-content">
                  <p class="c-prod__sub-offer-title">{{ block.settings.title }}</p>
                  <div class="c-prod__upsell-footer">
                    <div class="c-prod__upsell-meta">
                      {%- if block.settings.save_text != blank -%}
                        <p class="c-prod__sub-offer-save">{{ block.settings.save_text }}</p>
                      {%- endif -%}
                      <div class="c-prod__sub-offer-price-row">
                        <span class="c-prod__sub-offer-price">{{ block.settings.price_text }}</span>
                        {%- if block.settings.compare_price_text != blank -%}
                          <span class="c-prod__sub-offer-compare">{{ block.settings.compare_price_text }}</span>
                        {%- endif -%}
                      </div>
                    </div>
                    {%- if upsell_variant != blank -%}
                      <div class="c-prod__upsell-action">
                        <div class="c-prod__sub-offer-cta-wrap">
                          <div
                            class="c-prod__upsell-form"
                            data-product-id="{{ upsell_product.id }}"
                            data-variant-id="{{ upsell_variant.id }}"
                            data-selling-plan-id="{{ upsell_selling_plan_id }}"
                          >
                            <button type="button" class="c-prod__sub-offer-cta c-prod__sub-offer-cta--btn js-upsell-atc-{{ section.id }}">
                              {{ block.settings.btn_text | default: 'ADD TO CART' }}
                              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="14" viewBox="0 0 18 14" fill="none" aria-hidden="true">
                                <path d="M0.75 6.75H16.75M16.75 6.75L10.75 0.75M16.75 6.75L10.75 12.75" stroke="#002C41" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                              </svg>
                            </button>
                          </div>
                        </div>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              </div>

