   Designed for the Subscription Widget custom CSS field.
   Uses ::part() selectors per Recharge docs.
*/
#c-prod-template--20492130353320__c_product_page_QCgTQb .c-prod__card-img {
    width: auto;
    height: 170px !important;
    object-fit: contain;
    margin-bottom: 12px;
}

#c-prod-template--27493728616724__c_product_page_rKyTxE .c-prod__badge-right--image {
    width: 100%!important;
    max-width: 150px !important;
}

@media (max-width: 899px) {
    #c-prod-template--27493728616724__c_product_page_rKyTxE .c-prod__badge-right {
              width: 110px !important;
        height: 110px !important;
    }
  }
#c-prod-template--27493728616724__c_product_page_rKyTxE .c-prod__badge-right {
    top: 40px!important;
    right: 1px!important;
}

#shopify-buyer-consent {
    margin-top: 1em;
    display: inline-block;
    width: 100%;
    color: #707170 !important;
    font-size: 12px !important;
}

.rc-content-wrap {
  display: grid;
  gap: 6px;
  font-family: Raleway, sans-serif;
  color: #0b3550;
}

::part(rc-content-wrap) {
  display: grid;
  gap: 6px;
}

::part(rc-purchase-option),
::part(rc-purchase-option__subscription),
::part(rc-purchase-option__onetime) {
  background: #ffffff;
  border: 1.5px solid #d3dbe1;
  border-radius: 14px;
  overflow: hidden;
  box-sizing: border-box;
}

::part(rc-purchase-option__subscription) {
  position: relative;
  padding: 42px 12px 8px;
  border-color: #003b5c;
  box-shadow: 0 0 0 1px #003b5c;  
  background: linear-gradient(180deg, #003b5c 0 42px, #ffffff 42px 100%);
}

::part(rc-purchase-option__subscription)::before {
  content: 'Subscribe';
  position: absolute;
  top: 0;
  left: 12px;
  height: 42px;
  display: flex;
  align-items: center;
  color: #ffffff;
  font-size: 18px;
  font-weight: 700;
  line-height: 1;
}

::part(rc-purchase-option__onetime) {
  padding: 10px 12px;
}

.rc-selection__onetime {
  position: relative;
  border: 1.5px solid #d3dbe1;
  border-radius: 14px;
}

.rc-selection__onetime[rc-selected] {
  border: 1.5px solid #003b5c;
  box-shadow: 0 0 0 1px #003b5c;
}

.rc-selection__onetime::after {
  content: 'Value of one-time purchase';
  display: block;
  margin-top: 6px;
  color: #8a8a8a;
  font-size: 11px;
  font-style: italic;
  line-height: 1.2;
}

::part(rc-purchase-option__badge) {
  position: absolute;
  top: 8px;
  right: 12px;
  z-index: 2;
  display: inline-flex;
  align-items: center;
  min-height: 28px;
  padding: 0 12px;
  border-radius: 999px;
  background: #e3f3ec;
  color: #0b3550;
  font-size: 13px;
  font-weight: 700;
  line-height: 1;
}

::part(rc-purchase-option__label) {
  display: grid;
  grid-template-columns: minmax(0, 1fr) auto;
  align-items: start;
  gap: 6px;
  color: #0b3550;
}

::part(rc-purchase-option__selector),
::part(rc-purchase-option__selector_subscription),
::part(rc-purchase-option__selector_onetime) {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  color: #0b3550;
  font-size: 17px;
  font-weight: 700;
  line-height: 1.1;
}

::part(rc-purchase-option__input) {
  width: 18px;
  height: 18px;
  margin: 0;
  accent-color: #0b63ce;
}

::part(rc-purchase-option__checked-indicator) {
  color: #0b63ce;
}

::part(rc-learn-more__trigger),
::part(rc-learn-more__trigger-compact) {
  color: #0b3550;
  font-size: 12px;
  font-weight: 600;
}

::part(rc-purchase-option__prices) {
  display: flex;
  flex-direction: row-reverse;
  align-items: baseline;
  gap: 4px;
  text-align: right;
  white-space: nowrap;
}

::part(rc-purchase-option__discounted-price),
::part(rc-purchase-option__price) {
  color: #0b3550;
  font-size: 14px;
  font-weight: 800;
  letter-spacing: -0.01em;
  line-height: 1;
}

::part(rc-purchase-option__original-price) {
  color: #7d7d7d;
  font-size: 13px;
  font-weight: 500;
  line-height: 1;
  text-decoration: line-through;
}

::part(rc-purchase-option__sub-container) {
  margin-top: 6px;
  padding-top: 6px;
  border-top: 1px solid #d9ebe5;
}

::part(rc-benefits__list) {
  margin: 0 0 6px;
  padding: 0;
  color: #0b3550;
  --rc-widget-bullet-icon-image-color: #0b63ce;
}

::part(rc-plans__label) {
  display: block;
  margin: 0 0 4px;
  color: #0b3550;
  font-size: 12px;
  font-weight: 700;
}

::part(rc-plans-dropdown),
::part(rc-plans-select) {
  width: 100%;
  min-height: 32px;
  border-radius: 8px;
  background: #ffffff;
  color: #1f455d;
  font-size: 12px;
  padding: 4px 8px;
  box-sizing: border-box;
}

@media (max-width: 749px) {
  ::part(rc-purchase-option__subscription) {
    padding: 38px 10px 6px;
    background: linear-gradient(180deg, #003b5c 0 38px, #ffffff 38px 100%);
  }

  ::part(rc-purchase-option__subscription)::before {
    left: 10px;
    height: 38px;
    font-size: 12px;
  }

  ::part(rc-purchase-option__badge) {
    top: 6px;
    right: 8px;
    min-height: 20px;
    padding: 0 6px;
    font-size: 10px;
  }

  ::part(rc-purchase-option__onetime) {
    padding: 8px 10px;
  }

  .rc-selection__onetime::after {
    margin-top: 4px;
    font-size: 10px;
  }

  ::part(rc-purchase-option__selector),
  ::part(rc-purchase-option__selector_subscription),
  ::part(rc-purchase-option__selector_onetime) {
    font-size: 13px;
  }

  ::part(rc-purchase-option__discounted-price),
  ::part(rc-purchase-option__price) {
    font-size: 13px;
  }

  ::part(rc-purchase-option__original-price) {
    font-size: 11px;
  }
}


  /* IMPORTACIÓN DE FUENTE RALEWAY */
  @import url('https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400&display=swap');
shopify-accelerated-checkout {
    --shopify-accelerated-checkout-button-block-size: var(--button-height) !important;
    --shopify-accelerated-checkout-button-border-radius: var(--button-border-radius) !important;
}
  /* =========================================
     AISLAMIENTO TOTAL POR SECCIÓN
     ========================================= */
  #c-prod-{{ section.id }} {
    --cp-bg-page: {{ section.settings.bg_color }};
    --cp-bg-gallery: {{ section.settings.gallery_bg }};
    --cp-text-dark: #002C41; 
    --button-border-radius: 30px;
    --cp-text-light: #6b7280;
    --cp-accent: #0b5ee7; 
    --cp-badge-bg: #d1e8e2; 
    --cp-badge-text: #004b40;
    
    font-family: 'Raleway', sans-serif;
    background-color: var(--cp-bg-page);
    padding-top: {{ section.settings.pad_top_mob }}px;
    padding-bottom: {{ section.settings.pad_bot_mob }}px;
  }

  #c-prod-{{ section.id }} .c-prod__wrapper {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: 1fr;
    gap: 40px;
  }

  /* =========================================
     GALERÍA (IZQUIERDA)
     ========================================= */
  #c-prod-{{ section.id }} .c-prod__gallery {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  #c-prod-{{ section.id }} .c-prod__main-view {
    background-color:#F8F6F6;
    border-radius: 16px;
    aspect-ratio: 1 / 1;
    width: 100%;
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  #c-prod-{{ section.id }} .c-prod__main-img {
    width: auto;
    height: auto;
    border-radius:20px;
    object-fit: contain;
    transition: opacity 0.3s ease;
  }

  /* Badges Imagen */
  #c-prod-{{ section.id }} .c-prod__badge-left {
    position: absolute;
    top: 20px;
    left: 20px;
    background-color: #D6ECE6;
    color: var(--cp-text-dark);
    border: 1px solid var(--cp-text-dark);
    padding: 6px 14px;
    border-radius: 30px;
    font-size: 12px;
    font-weight: 700;
    z-index: 2;
  }
  #c-prod-{{ section.id }} .c-prod__badge-left--image {
    border: none;
    padding: 0;
    background: transparent;
    width: 50%;
    max-width: 110px;
  }
  #c-prod-{{ section.id }} .c-prod__badge-left-img {
    display: block;
    width: 100%;
    height: auto;
  }

  #c-prod-{{ section.id }} .c-prod__badge-right {
    position: absolute;
    top: 61px;
    right: 176px;
    background-color: var(--cp-text-dark);
    color: #fff;
    width: 100px;
    height: 100px;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 10px;
    line-height: 1.1;
    z-index: 2;
  }
  #c-prod-{{ section.id }} .c-prod__badge-right--image {
    background: transparent;
    padding: 0;
    width: 50%;
    max-width: 110px;
    height: auto;
    aspect-ratio: 1 / 1;
  }
  #c-prod-{{ section.id }} .c-prod__badge-right-img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }
  #c-prod-{{ section.id }} .c-prod__badge-right strong { font-size: 28px; font-weight: 800; }
  #c-prod-{{ section.id }} .c-prod__badge-right span { font-size: 10px; font-weight: 600; text-transform: uppercase; }

  /* Thumbnails */
  #c-prod-{{ section.id }} .c-prod__thumbs {
    display: flex;
    gap: 10px;
    overflow-x: auto;
    scrollbar-width: none;
  }
  #c-prod-{{ section.id }} .c-prod__thumbs::-webkit-scrollbar { display: none; }

  #c-prod-{{ section.id }} .c-prod__thumb-item {
    width: 70px;
    height: 70px;
    flex-shrink: 0;
    border: 0px solid transparent;
    border-radius: 8px;
    background-color: var(--cp-bg-gallery);
    cursor: pointer;
    transition: all 0.2s;
  }
  #c-prod-{{ section.id }} .c-prod__thumb-item.is-active { border-color: var(--cp-text-dark); }
  #c-prod-{{ section.id }} .c-prod__thumb-item img { width: 100%; height: 100%; object-fit: cover; }

  /* =========================================
     INFORMACIÓN (DERECHA - BLOQUES)
     ========================================= */
  #c-prod-{{ section.id }} .c-prod__info {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }
  #c-prod-{{ section.id }} .c-prod__form {
    display: flex;
    flex-direction: column;
    gap: 16px;
  }

  /* Bloque: Reviews */
  #c-prod-{{ section.id }} .c-prod__reviews { display: flex; align-items: center; gap: 8px; font-size: 13px; color: var(--cp-text-light); flex-wrap: nowrap; }
  #c-prod-{{ section.id }} .c-prod__reviews-stars { color: var(--cp-accent); letter-spacing: 0; display: inline-flex; gap: 2px; flex-shrink: 0; }
  #c-prod-{{ section.id }} .c-prod__reviews > span,
  #c-prod-{{ section.id }} .c-prod__reviews > a { white-space: nowrap; }
  #c-prod-{{ section.id }} .c-prod__reviews a { color: var(--cp-text-light); text-decoration: underline; }

  /* Bloque: Title */
  #c-prod-{{ section.id }} .c-prod__title { font-size: 32px; font-weight: 600; color: var(--cp-text-dark); line-height: 1.2; margin: 0; }
  #c-prod-{{ section.id }} .c-prod__title-secondary { font-size: 32px; font-weight: 600; color: var(--cp-text-dark); line-height: 1.25; margin: 0; }
  #c-prod-{{ section.id }} .c-prod__title-secondary-line2 { font-size: 25px; font-weight: 600; color: var(--cp-text-dark); line-height: 1.3; margin: 4px 0 0; }

  /* Bloque: Price & Stock */
  #c-prod-{{ section.id }} .c-prod__price-wrap { display: flex; align-items: center; gap: 25px; }
  #c-prod-{{ section.id }} .c-prod__payment-terms { font-size: 12px; color: var(--cp-text-light); margin-top: 4px; }
  #c-prod-{{ section.id }} .c-prod__price { font-size: 20px; font-weight: 700; color: var(--cp-text-dark); }
  #c-prod-{{ section.id }} .c-prod__stock { display: flex; align-items: center; gap: 10px; font-size: 16px; color:#000; }
  #c-prod-{{ section.id }} .c-prod__retail-text { color: var(--Dark-Green, #002C41); font-family: var(--Body, Raleway); font-size: var(--Text-Regular, 16px); font-style: normal; font-weight: 400; line-height: 120%; margin-top: 4px; }
  #c-prod-{{ section.id }} .c-prod__desc-block,
  #c-prod-{{ section.id }} .c-prod__desc-block p { color: var(--Dark-Green, #002C41); font-family: var(--Body, Raleway); font-size: var(--Text-Regular, 16px); font-style: normal; font-weight: 400; line-height: 120%; }
  #c-prod-{{ section.id }} .c-prod__desc-block { margin-top: 8px; }
  #c-prod-{{ section.id }} .c-prod__per-unit { font-family: var(--Body, Raleway); font-size: var(--Text-Regular, 16px); font-weight: 400; color: var(--cp-text-dark); margin-left: 10px; }
  @keyframes c-prod-pulse {
    0%   { box-shadow: 0 0 0 0 rgba(var(--cp-badge-bg-rgb, 0,168,107), 0.55); transform: scale(1); }
    60%  { box-shadow: 0 0 0 7px rgba(var(--cp-badge-bg-rgb, 0,168,107), 0); transform: scale(1.15); }
    100% { box-shadow: 0 0 0 0 rgba(var(--cp-badge-bg-rgb, 0,168,107), 0); transform: scale(1); }
  }
  #c-prod-{{ section.id }} .c-prod__stock-dot {
    width: 14px; height: 14px; border-radius: 50%;
    background-color: #CDFFF1;
    display: inline-block; flex-shrink: 0;
    animation: c-prod-pulse 1.8s ease-in-out infinite;
  }

  /* Bloque: Highlight */
  #c-prod-{{ section.id }} .c-prod__highlight {
    background-color: var(--cp-badge-bg);
    color: var(--cp-badge-text);
    padding: 8px 16px;
    border-radius: 50px;
    font-size: 12px;
    font-weight: 700;
    margin-bottom:5px;
    display: inline-table;
  }

  /* Bloque: Text Link */
  #c-prod-{{ section.id }} .c-prod__link {
    font-size: 13px; font-weight: 700; color: var(--cp-text-dark);
    text-decoration: none; display: inline-flex; align-items: center; gap: 6px;
    text-transform: uppercase;
  }

  /* =========================================
     VARIANTES
     ========================================= */
  #c-prod-{{ section.id }} .c-prod__variant-group { display: flex; flex-direction: column; gap: 12px; }
  #c-prod-{{ section.id }} .c-prod__option-name { font-weight: 700; font-size: 15px; color: var(--cp-text-dark); }
  #c-prod-{{ section.id }} .c-prod__radio { display: none; }

  /* Píldoras (Sabores) */
  #c-prod-{{ section.id }} .c-prod__pills { display: flex; flex-wrap: wrap; gap: 10px; }
  #c-prod-{{ section.id }} .c-prod__pill-label {
    display: flex; align-items: center; gap: 10px; padding: 10px 18px;
    border: 1.5px solid #d1d5db; border-radius: 5px; font-size: 14px; font-weight: 600;
    cursor: pointer; transition: all 0.2s; color: #6b7280; background: #fff;
  }
  #c-prod-{{ section.id }} .c-prod__radio:checked + .c-prod__pill-label {
    border: 2px solid #002C41;
    color: #002C41;
    background-color: var(--pill-selected-bg, #e8f5f2);
  }
  #c-prod-{{ section.id }} .c-prod__pill-dot { display: flex; flex-shrink: 0; }
  #c-prod-{{ section.id }} .c-prod__pill-check { display: none; flex-shrink: 0; }
  #c-prod-{{ section.id }} .c-prod__radio:checked + .c-prod__pill-label .c-prod__pill-dot { display: none; }
  #c-prod-{{ section.id }} .c-prod__radio:checked + .c-prod__pill-label .c-prod__pill-check { display: flex; }

  /* Tarjetas (Cantidades) */
  #c-prod-{{ section.id }} .c-prod__cards { display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px; }
  #c-prod-{{ section.id }} .c-prod__card-label {
    display: flex; flex-direction: column; align-items: center; padding: 20px 10px 15px;
    border: 1px solid #d1d5db; border-radius: 8px; cursor: pointer; transition: all 0.2s;
    position: relative; background: #fff;
  }
  #c-prod-{{ section.id }} .c-prod__card-img { width: auto; height: 140px; object-fit: contain; margin-bottom: 12px; }
  #c-prod-{{ section.id }} .c-prod__card-name { color: #000; text-align: center; font-family: var(--Body, Raleway); font-size: var(--Text-Small, 14px); font-style: normal; font-weight: 400; line-height: 120%; }
  #c-prod-{{ section.id }} .c-prod__card-price { color: #000; text-align: center; font-family: var(--Body, Raleway); font-size: var(--Text-Small, 14px); font-style: normal; font-weight: 700; line-height: 120%; }
  #c-prod-{{ section.id }} .c-prod__card-per-unit { color: #000; text-align: center; font-family: var(--Body, Raleway); font-size: var(--Text-Small, 14px); font-style: normal; font-weight: 700; line-height: 120%; }
  #c-prod-{{ section.id }} .c-prod__card-badge {
    position: absolute; top: -10px; background-color: var(--cp-badge-bg); color: var(--cp-text-dark);
    font-size: 10px; font-weight: 700; padding: 4px 10px; border-radius: 30px; white-space: nowrap; border: 1px solid var(--cp-text-dark);
  }
  #c-prod-{{ section.id }} .c-prod__radio:checked + .c-prod__card-label { 
    border-color: var(--cp-accent); 
    box-shadow: 0 0 0 1px var(--cp-accent); 
    background-color: #f8fbff; 
  }

  /* Bloque: App Widget */
  #c-prod-{{ section.id }} .c-prod__app-wrapper { width: 100%; }

  /* Bloque: Botón de Compra */
  #c-prod-{{ section.id }} .c-prod__btn-submit {
    width: 100%; background-color: var(--cp-accent); color: #fff; border: none;
    border-radius: 50px; padding: 18px; font-size: 15px; font-weight: 700; cursor: pointer;
    transition: 0.3s; font-family: 'Raleway', sans-serif; display: flex; align-items: center; justify-content: center; gap: 8px;
    text-transform: uppercase; letter-spacing: 0.5px;
  }
  #c-prod-{{ section.id }} .c-prod__btn-submit:hover { background-color: #084ab8; }
  #c-prod-{{ section.id }} .c-prod__btn-submit:disabled { background-color: #d1d5db; cursor: not-allowed; }
  #c-prod-{{ section.id }} .c-prod__dynamic-checkout {
    margin-top: 10px;
    width: 100%;
  }

  /* =========================================
     COMPORTAMIENTO DESKTOP
     ========================================= */
  @media (min-width: 900px) {
    #c-prod-{{ section.id }} {
      padding-top: {{ section.settings.pad_top_desk }}px;
      padding-bottom: {{ section.settings.pad_bot_desk }}px;
    }
    #c-prod-{{ section.id }} .c-prod__wrapper {
      grid-template-columns: minmax(0, 1fr) minmax(0, 1.1fr);
      gap: 60px;
      align-items: start;
    }
    #c-prod-{{ section.id }} .c-prod__gallery {
      position: sticky;
      top: 40px;
      min-width: 0;
      overflow: hidden;
    }
  }

  @media (max-width: 899px) {
    #c-prod-{{ section.id }} {
      overflow-x: clip;
    }

    #c-prod-{{ section.id }} .c-prod__wrapper {
      padding: 0 0px;
      gap: 20px;
      max-width: 380px;
      margin: 0 auto;
    }


    #c-prod-{{ section.id }} .c-prod__wrapper > *,
    #c-prod-{{ section.id }} .c-prod__info,
    #c-prod-{{ section.id }} .c-prod__form,
    #c-prod-{{ section.id }} .c-prod__variant-group {
      min-width: 0;
    }

    #c-prod-{{ section.id }} .c-prod__gallery {
      gap: 10px;
      align-items: center;
    }

    #c-prod-{{ section.id }} .c-prod__main-view,
    #c-prod-{{ section.id }} .c-prod__thumbs {
      width: 100%;
      max-width: 100%;
      margin-left: auto;
      margin-right: auto;
    }

    #c-prod-{{ section.id }} .c-prod__thumb-item {
      width: 58px;
      height: 58px;
    }

    #c-prod-{{ section.id }} .c-prod__thumbs {
      justify-content: center;
    }

    #c-prod-{{ section.id }} .c-prod__info,
    #c-prod-{{ section.id }} .c-prod__form {
      gap: 10px;
    }

    #c-prod-{{ section.id }} .c-prod__variant-group--pills {
      align-items: center;
    }

    #c-prod-{{ section.id }} .c-prod__variant-group--pills .c-prod__pills {
      justify-content: center;
    }

    #c-prod-{{ section.id }} .c-prod__payment-terms {
      text-align: center;
    }

    #c-prod-{{ section.id }} .c-prod__reviews {
      gap: 6px;
      font-size: 11px;
      flex-wrap: wrap;
    }

    #c-prod-{{ section.id }} .c-prod__reviews > span,
    #c-prod-{{ section.id }} .c-prod__reviews > a {
      white-space: normal;
    }

    #c-prod-{{ section.id }} .c-prod__title {
      font-size: 20px;
      line-height: 1.15;
    }
    #c-prod-{{ section.id }} .c-prod__title-secondary {
      font-size: 24px;
      line-height: 1.2;
