<div id="c-story-{{ section.id }}" class="c-story" data-section-id="{{ section.id }}">
  <div class="c-story__container">
    
    <div class="c-story__left">
      {%- if section.settings.subheading != blank -%}
        <div class="c-story__subheading">{{ section.settings.subheading }}</div>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="c-story__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="c-story__description">
          {{ section.settings.description }}
        </div>
      {%- endif -%}

      {%- if section.settings.signature_image != blank -%}
        <div class="c-story__signature">
          <img src="{{ section.settings.signature_image | image_url: width: 400 }}" alt="Signature" loading="lazy">
        </div>
      {%- endif -%}

      {%- if section.settings.link_text != blank -%}
        <a href="{{ section.settings.link_url | default: '#' }}" class="c-story__link">
          {{ section.settings.link_text }}
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      {%- endif -%}
    </div>

    <div class="c-story__right">
      <div class="c-story__cards-wrapper">
        
        <div class="c-story__card c-story__card--primary">
          <div class="c-story__card-header">
            {%- if section.settings.card1_logo != blank -%}
              <img src="{{ section.settings.card1_logo | image_url: width: 300 }}" alt="Dr Jen Logo" loading="lazy" class="c-story__card-logo">
            {%- endif -%}
          </div>
          <ul class="c-story__card-list">
            {%- if section.settings.card1_item1 != blank -%}<li>{{ section.settings.card1_item1 }}</li>{%- endif -%}
            {%- if section.settings.card1_item2 != blank -%}<li>{{ section.settings.card1_item2 }}</li>{%- endif -%}
            {%- if section.settings.card1_item3 != blank -%}<li>{{ section.settings.card1_item3 }}</li>{%- endif -%}
            {%- if section.settings.card1_item4 != blank -%}<li>{{ section.settings.card1_item4 }}</li>{%- endif -%}
          </ul>
        </div>

        <div class="c-story__card c-story__card--secondary">
          <div class="c-story__card-header">
            {%- if section.settings.card2_title != blank -%}
              <h3 class="c-story__card-title">{{ section.settings.card2_title | newline_to_br }}</h3>
            {%- endif -%}
          </div>
          <ul class="c-story__card-list">
            {%- if section.settings.card2_item1 != blank -%}<li>{{ section.settings.card2_item1 }}</li>{%- endif -%}
            {%- if section.settings.card2_item2 != blank -%}<li>{{ section.settings.card2_item2 }}</li>{%- endif -%}
            {%- if section.settings.card2_item3 != blank -%}<li>{{ section.settings.card2_item3 }}</li>{%- endif -%}
            {%- if section.settings.card2_item4 != blank -%}<li>{{ section.settings.card2_item4 }}</li>{%- endif -%}
          </ul>
        </div>

      </div>
    </div>

  </div>
</div>

<style>
  @import url('https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,400;0,500;0,600;0,700;1,400&family=Playfair+Display:ital,wght@1,400;1,500&display=swap');

  #c-story-{{ section.id }} {
    background-color: {{ section.settings.bg_color }};
    padding-top: {{ section.settings.padding_top_desktop }}px;
    padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
    font-family: 'Raleway', sans-serif;
    overflow: hidden;
  }

  #c-story-{{ section.id }} .c-story__container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 60px;
    align-items: start;
  }

  /* --- COLUMNA IZQUIERDA --- */
  #c-story-{{ section.id }} .c-story__left {
    display: flex;
    flex-direction: column;
  }

  #c-story-{{ section.id }} .c-story__subheading {
    color: {{ section.settings.subheading_color }};
    font-size: {{ section.settings.subheading_size_desktop }}px;
    margin-bottom: 8px;
    font-weight: 400;
    font-family: 'Playfair Display', Georgia, serif !important;
  }

  #c-story-{{ section.id }} .c-story__subheading em,
  #c-story-{{ section.id }} .c-story__subheading i {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    color: {{ section.settings.subheading_em_color }};
  }

  #c-story-{{ section.id }} .c-story__heading {
    color: {{ section.settings.heading_color }};
    font-size: {{ section.settings.heading_size_desktop }}px;
    font-weight: {{ section.settings.heading_weight }};
    max-width: {{ section.settings.heading_max_desktop }}%;
    margin: 0 0 24px 0;
    line-height: 1.2;
  }

  #c-story-{{ section.id }} .c-story__description {
    color: {{ section.settings.text_color }};
    font-size: {{ section.settings.text_size_desktop }}px;
    max-width: {{ section.settings.text_max_desktop }}%;
    line-height: 1.6;
    margin-bottom: 30px;
  }

  #c-story-{{ section.id }} .c-story__description p {
    margin: 0 0 16px 0;
  }
  #c-story-{{ section.id }} .c-story__description p:last-child {
    margin-bottom: 0;
  }

  #c-story-{{ section.id }} .c-story__signature {
    margin-bottom: 30px;
    max-width: {{ section.settings.signature_max_desktop }}px;
  }

  #c-story-{{ section.id }} .c-story__signature img {
    width: 100%;
    height: auto;
    display: block;
  }

  #c-story-{{ section.id }} .c-story__link {
    color: {{ section.settings.link_color }};
    font-size: {{ section.settings.link_size_desktop }}px;
    font-weight: 700;
    text-transform: uppercase;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    width: 20%;
    border-bottom: 1px solid #002C41;
    transition: opacity 0.3s ease;
  }
  
  #c-story-{{ section.id }} .c-story__link:hover {
    opacity: 0.7;
  }

  /* --- COLUMNA DERECHA (TARJETAS) --- */
  #c-story-{{ section.id }} .c-story__cards-wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
  }

  #c-story-{{ section.id }} .c-story__card {
    border-radius: {{ section.settings.card_radius }}px;
    padding: 30px 24px;
    display: flex;
    flex-direction: column;
  }

  #c-story-{{ section.id }} .c-story__card-header {
    padding-bottom: 20px;
    margin-bottom: 20px;
    display: flex;
    justify-content: center;
    align-items: center;
    min-height: 60px;
  }

  #c-story-{{ section.id }} .c-story__card-logo {
    max-width: 140px;
    height: auto;
  }

  #c-story-{{ section.id }} .c-story__card-title {
    margin: 0;
    font-size: {{ section.settings.card_title_size_desktop }}px;
    text-align: center;
    font-weight: 400;
    line-height: 1.3;
  }

  #c-story-{{ section.id }} .c-story__card-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
  }

  #c-story-{{ section.id }} .c-story__card-list li {
    padding: 20px 0;
    font-size: {{ section.settings.card_text_size_desktop }}px;
    line-height: 1.4;
  }

  /* Estilos específicos Tarjeta 1 (Primaria) */
  #c-story-{{ section.id }} .c-story__card--primary {
    background-color: {{ section.settings.card1_bg }};
  }
  #c-story-{{ section.id }} .c-story__card--primary .c-story__card-header {
    border-bottom: 1px solid {{ section.settings.card1_line }};
  }
  #c-story-{{ section.id }} .c-story__card--primary .c-story__card-list li {
    color: {{ section.settings.card1_text }};
    font-weight: 700;
    border-bottom: 1px solid {{ section.settings.card1_line }};
  }
  #c-story-{{ section.id }} .c-story__card--primary .c-story__card-list li:last-child {
    border-bottom: 1px solid {{ section.settings.card1_line }};
  }

  /* Estilos específicos Tarjeta 2 (Secundaria) */
  #c-story-{{ section.id }} .c-story__card--secondary {
    background-color: {{ section.settings.card2_bg }};
  }
  #c-story-{{ section.id }} .c-story__card--secondary .c-story__card-title {
    color: {{ section.settings.card2_text }};
  }
  #c-story-{{ section.id }} .c-story__card--secondary .c-story__card-header {
    border-bottom: 1px solid {{ section.settings.card2_line }};
  }
  #c-story-{{ section.id }} .c-story__card--secondary .c-story__card-list li {
    color: {{ section.settings.card2_text }};
    font-weight: 400;
    border-bottom: 1px solid {{ section.settings.card2_line }};
  }
  #c-story-{{ section.id }} .c-story__card--secondary .c-story__card-list li:last-child {
    border-bottom: 1px solid {{ section.settings.card2_line }};
  }

  /* --- RESPONSIVO --- */
  @media screen and (max-width: 991px) {
    #c-story-{{ section.id }} .c-story__container {
      grid-template-columns: 1fr;
      gap: 50px;
    }
    
    /* Configuración Dinámica de Alineación (Móvil & Tablet) */
    #c-story-{{ section.id }} .c-story__left {
      max-width: 800px;
      margin: 0 auto;
      text-align: {{ section.settings.mobile_alignment }};
      align-items: {% if section.settings.mobile_alignment == 'center' %}center{% elsif section.settings.mobile_alignment == 'right' %}flex-end{% else %}flex-start{% endif %};
    }
    
    #c-story-{{ section.id }} .c-story__description p {
      text-align: {{ section.settings.mobile_alignment }};
    }

    #c-story-{{ section.id }} .c-story__heading,
    #c-story-{{ section.id }} .c-story__description,
    #c-story-{{ section.id }} .c-story__signature {
      {% if section.settings.mobile_alignment == 'center' %}
        margin-left: auto;
        margin-right: auto;
      {% elsif section.settings.mobile_alignment == 'right' %}
        margin-left: auto;
        margin-right: 0;
      {% else %}
        margin-left: 0;
        margin-right: auto;
      {% endif %}
    }
  }

  @media screen and (max-width: 768px) {
    #c-story-{{ section.id }} {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }

    #c-story-{{ section.id }} .c-story__container {
      padding: 0 20px;
      gap: 40px;
    }

    /* Tipografía Móvil */
    #c-story-{{ section.id }} .c-story__subheading {
      font-size: {{ section.settings.subheading_size_mobile }}px;
    }

    #c-story-{{ section.id }} .c-story__heading {
      font-size: {{ section.settings.heading_size_mobile }}px;
      max-width: {{ section.settings.heading_max_mobile }}%;
      margin-bottom: 44px;
    }

    #c-story-{{ section.id }} .c-story__description {
      font-size: {{ section.settings.text_size_mobile }}px;
      max-width: {{ section.settings.text_max_mobile }}%;
    }

    #c-story-{{ section.id }} .c-story__signature {
      max-width: {{ section.settings.signature_max_mobile }}px;
    }

    #c-story-{{ section.id }} .c-story__link {
      font-size: {{ section.settings.link_size_mobile }}px;
      width: auto;
    }

    /* Tarjetas Móvil (Apiladas verticalmente) */
    #c-story-{{ section.id }} .c-story__cards-wrapper {
      grid-template-columns: 1fr;
      gap: 24px;
    }

    #c-story-{{ section.id }} .c-story__card {
      border-radius: 0;
    }

    #c-story-{{ section.id }} .c-story__card:first-child {
      border-top-left-radius: {{ section.settings.card_radius }}px;
      border-top-right-radius: {{ section.settings.card_radius }}px;
      border-bottom-left-radius: {{ section.settings.card_radius }}px;
      border-bottom-right-radius: {{ section.settings.card_radius }}px;
    }

    #c-story-{{ section.id }} .c-story__card:last-child {
      border-bottom-left-radius: {{ section.settings.card_radius }}px;
      border-bottom-right-radius: {{ section.settings.card_radius }}px;
      border-top-left-radius: {{ section.settings.card_radius }}px;
      border-top-right-radius: {{ section.settings.card_radius }}px;
    }

    #c-story-{{ section.id }} .c-story__card-title {
      font-size: {{ section.settings.card_title_size_mobile }}px;
    }

    #c-story-{{ section.id }} .c-story__card-list li {
      font-size: {{ section.settings.card_text_size_mobile }}px;
      padding: 16px 0;
    }
  }
</style>

