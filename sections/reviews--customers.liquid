<style>
#shopify-section-{{ section.id }} {
  background-color: {{section.settings.bg_color}};
  color:{{section.settings.text_color}};
}
  .MC-Testimonial-Container .section__title{
    margin-block-start: 20px;
  }
</style>

<div class="container">
<div class="MC-Testimonial-Container">
<h3 class="section__heading text--center">
  {{section.settings.testimonials_heading}}
</h3>
<div class="Homepage-Testimonials slider--reviews slider--fix-width slider--theme-dots" data-flickity='{"wrapAround" : true, "contain": true, "cellAlign" : "left"}'>
  {% for block in section.blocks %}
      <div class="MC-Testimonial">
          <div class="start-rating">
              {% for i in (1..block.settings.star_rating) %}
                  <i class="fa-solid fa-star" style="color: {{block.settings.star_color}}; font-size: 24px;"></i>
              {% endfor %}
          </div>
          <p class="section__desc">{{block.settings.description}}</p>
          <h5 class="section__title">{{block.settings.title}} - Verified Buyer</h5>
      </div>
  {% endfor %}
</div>
</div>  
</div>

{% schema %}
{
   "name": "Reviews - customers",
  "tag": "section",
  "class": "section__padding ss--reviews--professionals",
   "settings" : [
    {
        "type": "text",
        "id": "testimonials_heading",
        "label": "Testimonial Title"
    },
    {
        "type": "color",
        "id": "bg_color",
        "label": "Background Color",
        "default": "#ffffff"
    },
    {
        "type": "color",
        "id": "text_color",
        "label": "Text Color",
        "default": "#1D2433"
    }
   ],
   "blocks" : [
        {
             "name": "Testimonial",
             "type" : "testimonial",
             "settings" : [
                {
                    "type": "range",
                    "id": "star_rating",
                    "label": "Star Rating",
                    "unit": "*",
                    "min": 1,
                    "max": 5,
                    "step": 1,
                    "default": 5
                },
                {
                    "type": "textarea",
                    "id": "description",
                    "label": "description"
                },
                {
                    "type": "text",
                    "id": "title",
                    "label": "Buyer Name"
                },
                {
                    "type": "color",
                    "id": "star_color",
                    "label": "Star Color",
                    "default": "#8BD1CF"
                }
             ]
        }
   ],
   "presets": [
    {
        "name": "Reviews - customers",
      "category": "Reviews or Testimonials"
    }
   ]
}
{% endschema %}