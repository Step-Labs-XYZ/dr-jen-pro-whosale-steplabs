<style>
  #shopify-section-{{ section.id }} {
    background: {{section.settings.Background_Color}};
  }
  </style>
  
  <div class="container section_{{ section.id }}">
  <div class="text-w-image">
    {% if section.settings.heading != blank %}
      <h3 class="section__heading">
        {{section.settings.heading}}
      </h3>
      <p class="section__desc">
        {{section.settings.subheading}}
      </p>
    {% endif %}
      <div class="wrapper--image {% if section.settings.select_direction_id == 'Left' %}Images_left{% endif %}">
        <img style="padding: {{ section.settings.padding_id }}px 0; max-width: {{ section.settings.size_id}}px;" src="{{section.settings.section_image | img_url: 'master'}}" />
        <div class="text_container_wrapper--image">
          {% if section.settings.text_width_image_id != blank %}
           {{ section.settings.text_width_image_id }}
          {% endif %}
        </div>
        

      </div>
      {% if section.settings.button_text != blank %}
        <div class="wrapper--cta">
          <a href="{{section.settings.button_url}}" class="hero-button btn--dj" style="background-color: {{section.settings.button_color}};">{{section.settings.button_text}}</a>
        </div>
      {% endif %}
  </div>
  </div>
  
  <style>
    .template-product .ss--image-with-text--top .text-w-image{
      background-color: inherit;
    }
  
    .template-product .ss--image-with-text--top .section__heading{
      font-size: clamp(26px, 3vw, 40px);
      line-height: normal;
      margin: 0 0 10px 0;
    }
    .template-product .ss--image-with-text--top .section__desc{
      font-size: clamp(18px, 3vw, 22px);
      line-height: 32px;
      margin: 0 auto 30px;
    }
    .template-product .ss--image-with-text--top .section__desc p{
      max-width: 1080px;
    }
    .template-product .ss--image-with-text--top .container{
      padding: 0;
    }
    .template-product .ss--image-with-text--top .hero-button.btn--dj{
      border-radius: 6px;
      padding: 10px;
      display: block;
      max-width: 335px;
      margin: 20px auto 0;
    }
    .ss--image-with-text--top .wrapper--image h2{
      font-size: clamp(24px, 3vw, 32px);
     line-height: 40px;
      margin: 30px 0 16px;
    }
    .ss--image-with-text--top .wrapper--image h4{
      font-size: clamp(18px, 3vw, 22px);
      line-height: 40px;
      margin: 5px 0;
      font-weight: 500
    }
    .ss--image-with-text--top .wrapper--image p{
      font-size: 16px;
      line-height: 28px;
      max-width: 415px;
      margin: 0;
    }
    .ss--image-with-text--top .wrapper--image h5{
      font-size: 16px;
      font-weight: 700;
      margin: 0;
    }
    .ss--image-with-text--top .text_container_wrapper--image{
      max-width: 500px;
      text-align: left;
      width: 100%;
    }
    .ss--image-with-text--top .wrapper--image{
      display: flex;
      justify-content: center;
      align-items: center;
      flex-wrap: wrap;
    }
    .ss--image-with-text--top .text-w-image img{
      max-width: 670px;
    }
    .template-mouth-rinse-pdp .ss--image-with-text--top .text-w-image img{
    max-width: 576px;
    margin: auto
    }

    .template-mouth-rinse-pdp .ss--image-with-text--top .wrapper--image h4{
      font-size: clamp(20px, 3vw, 26px);
      line-height: 38px;
      font-weight: 600;
    }

    .template-mouth-rinse-pdp .ss--image-with-text--top .wrapper--image p{
      font-size: clamp(18px, 3vw, 22px);
      line-height: 32px;
      margin: 15px 0;
      max-width: 570px;

    }

    .template-mouth-rinse-pdp .ss--image-with-text--top .wrapper--image{
      flex-direction: row-reverse;
    }
    .template-mouth-rinse-pdp .ss--image-with-text--top .wrapper--image.Images_left{
      flex-direction: unset;
    }
    .template-mouth-rinse-pdp .ss--image-with-text--top .text-w-image{
      padding: 0 80px
    }
    .template-mouth-rinse-pdp .ss--image-with-text--top .text_container_wrapper--image{
      max-width: 600px;
      width: 100%;
    }
 
    @media screen and (max-width: 768px) {
      .template-mouth-rinse-pdp .ss--image-with-text--top .text-w-image{
        padding: 35px 20px;
      }
      .template-mouth-rinse-pdp .ss--image-with-text--top .text-w-image img{
        margin: 15px 0 25px;
        padding: 0 !important;
      }
      .template-product .ss--image-with-text--top .container{
        padding: 10px 0;
      }
      .template-product .ss--image-with-text--top .section__desc{
      line-height: 24px;
      }
      .template-product .ss--image-with-text--top .hero-button.btn--dj{
      padding: 5px !important;
      margin: 0 ;
    }
    }
  </style>
  
  
  {% schema %}
  {
     "name": "Image with text - top",
      "tag": "section",
      "class": "section__padding ss--image-with-text--top",
      "settings": [
          {
            "type": "select",
            "id": "select_direction_id",
            "label": "Direction Image",
            "options": [
              {
                "value": "Right",
                "label": "Right"
              },
              {
                "value": "Left",
                "label": "Left"
              }
            ]
          },
          {
              "type": "text",
              "id": "heading",
              "label": "Heading"
          },
          {
              "type": "text",
              "id": "subheading",
              "label": "Subheading"
          },
          {
              "type": "image_picker",
              "id": "section_image",
              "label": "Image"
          }, 
          {
            "type": "range",
            "id": "size_id",
            "label": "Size image",
            "unit": "px",
            "min":100,
            "max": 800,
            "step": 20,
            "default": 500
          },
          {
            "type": "range",
            "id": "padding_id",
            "label": "Padding Image",
            "unit": "px",
            "min": 0,
            "max": 300,
            "step": 5,
            "default": 5
          },
          {
            "type": "richtext",
            "id": "text_width_image_id",
            "label": "Text"
          },
          {
              "type": "header",
              "content": "Button Settings"
          },
          {
              "type": "url",
              "id": "button_url",
              "label": "Button URL"
          },
          {
              "type": "text",
              "id": "button_text",
              "label": "Button Text"
          },
          {
              "type": "color",
              "id": "button_color",
              "label": "Button Color",
              "default": "#df477f"
          },
          {
              "type": "color",
              "id": "Background_Color",
              "label": "Background Color",
              "default": "#fdf3ef"
          }
      ],
     "presets": [
      {
        "name": "Image with text - top",
        "category": "Image with text"
      }
     ]
  }
  {% endschema %}