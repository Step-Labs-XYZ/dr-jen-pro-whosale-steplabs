<div id="c-mineral-uptake-{{ section.id }}" class="Cmineral-uptake" data-section-id="{{ section.id }}">
  <div class="Cmineral-uptake__container">
    
    <div class="Cmineral-uptake__content">
      {%- if section.settings.main_heading != blank -%}
        <h2 class="Cmineral-uptake__heading">{{ section.settings.main_heading | newline_to_br }}</h2>
      {%- endif -%}

      {%- if section.settings.description != blank -%}
        <div class="Cmineral-uptake__description">
          <p>{{ section.settings.description | newline_to_br }}</p>
        </div>
      {%- endif -%}

      {%- if section.settings.link_text != blank -%}
        <a href="{{ section.settings.link_url | default: '#' }}" class="Cmineral-uptake__study-link">
          {{ section.settings.link_text }}
        </a>
      {%- endif -%}

      {%- if section.settings.description_desktop_extra != blank -%}
        <div class="Cmineral-uptake__description Cmineral-uptake__description--desktop-extra">
          <p>{{ section.settings.description_desktop_extra | newline_to_br }}</p>
        </div>
      {%- endif -%}

      {%- if section.settings.button_text != blank -%}
        <a href="{{ section.settings.button_url | default: '#' }}"
           class="Cmineral-uptake__button Cmineral-uptake__button--desktop">
          {{ section.settings.button_text }}
        </a>
      {%- endif -%}
    </div>

    <div class="Cmineral-uptake__images">
      {%- if section.settings.images_title != blank -%}
        <h3 class="Cmineral-uptake__images-title">{{ section.settings.images_title | newline_to_br }}</h3>
      {%- endif -%}

      <div class="Cmineral-uptake__images-grid">
        <div class="Cmineral-uptake__image-item">
          {%- if section.settings.image_1 != blank -%}
            <div class="Cmineral-uptake__image-wrapper">
              <img 
                src="{{ section.settings.image_1 | image_url: width: 600 }}" 
                alt="{{ section.settings.image_1_label | escape }}"
                class="Cmineral-uptake__image"
                loading="lazy"
              />
            </div>
          {%- else -%}
            <div class="Cmineral-uptake__image-placeholder">
              <svg width="200" height="200" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="200" height="200" fill="#E5E5E5"/>
                <text x="50%" y="50%" text-anchor="middle" fill="#999" font-size="14">Image 1</text>
              </svg>
            </div>
          {%- endif -%}
          
          {%- if section.settings.image_1_label != blank -%}
            <p class="Cmineral-uptake__image-label">{{ section.settings.image_1_label | newline_to_br }}</p>
          {%- endif -%}
        </div>

        <div class="Cmineral-uptake__image-item">
          {%- if section.settings.image_2 != blank -%}
            <div class="Cmineral-uptake__image-wrapper">
              <img 
                src="{{ section.settings.image_2 | image_url: width: 600 }}" 
                alt="{{ section.settings.image_2_label | escape }}"
                class="Cmineral-uptake__image"
                loading="lazy"
              />
            </div>
          {%- else -%}
            <div class="Cmineral-uptake__image-placeholder">
              <svg width="200" height="200" viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="200" height="200" fill="#E5E5E5"/>
                <text x="50%" y="50%" text-anchor="middle" fill="#999" font-size="14">Image 2</text>
              </svg>
            </div>
          {%- endif -%}
          
          {%- if section.settings.image_2_label != blank -%}
            <p class="Cmineral-uptake__image-label">{{ section.settings.image_2_label | newline_to_br }}</p>
          {%- endif -%}
        </div>
      </div>
    </div>

  </div>

  {%- comment -%} Mobile-only bottom content {%- endcomment -%}
  {%- if section.settings.description_mobile_bottom != blank or section.settings.mobile_button_text != blank -%}
    <div class="Cmineral-uptake__mobile-bottom">
      {%- if section.settings.description_mobile_bottom != blank -%}
        <div class="Cmineral-uptake__description Cmineral-uptake__description--mobile-bottom">
          <p>{{ section.settings.description_mobile_bottom | newline_to_br }}</p>
        </div>
      {%- endif -%}

      {%- if section.settings.mobile_button_text != blank -%}
        <a href="{{ section.settings.mobile_button_url | default: '#' }}"
           class="Cmineral-uptake__button Cmineral-uptake__button--mobile">
          {{ section.settings.mobile_button_text }}
        </a>
      {%- endif -%}
    </div>
  {%- endif -%}
</div>

<style>
@import url('https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800&display=swap');

#c-mineral-uptake-{{ section.id }} {
  background-color: {{ section.settings.background_color }};
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  overflow: hidden;
  font-family: 'Raleway', sans-serif;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__container {
  max-width: 1440px;
  margin: 0 auto;
  padding: 0 40px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

/* Columna Izquierda */
#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__content {
  display: flex;
  flex-direction: column;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__heading {
  font-size: {{ section.settings.heading_size_desktop }}px;
  max-width: {{ section.settings.heading_max_desktop }}%;
  font-weight: 600;
  line-height: 1.25;
  color: {{ section.settings.heading_color }};
  margin: 0 0 20px 0;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__description {
  font-size: {{ section.settings.text_size_desktop }}px;
  max-width: {{ section.settings.text_max_desktop }}%;
  font-weight: 400;
  line-height: 1.6;
  color: {{ section.settings.text_color }};
  margin: 0;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__description p {
  margin: 0;
}

/* Link de estudio con espacio */
#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__study-link {
  font-size: {{ section.settings.text_size_desktop }}px;
  color: {{ section.settings.link_color }};
  text-decoration: underline;
  font-weight: 400;
  display: inline-block;
  margin-bottom: 24px;
  transition: opacity 0.3s ease;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__study-link:hover {
  opacity: 0.7;
}

/* Texto extra negrita */
#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__description--desktop-extra {
  font-weight: 700;
  color: {{ section.settings.bold_text_color }};
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__description--mobile-bottom {
  font-weight: 700;
  color: {{ section.settings.bold_text_color }};
}

/* Botón (si se usa) */
#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 16px 40px;
  background: transparent;
  border: 2px solid {{ section.settings.heading_color }};
  border-radius: 50px;
  font-size: 16px;
  font-weight: 700;
  color: {{ section.settings.heading_color }};
  text-decoration: none;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  transition: all 0.3s ease;
  align-self: flex-start;
  margin-top: 20px;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__button:hover {
  background: {{ section.settings.heading_color }};
  color: {{ section.settings.background_color }};
  transform: translateY(-2px);
}

/* Columna Derecha */
#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__images {
  display: flex;
  flex-direction: column;
  gap: 30px;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__images-title {
  font-size: {{ section.settings.img_title_size_desktop }}px;
  max-width: {{ section.settings.img_title_max_desktop }}%;
  font-weight: 400;
  line-height: 1.3;
  color: {{ section.settings.images_title_color }};
  margin: 0 auto;
  text-align: center;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__images-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 40px;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__image-item {
  display: flex;
  flex-direction: column;
  gap: 16px;
  align-items: center;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__image-wrapper {
  width: 100%;
  aspect-ratio: 1; 
  border-radius: 12px;
  overflow: hidden;
  background: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__image {
  width: 80%;
  height: 100%;
  object-fit: contain;
  border-radius: 12px;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__image-placeholder {
  width: 100%;
  aspect-ratio: 1;
  border-radius: 12px;
  background: #F8F8F8;
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2px dashed #D6D6D6;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__image-label {
  font-size: {{ section.settings.label_size_desktop }}px;
  font-weight: 700;
  line-height: 1.4;
  color: {{ section.settings.labels_color }};
  margin: 0;
  text-align: center;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__mobile-bottom {
  display: none;
}

#c-mineral-uptake-{{ section.id }} .Cmineral-uptake__button--mobile {
  display: none;
}

/* Responsivo */
@media (max-width: 991px) {
  #c-mineral-uptake-{{ section.id }} .Cmineral-uptake__container {
    grid-template-columns: 1fr;
    gap: 60px;
  }
}

@media (max-width: 768px) {
  #c-mineral-uptake-{{ section.id }} {
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
  }

  #c-mineral-uptake-{{ section.id }} .Cmineral-uptake__container {
    padding: 0 20px;
    gap: 40px;
  }

  #c-mineral-uptake-{{ section.id }} .Cmineral-uptake__heading {
    font-size: {{ section.settings.heading_size_mobile }}px;
    max-width: {{ section.settings.heading_max_mobile }}%;
    text-align: left;
    margin-left: 0;
    margin-right: 0;
  }

  #c-mineral-uptake-{{ section.id }} .Cmineral-uptake__description {
    font-size: {{ section.settings.text_size_mobile }}px;
    max-width: {{ section.settings.text_max_mobile }}%;
  }

  #c-mineral-uptake-{{ section.id }} .Cmineral-uptake__study-link {
    font-size: {{ section.settings.text_size_mobile }}px;
    margin-top: 10px;
    margin-bottom: 20px;
  }

  #c-mineral-uptake-{{ section.id }} .Cmineral-uptake__images-title {
    font-size: {{ section.settings.img_title_size_mobile }}px;
    max-width: {{ section.settings.img_title_max_mobile }}%;
  }

  #c-mineral-uptake-{{ section.id }} .Cmineral-uptake__image-label {
    font-size: {{ section.settings.label_size_mobile }}px;
  }

  #c-mineral-uptake-{{ section.id }} .Cmineral-uptake__images-grid {
    gap: 24px;
  }

  #c-mineral-uptake-{{ section.id }} .Cmineral-uptake__button {
    padding: 14px 32px;
    font-size: 14px;
  }

  #c-mineral-uptake-{{ section.id }} .Cmineral-uptake__description--desktop-extra {
    display: block;
  }

  #c-mineral-uptake-{{ section.id }} .Cmineral-uptake__mobile-bottom {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: 1400px;
    margin: 28px auto 0;
    padding: 0 20px;
  }

  #c-mineral-uptake-{{ section.id }} .Cmineral-uptake__button--desktop {
    display: none;
  }

  #c-mineral-uptake-{{ section.id }} .Cmineral-uptake__button--mobile {
    display: inline-flex;
    width: 100%;
  }
}

@media (max-width: 480px) {
  #c-mineral-uptake-{{ section.id }} .Cmineral-uptake__button {
    width: 70%;
    align-self: center;
  }
}
</style>

