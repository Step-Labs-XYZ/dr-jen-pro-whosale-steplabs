<div style="background-color: {{ section.settings.background_id }};" class="reviews_comntainer_dr">
    <h2>{{ section.settings.title_reviews_wholesale }}</h2>

    <div class="reviews_container_card">
        {% for block in section.blocks %}
                <div class="card_reviews">
                        <img src="{{ block.settings.image_dr_reviews | image_url: width: 140  }}" alt="{{ block.settings.image_dr_reviews.alt }}">
                        
                        <div class="review_text_container">
<!--                             <div class="start-rating">
                                {% for i in (1..block.settings.star_rating) %}
                                    <i class="fa-solid fa-star" style="color: {{block.settings.star_color}};"></i>
                                {% endfor %}
                            </div> -->
                            <h5>{{ block.settings.name_dr }}</h5>
                            <p>{{ block.settings.review_dr }}</p>
                        </div>
                </div>
        {% endfor %}
    </div>
</div>
<script>

setTimeout(() => {
    $('.reviews_container_card').slick({
  infinite: true,
  slidesToShow: 3,
  slidesToScroll: 3,
  arrows: true,
  dots: false,
  responsive: [
    {
      breakpoint: 768,
      settings: {
        slidesToShow: 1,
        slidesToScroll: 1
      }
    }
  ]
});
}, 500);    

</script>

<style>
.reviews_container_card img{
border-radius: 100px;
max-width: 130px;
width: 100%;
max-height: 130px;
height: 100%;
object-fit: cover;
margin: 0 auto 22px;
}
.start-rating i{
font-size: 24px;
}
.review_text_container h5{
font-size: clamp(16px, 4vw, 18px);
margin: 0 0 10px;
}

.review_text_container p{
font-size: 14px;
margin: 0;
}
.review_text_container{
padding: 20px;
text-align: left;
}
.reviews_container_card{
    padding: 0 150px;
    overflow-x: hidden;
}
.card_reviews{
text-align: center;
margin: 0 10px;
background: #FFFFFF;
box-shadow: 2px 2px 10px -1px rgb(116 135 173 / 25%);
border-radius: 16px;
padding: 25px 0 0;
min-height: 525px;
height: 100%;
}

.reviews_comntainer_dr h2{
font-size: clamp(24px, 4vw, 32px);
line-height: normal;
}
.reviews_comntainer_dr h2 span{
font-size: clamp(26px, 4vw, 40px);
line-height: normal;
}
.reviews_comntainer_dr{
padding: 45px 0 60px;
}
.reviews_comntainer_dr{
text-align: center;
}
.reviews_comntainer_dr .flickity-page-dots{
    display: none;
}
.reviews_comntainer_dr .flickity-button-icon{
    fill: #5AC8D4 !important;
}
.reviews_comntainer_dr .flickity-prev-next-button .flickity-button-icon{
    width: 80% !important;
    height: 80% !important;
}
.reviews_container_card .slick-next.slick-arrow::after{
  content: "";
  background-image: url('https://cdn.shopify.com/s/files/1/0747/1769/2180/files/Arrow_2.svg?v=1681939718');
  height: 48px;
  width: 48px;
  display: block;
  
}
.reviews_container_card .slick-next.slick-arrow{
    position: absolute;
    right: 7%;
    transform: translateY(-50%);
    top: 50%;
    z-index: 1;
}
.reviews_container_card .slick-prev.slick-arrow{
    position: absolute;
    left: 7%;
    transform: translateY(-50%);
    top: 50%;
    z-index: 1;
}
.reviews_container_card .slick-prev.slick-arrow::after{
  content: "";
  background-image: url('https://cdn.shopify.com/s/files/1/0747/1769/2180/files/Arrow_3.svg?v=1681939718');
  height: 48px;
  width: 48px;
  display: block;
  
}
.reviews_container_card .slick-arrow{
    font-size: 0;
}
@media screen and (max-width: 1000px) {
    .reviews_container_card{
        padding: 0 45px 0 55px;
    } 
    .text_explore_p_container a{
        margin: 5vw auto 0;
    }
    .card_reviews{
        margin: 0 20px;
        box-shadow: 2px 2px 10px -1px rgb(116 135 173 / 25%);
    }
    .reviews_comntainer_dr h2{
        padding: 0 25px;
    }
    .reviews_comntainer_dr{
        padding: 40px 0 50px;
    }
    .reviews_comntainer_dr .flickity-prev-next-button .flickity-button-icon{
        top: -11rem !important;
    }
    .reviews_container_card{
        padding: 0 25px;
    }
    .reviews_container_card .slick-next.slick-arrow{
        right: 0;
    }
    .reviews_container_card .slick-prev.slick-arrow{
        left: 0;
    }
}
</style>

{% schema %}
{
   "name": "Dr reviews wholesale",
   "settings" : [
   {
    "type": "text",
    "id": "title_reviews_wholesale",
    "label": "Title Page",
    "default": "Wholesale"
   },
   {
    "type": "color",
    "id": "background_id",
    "label": "Background_color"
   }
],
"blocks": [
        {
            "type": "Review",
            "name": "Review",
            "settings": [
                {
                    "type": "image_picker",
                    "id": "image_dr_reviews",
                    "label": "DR Image"
                }, 
                {
                    "type": "text",
                    "id": "name_dr",
                    "label": "Dr Name"
                },
                {
                    "type": "text",
                    "id": "review_dr",
                    "label": "Dr review"
                },
                {
                    "type": "color",
                    "id": "star_color",
                    "label": "Star Color",
                    "default": "#8BD1CF"
                },
                {
                    "type": "range",
                    "id": "star_rating",
                    "label": "Star Rating",
                    "unit": "*",
                    "min": 1,
                    "max": 5,
                    "step": 1,
                    "default": 5
                }
            ]
        }
   ],
   "presets": [
    {
        "name": "reviews wholesale"
    }
   ]
}
{% endschema %}