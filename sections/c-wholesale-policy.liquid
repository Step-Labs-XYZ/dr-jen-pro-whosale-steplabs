{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Raleway:wght@400;500;600;700;800&display=swap');

  #c-wholesale-policy-{{ section.id }} {
    --bg: {{ section.settings.bg_color }};
    --heading: {{ section.settings.heading_color }};
    --text: {{ section.settings.text_color }};
    --btn-border: {{ section.settings.btn_border_color }};
    --btn-text: {{ section.settings.btn_text_color }};
    --btn-bg-hover: {{ section.settings.btn_bg_hover }};
    --btn-text-hover: {{ section.settings.btn_text_hover }};
    --radius: {{ section.settings.card_radius }}px;

    background: var(--bg);
    font-family: 'Raleway', sans-serif;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 10px;
    padding: 32px 20px;
  }

  #c-wholesale-policy-{{ section.id }} .c-wp__wrapper {
    width: 100%;
    max-width: 1440px;
  }

  #c-wholesale-policy-{{ section.id }} .c-wp__card {
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    align-items: flex-start;
    align-self: stretch;
    gap: 24px;
    padding: 32px 20px;
    border-radius: var(--radius);
    background: rgba(255, 255, 255, 0.32);
    backdrop-filter: blur(2px);
  }

  /* LEFT */
  #c-wholesale-policy-{{ section.id }} .c-wp__left {
    display: flex;
    flex-direction: column;
    gap: 20px;
    align-items: flex-start;
  }

  #c-wholesale-policy-{{ section.id }} .c-wp__heading {
    margin: 0;
    color: var(--heading);
    font-size: {{ section.settings.heading_size_mob }}px;
    font-weight: 600;
    line-height: 1.15;
  }

  #c-wholesale-policy-{{ section.id }} .c-wp__btn {
    display: inline-block;
    color: var(--btn-text);
    border: 2px solid var(--btn-border);
    background: transparent;
    font-family: 'Raleway', sans-serif;
    font-size: {{ section.settings.btn_size_mob }}px;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 10px 22px;
    border-radius: 40px;
    text-decoration: none;
    cursor: pointer;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  #c-wholesale-policy-{{ section.id }} .c-wp__btn:hover {
    background: var(--btn-bg-hover);
    color: var(--btn-text-hover);
  }

  /* RIGHT */
  #c-wholesale-policy-{{ section.id }} .c-wp__right {
    display: flex;
    flex-direction: column;
    gap: 16px;
    max-width: {{ section.settings.text_max_width_mob }}px;
  }

  #c-wholesale-policy-{{ section.id }} .c-wp__text {
    margin: 0;
    color: var(--text);
    font-size: {{ section.settings.text_size_mob }}px;
    line-height: 1.7;
  }

  /* DESKTOP */
  @media (min-width: 768px) {
    #c-wholesale-policy-{{ section.id }} {
      padding: 64px;
    }

    #c-wholesale-policy-{{ section.id }} .c-wp__card {
      flex-direction: row;
      align-items: flex-start;
      gap: 60px;
      padding: 44px 32px;
    }

    #c-wholesale-policy-{{ section.id }} .c-wp__left {
      width: {{ section.settings.left_width_desk }}%;
      flex-shrink: 0;
    }

    #c-wholesale-policy-{{ section.id }} .c-wp__right {
      flex: 1;
      min-width: 0;
      max-width: {{ section.settings.text_max_width_desk }}px;
    }

    #c-wholesale-policy-{{ section.id }} .c-wp__heading {
      font-size: {{ section.settings.heading_size_desk }}px;
    }

    #c-wholesale-policy-{{ section.id }} .c-wp__text {
      font-size: {{ section.settings.text_size_desk }}px;
    }

    #c-wholesale-policy-{{ section.id }} .c-wp__btn {
      font-size: {{ section.settings.btn_size_desk }}px;
    }
  }
{%- endstyle -%}

<section id="c-wholesale-policy-{{ section.id }}" data-sl-id="sl-section-wholesale-policy-v1">
  <div class="c-wp__wrapper">
    <div class="c-wp__card">

      <!-- LEFT -->
      <div class="c-wp__left">

        {% if section.settings.heading != blank %}
          <h2 class="c-wp__heading">{{ section.settings.heading }}</h2>
        {% endif %}

        {% if section.settings.btn_label != blank and section.settings.btn_url != blank %}
          <a class="c-wp__btn" href="{{ section.settings.btn_url }}">
            {{ section.settings.btn_label }}
          </a>
        {% endif %}

      </div>

      <!-- RIGHT -->
      <div class="c-wp__right">

        {% if section.settings.text_1 != blank %}
          <p class="c-wp__text">{{ section.settings.text_1 }}</p>
        {% endif %}

        {% if section.settings.text_2 != blank %}
          <p class="c-wp__text">{{ section.settings.text_2 }}</p>
        {% endif %}

      </div>

    </div>
  </div>
</section>

{% schema %}
{
  "name": "C - Wholesale Policy",
  "settings": [
    { "type": "text", "id": "heading", "label": "Titulo" },
    { "type": "textarea", "id": "text_1", "label": "Parrafo 1" },
    { "type": "textarea", "id": "text_2", "label": "Parrafo 2" },

    { "type": "header", "content": "Boton" },
    { "type": "text", "id": "btn_label", "label": "Texto del boton" },
    { "type": "url", "id": "btn_url", "label": "URL del boton" },

    { "type": "header", "content": "Colores" },
    { "type": "color", "id": "bg_color", "label": "Fondo", "default": "#002C41" },
    { "type": "color", "id": "heading_color", "label": "Titulo", "default": "#FFFFFF" },
    { "type": "color", "id": "text_color", "label": "Texto", "default": "#FFFFFF" },
    { "type": "color", "id": "btn_border_color", "label": "Boton borde", "default": "#FFFFFF" },
    { "type": "color", "id": "btn_text_color", "label": "Boton texto", "default": "#FFFFFF" },
    { "type": "color", "id": "btn_bg_hover", "label": "Boton fondo hover", "default": "#FFFFFF" },
    { "type": "color", "id": "btn_text_hover", "label": "Boton texto hover", "default": "#2D4A5A" },

    { "type": "header", "content": "Layout" },
    { "type": "range", "id": "card_radius", "label": "Radio del card", "min": 0, "max": 40, "step": 2, "default": 12 },
    { "type": "range", "id": "left_width_desk", "label": "Ancho columna izq. desktop (%)", "min": 20, "max": 60, "step": 1, "default": 35 },

    { "type": "header", "content": "Tipografia" },
    { "type": "range", "id": "heading_size_mob", "label": "Titulo mobile", "min": 18, "max": 60, "step": 1, "default": 28 },
    { "type": "range", "id": "heading_size_desk", "label": "Titulo desktop", "min": 20, "max": 80, "step": 1, "default": 36 },
    { "type": "range", "id": "text_size_mob", "label": "Texto mobile", "min": 12, "max": 24, "step": 1, "default": 14 },
    { "type": "range", "id": "text_size_desk", "label": "Texto desktop", "min": 12, "max": 30, "step": 1, "default": 15 },
    { "type": "range", "id": "text_max_width_mob", "label": "Max width texto mobile (px)", "min": 200, "max": 800, "step": 10, "default": 600 },
    { "type": "range", "id": "text_max_width_desk", "label": "Max width texto desktop (px)", "min": 200, "max": 1000, "step": 10, "default": 600 },
    { "type": "range", "id": "btn_size_mob", "label": "Boton mobile", "min": 10, "max": 20, "step": 1, "default": 11 },
    { "type": "range", "id": "btn_size_desk", "label": "Boton desktop", "min": 10, "max": 20, "step": 1, "default": 12 },

    { "type": "header", "content": "Espaciado" },
    { "type": "range", "id": "pad_top_mob", "label": "Padding top mobile", "min": 0, "max": 120, "step": 4, "default": 32 },
    { "type": "range", "id": "pad_bot_mob", "label": "Padding bottom mobile", "min": 0, "max": 120, "step": 4, "default": 32 }
  ],

  "blocks": [],

  "presets": [
    {
      "name": "C - Wholesale Policy"
    }
  ]
}
{% endschema %}