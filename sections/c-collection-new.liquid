{% comment %}
  ╔══════════════════════════════════════════════════════════════╗
  ║  C - Collection New                                          ║
  ║  Metafields requeridos en productos:                         ║
  ║    custom.tag_one    → filtro / badge 1                      ║
  ║    custom.tag_two    → filtro / badge 2                      ║
  ║    custom.short_name → nombre corto (override del título)    ║
  ║    custom.list       → bullets (Rich Text metafield)         ║
  ╚══════════════════════════════════════════════════════════════╝
{% endcomment %}

{%- assign section_id    = section.id -%}
{%- assign default_filter = section.settings.default_filter | strip | downcase -%}

{%- comment %} ── Filtros desde custom.tag_one y custom.tag_two de metafields ── {%- endcomment %}
{%- assign seen_tags = '' -%}
{%- assign all_filter_tags = '' -%}
{%- for product in collection.products -%}
  {%- assign t1 = product.metafields.custom.tag_one.value | strip -%}
  {%- assign t2 = product.metafields.custom.tag_two.value | strip -%}
  {%- unless t1 == blank or seen_tags contains t1 -%}
    {%- assign seen_tags = seen_tags | append: t1 | append: '|||' -%}
    {%- assign all_filter_tags = all_filter_tags | append: t1 | append: '|||' -%}
  {%- endunless -%}
  {%- unless t2 == blank or seen_tags contains t2 -%}
    {%- assign seen_tags = seen_tags | append: t2 | append: '|||' -%}
    {%- assign all_filter_tags = all_filter_tags | append: t2 | append: '|||' -%}
  {%- endunless -%}
{%- endfor -%}
{%- assign filter_tags_array = all_filter_tags | split: '|||' -%}

<div
  id="c-col-new-{{ section_id }}"
  class="c-col-new"
  data-section-id="{{ section_id }}"
  data-collection-handle="{{ collection.handle }}"
  data-default-filter="{{ default_filter | escape }}"
>

  <!-- ══════════════════════════════════════
       SIDEBAR
  ══════════════════════════════════════ -->
  <aside class="c-col-new__sidebar" id="c-col-new-sidebar-{{ section_id }}">

    {%- if section.settings.show_search -%}
    <div class="c-col-new__search-box">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
        <path d="M20 20L16.65 16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <input
        type="text"
        id="c-col-new-search-{{ section_id }}"
        class="c-col-new__search-input"
        placeholder="{{ section.settings.search_placeholder | default: 'Search' }}"
        autocomplete="off"
        aria-label="Search products"
      />
    </div>
    {%- endif -%}

    <div class="c-col-new__filter-section" id="c-col-new-filter-section-{{ section_id }}">
      <div class="c-col-new__filter-header" role="button" aria-expanded="true" aria-controls="c-col-new-filters-{{ section_id }}">
        <span class="c-col-new__filter-label">{{ section.settings.filter_label | default: 'TYPE' }}</span>
        <svg class="c-col-new__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none">
          <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <div class="c-col-new__filters" id="c-col-new-filters-{{ section_id }}">

        {%- comment %} "All" option {%- endcomment %}
        {%- assign all_checked = '' -%}
        {%- if default_filter == blank or default_filter == 'all' -%}
          {%- assign all_checked = 'checked' -%}
        {%- endif -%}
        <label class="c-col-new__filter-item">
          <input type="radio" name="c-col-new-type-{{ section_id }}" value="all" {{ all_checked }} class="c-col-new__radio" />
          <span class="c-col-new__radio-dot"></span>
          {{ section.settings.all_label | default: 'All' }}
        </label>

        {%- comment %} Dynamic filters from custom.tag_one / custom.tag_two metafields {%- endcomment %}
        {%- for tag in filter_tags_array -%}
          {%- assign tag_trimmed = tag | strip -%}
          {%- unless tag_trimmed == blank -%}
            {%- assign tag_lower = tag_trimmed | downcase -%}
            {%- assign tag_checked = '' -%}
            {%- if default_filter == tag_lower -%}
              {%- assign tag_checked = 'checked' -%}
            {%- endif -%}
            <label class="c-col-new__filter-item">
              <input
                type="radio"
                name="c-col-new-type-{{ section_id }}"
                value="{{ tag_trimmed | escape }}"
                {{ tag_checked }}
                class="c-col-new__radio"
              />
              <span class="c-col-new__radio-dot"></span>
              {{ tag_trimmed }}
            </label>
          {%- endunless -%}
        {%- endfor -%}

      </div>
    </div>

  </aside>

  <!-- ══════════════════════════════════════
       PRODUCT GRID
  ══════════════════════════════════════ -->
  <main class="c-col-new__main">
    <div class="c-col-new__grid" id="c-col-new-grid-{{ section_id }}">

      {%- for product in collection.products -%}
        {%- assign p_img       = product.featured_image -%}
        {%- assign p_title     = product.metafields.custom.short_name.value | default: product.title -%}
        {%- assign p_price     = product.price_min | money -%}
        {%- assign p_list_raw  = product.metafields.custom.list.value | default: '' -%}
        {%- assign p_tag_one   = product.metafields.custom.tag_one.value | default: '' -%}
        {%- assign p_tag_two   = product.metafields.custom.tag_two.value | default: '' -%}
        {%- assign p_variant   = product.first_available_variant -%}
        {%- assign p_data_tags = p_tag_one | downcase | append: '|||' | append: p_tag_two | downcase -%}

        {%- comment %} Embed variants JSON for this product {%- endcomment %}
        <script type="application/json" class="c-col-new__variants-json" data-product-id="{{ product.id }}">
          [{% for v in product.variants %}{"id":{{ v.id }},"title":{{ v.title | json }},"options":{{ v.options | json }},"price":{{ v.price | json }},"price_money":{{ v.price | money | json }},"available":{{ v.available | json }}}{% unless forloop.last %},{% endunless %}{% endfor %}]
        </script>

        <div
          class="c-col-new__card"
          data-tags="{{ p_data_tags | escape }}"
          data-title="{{ product.title | downcase | escape }}"
          data-product-id="{{ product.id }}"
        >

          <!-- Image Box -->
          <div class="c-col-new__image-box">

            {%- if p_tag_one != blank or p_tag_two != blank -%}
              <div class="c-col-new__badges c-col-new__badges--{{ section.settings.badge_alignment }}">
                {%- if p_tag_one != blank -%}
                  <span class="c-col-new__badge">{{ p_tag_one }}</span>
                {%- endif -%}
                {%- if p_tag_two != blank -%}
                  <span class="c-col-new__badge">{{ p_tag_two }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- if p_img != blank -%}
              <a href="{{ product.url }}" class="c-col-new__image-link">
                <img
                  src="{{ p_img | image_url: width: 600 }}"
                  alt="{{ product.title | escape }}"
                  width="300"
                  height="300"
                  loading="lazy"
                />
              </a>
            {%- endif -%}

            {%- if section.settings.show_subscribe_save -%}
              <div class="c-col-new__subscribe-pill">
                {{ section.settings.subscribe_text | default: 'Subscribe & Save up to 15% OFF' }}
              </div>
            {%- endif -%}

          </div>

          <!-- Info -->
          <div class="c-col-new__info">

            <a href="{{ product.url }}" class="c-col-new__title-link">
              <h3 class="c-col-new__title">{{ p_title }}</h3>
            </a>

            {%- if p_list_raw != blank -%}
              <div class="c-col-new__list">
                {{ product.metafields.custom.list | metafield_tag }}
              </div>
            {%- endif -%}

            {%- comment %} ── Variant selector panel ── {%- endcomment %}
            {%- if product.has_only_default_variant == false -%}
              <div
                class="c-col-new__variant-panel"
                data-product-id="{{ product.id }}"
              >
                {%- for option in product.options_with_values -%}
                  {%- assign opt_index = forloop.index -%}
                  <div class="c-col-new__opt-group">
                    <button
                      type="button"
                      class="c-col-new__opt-header"
                      aria-expanded="{{ section.settings.variants_default_open | default: false }}"
                    >
                      <span class="c-col-new__opt-label">{{ section.settings.choose_text | default: 'Choose your' }} {{ option.name }}</span>
                      <svg class="c-col-new__opt-chevron" width="14" height="14" viewBox="0 0 24 24" fill="none">
                        <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </button>
                    <div class="c-col-new__opt-body{% if section.settings.variants_default_open %} is-open{% endif %}">
                      {%- for value in option.values -%}
                        {%- assign radio_id = 'ccn-' | append: section_id | append: '-p' | append: product.id | append: '-o' | append: opt_index | append: '-' | append: forloop.index -%}
                        {%- assign value_handle = value | handleize -%}
                        {%- assign dot_color = '' -%}
                        {%- if value_handle contains 'cool-mint' or value_handle contains 'mint' -%}
                          {%- assign dot_color = '#CDFFF1' -%}
                        {%- elsif value_handle contains 'strawberry' -%}
                          {%- assign dot_color = '#FF83BD' -%}
                        {%- elsif value_handle contains 'orange' or value_handle contains 'mango' -%}
                          {%- assign dot_color = '#FFC183' -%}
                        {%- elsif value_handle contains 'watermelon' -%}
                          {%- assign dot_color = '#FF8385' -%}
                        {%- endif -%}

                        <label class="c-col-new__opt-item" for="{{ radio_id }}">
                          <input
                            type="radio"
                            id="{{ radio_id }}"
                            class="c-col-new__opt-radio"
                            name="ccn-{{ section_id }}-p{{ product.id }}-o{{ opt_index }}"
                            value="{{ value | escape }}"
                            data-position="{{ opt_index }}"
                            data-product-id="{{ product.id }}"
                            {% if forloop.first %}checked{% endif %}
                          />
                          {%- if dot_color != '' -%}
                            <span class="c-col-new__opt-dot" style="background:{{ dot_color }};"></span>
                          {%- else -%}
                            <span class="c-col-new__opt-dot c-col-new__opt-dot--empty"></span>
                          {%- endif -%}
                          <span class="c-col-new__opt-text">{{ value }}</span>
                        </label>
                      {%- endfor -%}
                    </div>
                  </div>
                {%- endfor -%}
              </div>
            {%- endif -%}

            <div class="c-col-new__price" data-product-id="{{ product.id }}">{{ p_price }}</div>

            <div class="c-col-new__actions">
              {%- if p_variant != blank -%}
                <button
                  class="c-col-new__add-btn"
                  type="button"
                  data-product-id="{{ product.id }}"
                  data-variant-id="{{ p_variant.id }}"
                  data-product-url="{{ product.url }}"
                  data-add-text="{{ section.settings.add_to_cart_text | default: 'ADD TO CART' | escape }}"
                >
                  {{ section.settings.add_to_cart_text | default: 'ADD TO CART' }}
                </button>
              {%- endif -%}

              <a href="{{ product.url }}" class="c-col-new__learn-more">
                {{ section.settings.learn_more_text | default: 'LEARN MORE' }}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>

          </div>
        </div>
      {%- else -%}
        <p class="c-col-new__empty">{{ section.settings.empty_text | default: 'No products in this collection.' }}</p>
      {%- endfor -%}

    </div>

    <p class="c-col-new__no-results" id="c-col-new-no-results-{{ section_id }}" style="display:none;">
      {{ section.settings.no_results_text | default: 'No products found.' }}
    </p>
  </main>

</div>


<!-- ════════════════════════════════════════════════════════════
     STYLES
════════════════════════════════════════════════════════════ -->
<style>
#c-col-new-{{ section_id }} {
  display: flex;
  gap: 40px;
  max-width: 1440px;
  margin: 0 auto;
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  padding-left: 40px;
  padding-right: 40px;
  background-color: {{ section.settings.bg_color }};
  font-family: 'Raleway', sans-serif;
  align-items: flex-start;
  box-sizing: border-box;
}

/* ════ SIDEBAR ════ */
#c-col-new-{{ section_id }} .c-col-new__sidebar {
  width: {{ section.settings.sidebar_width }}px;
  flex-shrink: 0;
  position: sticky;
  top: 100px;
}

/* Search box */
#c-col-new-{{ section_id }} .c-col-new__search-box {
  display: flex;
  align-items: center;
  gap: 8px;
  border: 1.5px solid #F3F3F3B2;
  border-radius: 8px;
  padding: 8px 12px;
  margin-bottom: 20px;
  background: #F3F3F3B2;
  transition: border-color 0.2s ease;
}
#c-col-new-{{ section_id }} .c-col-new__search-box:focus-within {
  border-color: {{ section.settings.heading_color }};
}
#c-col-new-{{ section_id }} .c-col-new__search-box svg {
  color: #aaa;
  flex-shrink: 0;
}
#c-col-new-{{ section_id }} .c-col-new__search-input {
  border: none;
  outline: none;
  font-family: 'Raleway', sans-serif;
  font-size: 13px;
  color: #1F2023;
  width: 100%;
  background: transparent;
}
#c-col-new-{{ section_id }} .c-col-new__search-input::placeholder { color: #bbb; }

/* Filter section */
#c-col-new-{{ section_id }} .c-col-new__filter-section {
  border: 1px solid #002C41;
  border-radius: 10px;
  padding: 16px 16px 20px;
  background: #fff;
}

#c-col-new-{{ section_id }} .c-col-new__filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  margin-bottom: 16px;
  user-select: none;
}
#c-col-new-{{ section_id }} .c-col-new__filter-label {
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: #000;
}
#c-col-new-{{ section_id }} .c-col-new__chevron {
  color: #666;
  transition: transform 0.25s ease;
}
#c-col-new-{{ section_id }} .c-col-new__filter-section.is-collapsed .c-col-new__chevron {
  transform: rotate(-90deg);
}
#c-col-new-{{ section_id }} .c-col-new__filter-section.is-collapsed .c-col-new__filters {
  display: none;
}

/* Filter items */
#c-col-new-{{ section_id }} .c-col-new__filter-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: 'Raleway', sans-serif;
  font-size: 14px;
  color: #000;
  margin-bottom: 14px;
  cursor: pointer;
  font-weight: 700;
  user-select: none;
  transition: color 0.2s;
  line-height: 1.3;
}
#c-col-new-{{ section_id }} .c-col-new__filter-item:last-child { margin-bottom: 0; }
#c-col-new-{{ section_id }} .c-col-new__filter-item:hover { color: {{ section.settings.heading_color }}; }

#c-col-new-{{ section_id }} .c-col-new__radio { display: none; }

#c-col-new-{{ section_id }} .c-col-new__radio-dot {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 2px solid #ccc;
  flex-shrink: 0;
  transition: border-color 0.2s ease;
  position: relative;
}
#c-col-new-{{ section_id }} .c-col-new__radio-dot::after {
  content: '';
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: {{ section.settings.heading_color }};
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%) scale(0);
  transition: transform 0.2s ease;
}
#c-col-new-{{ section_id }} .c-col-new__radio:checked + .c-col-new__radio-dot {
  border-color: {{ section.settings.heading_color }};
}
#c-col-new-{{ section_id }} .c-col-new__radio:checked + .c-col-new__radio-dot::after {
  transform: translate(-50%, -50%) scale(1);
}

/* ════ MAIN & GRID ════ */
#c-col-new-{{ section_id }} .c-col-new__main {
  flex: 1;
  min-width: 0;
}

#c-col-new-{{ section_id }} .c-col-new__grid {
  display: grid;
  grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
  gap: {{ section.settings.grid_gap }}px;
}

#c-col-new-{{ section_id }} .c-col-new__empty,
#c-col-new-{{ section_id }} .c-col-new__no-results {
  font-family: 'Raleway', sans-serif;
  font-size: 15px;
  color: #999;
  text-align: center;
  padding: 60px 0;
  grid-column: 1 / -1;
}

/* ════ CARD ════ */
#c-col-new-{{ section_id }} .c-col-new__card {
  display: flex;
  flex-direction: column;
  background: transparent;
  transition: transform 0.3s ease;
  height: 100%;
}
#c-col-new-{{ section_id }} .c-col-new__card:hover {
  transform: translateY(-4px);
}
#c-col-new-{{ section_id }} .c-col-new__card[data-hidden="true"] {
  display: none;
}

/* Image Box */
#c-col-new-{{ section_id }} .c-col-new__image-box {
  position: relative;
  background: #F7F7F7;
  border: 1.5px solid {{ section.settings.heading_color }};
  border-radius: 12px;
  padding: 40px 20px;
  margin-bottom: 12px;
  margin-top: 18px;
  display: flex;
  justify-content: center;
  align-items: center;
  height: {{ section.settings.image_height_desktop }}px;
}
#c-col-new-{{ section_id }} .c-col-new__image-link {
  display: block;
  width: 100%;
  height: 100%;
}
#c-col-new-{{ section_id }} .c-col-new__image-link img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

/* Badges */
#c-col-new-{{ section_id }} .c-col-new__badges {
  position: absolute;
  top: 0;
  display: flex;
  gap: 8px;
  white-space: nowrap;
  z-index: 2;
}
#c-col-new-{{ section_id }} .c-col-new__badges--left   { left: 20px; transform: translateY(-50%); }
#c-col-new-{{ section_id }} .c-col-new__badges--center { left: 50%; transform: translate(-50%, -50%); }
#c-col-new-{{ section_id }} .c-col-new__badges--right  { right: 20px; left: auto; transform: translateY(-50%); }

#c-col-new-{{ section_id }} .c-col-new__badge {
  background: #fff;
  border: 1.5px solid {{ section.settings.heading_color }};
  color: {{ section.settings.heading_color }};
  font-family: 'Raleway', sans-serif;
  font-size: 11px;
  font-weight: 700;
  padding: 6px 14px;
  border-radius: 20px;
  line-height: 1;
}

/* Subscribe pill */
#c-col-new-{{ section_id }} .c-col-new__subscribe-pill {
  position: absolute;
  bottom: 29px;
  left: 50%;
  transform: translate(-50%, 50%);
  background: #fff;
  color: #1F2023;
  font-family: 'Raleway', sans-serif;
  font-size: 10px;
  font-weight: 800;
  font-style: italic;
  padding: 6px 24px;
  border-radius: 40px;
  text-align: center;
  white-space: nowrap;
  box-shadow: 0 4px 15px rgba(0,0,0,.08);
  width: max-content;
  max-width: 90%;
  z-index: 2;
}

/* Info */
#c-col-new-{{ section_id }} .c-col-new__info {
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: 12px;
  padding: 12px;
}
#c-col-new-{{ section_id }} .c-col-new__title-link { text-decoration: none; color: inherit; }
#c-col-new-{{ section_id }} .c-col-new__title {
  font-family: 'Raleway', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: {{ section.settings.heading_color }};
  margin: 0;
  line-height: 1.3;
}
#c-col-new-{{ section_id }} .c-col-new__title-link:hover .c-col-new__title { text-decoration: underline; }

#c-col-new-{{ section_id }} .c-col-new__list {
  font-family: 'Raleway', sans-serif;
  font-size: 13px;
  font-weight: 400;
  color: {{ section.settings.text_color }};
  line-height: 1.5;
}
#c-col-new-{{ section_id }} .c-col-new__list ul,
#c-col-new-{{ section_id }} .c-col-new__list ol {
  list-style: none;
  margin: 0;
  padding: 0;
}
#c-col-new-{{ section_id }} .c-col-new__list ul li,
#c-col-new-{{ section_id }} .c-col-new__list ol li {
  padding: 2px 0 2px 14px;
  position: relative;
}
#c-col-new-{{ section_id }} .c-col-new__list ul li::before,
#c-col-new-{{ section_id }} .c-col-new__list ol li::before {
  content: '\2022';
  position: absolute;
  left: 0;
  color: {{ section.settings.text_color }};
}
#c-col-new-{{ section_id }} .c-col-new__list p,
#c-col-new-{{ section_id }} .c-col-new__list h1,
#c-col-new-{{ section_id }} .c-col-new__list h2,
#c-col-new-{{ section_id }} .c-col-new__list h3 {
  margin: 0;
  font-size: 13px;
  font-weight: 400;
  color: {{ section.settings.text_color }};
}

/* ════ VARIANT PANEL ════ */
#c-col-new-{{ section_id }} .c-col-new__variant-panel {
  border-top: 1px solid #e5e5e5;
  margin-top: 4px;
  margin-bottom: 4px;
}

#c-col-new-{{ section_id }} .c-col-new__opt-group {
  border-bottom: 1px solid #e5e5e5;
}

#c-col-new-{{ section_id }} .c-col-new__opt-header {
  width: 100%;
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 0;
  background: none;
  border: none;
  cursor: pointer;
  font-family: 'Raleway', sans-serif;
  gap: 8px;
}

#c-col-new-{{ section_id }} .c-col-new__opt-label {
  font-size: 13px;
  font-weight: 700;
  color: #1F2023;
  text-align: left;
}

#c-col-new-{{ section_id }} .c-col-new__opt-chevron {
  color: #666;
  flex-shrink: 0;
  transition: transform 0.2s ease;
}

