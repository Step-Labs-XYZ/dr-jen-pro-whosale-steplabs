{% comment %}
  ╔══════════════════════════════════════════════════════════════╗
  ║  C - Collection New                                          ║
  ║  Metafields requeridos en productos:                         ║
  ║    custom.tag_one    → filtro / badge 1                      ║
  ║    custom.tag_two    → filtro / badge 2                      ║
  ║    custom.short_name → nombre corto (override del título)    ║
  ║    custom.list       → bullets (Rich Text metafield)           ║
  ╚══════════════════════════════════════════════════════════════╝
{% endcomment %}

{%- assign section_id    = section.id -%}
{%- assign default_filter = section.settings.default_filter | strip | downcase -%}

{%- comment %} ── Filtros desde custom.tag_one y custom.tag_two de metafields ── {%- endcomment %}
{%- assign seen_tags = '' -%}
{%- assign all_filter_tags = '' -%}
{%- for product in collection.products -%}
  {%- assign t1 = product.metafields.custom.tag_one.value | strip -%}
  {%- assign t2 = product.metafields.custom.tag_two.value | strip -%}
  {%- unless t1 == blank or seen_tags contains t1 -%}
    {%- assign seen_tags = seen_tags | append: t1 | append: '|||' -%}
    {%- assign all_filter_tags = all_filter_tags | append: t1 | append: '|||' -%}
  {%- endunless -%}
  {%- unless t2 == blank or seen_tags contains t2 -%}
    {%- assign seen_tags = seen_tags | append: t2 | append: '|||' -%}
    {%- assign all_filter_tags = all_filter_tags | append: t2 | append: '|||' -%}
  {%- endunless -%}
{%- endfor -%}
{%- assign filter_tags_array = all_filter_tags | split: '|||' -%}

<div
  id="c-col-new-{{ section_id }}"
  class="c-col-new"
  data-section-id="{{ section_id }}"
  data-collection-handle="{{ collection.handle }}"
  data-default-filter="{{ default_filter | escape }}"
>

  <!-- ══════════════════════════════════════
       SIDEBAR
  ══════════════════════════════════════ -->
  <aside class="c-col-new__sidebar" id="c-col-new-sidebar-{{ section_id }}">

    {%- if section.settings.show_search -%}
    <div class="c-col-new__search-box">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none">
        <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="2"/>
        <path d="M20 20L16.65 16.65" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
      <input
        type="text"
        id="c-col-new-search-{{ section_id }}"
        class="c-col-new__search-input"
        placeholder="{{ section.settings.search_placeholder | default: 'Search' }}"
        autocomplete="off"
        aria-label="Search products"
      />
    </div>
    {%- endif -%}

    <div class="c-col-new__filter-section" id="c-col-new-filter-section-{{ section_id }}">
      <div class="c-col-new__filter-header" role="button" aria-expanded="true" aria-controls="c-col-new-filters-{{ section_id }}">
        <span class="c-col-new__filter-label">{{ section.settings.filter_label | default: 'TYPE' }}</span>
        <svg class="c-col-new__chevron" width="14" height="14" viewBox="0 0 24 24" fill="none">
          <path d="M6 9L12 15L18 9" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </div>

      <div class="c-col-new__filters" id="c-col-new-filters-{{ section_id }}">

        {%- comment %} "All" option {%- endcomment %}
        {%- assign all_checked = '' -%}
        {%- if default_filter == blank or default_filter == 'all' -%}
          {%- assign all_checked = 'checked' -%}
        {%- endif -%}
        <label class="c-col-new__filter-item">
          <input type="radio" name="c-col-new-type-{{ section_id }}" value="all" {{ all_checked }} class="c-col-new__radio" />
          <span class="c-col-new__radio-dot"></span>
          {{ section.settings.all_label | default: 'All' }}
        </label>

        {%- comment %} Dynamic filters from custom.tag_one / custom.tag_two metafields {%- endcomment %}
        {%- for tag in filter_tags_array -%}
          {%- assign tag_trimmed = tag | strip -%}
          {%- unless tag_trimmed == blank -%}
            {%- assign tag_lower = tag_trimmed | downcase -%}
            {%- assign tag_checked = '' -%}
            {%- if default_filter == tag_lower -%}
              {%- assign tag_checked = 'checked' -%}
            {%- endif -%}
            <label class="c-col-new__filter-item">
              <input
                type="radio"
                name="c-col-new-type-{{ section_id }}"
                value="{{ tag_trimmed | escape }}"
                {{ tag_checked }}
                class="c-col-new__radio"
              />
              <span class="c-col-new__radio-dot"></span>
              {{ tag_trimmed }}
            </label>
          {%- endunless -%}
        {%- endfor -%}

      </div>
    </div>

  </aside>

  <!-- ══════════════════════════════════════
       PRODUCT GRID
  ══════════════════════════════════════ -->
  <main class="c-col-new__main">
    <div class="c-col-new__grid" id="c-col-new-grid-{{ section_id }}">

      {%- for product in collection.products -%}
        {%- assign p_img       = product.featured_image -%}
        {%- assign p_title     = product.metafields.custom.short_name.value | default: product.title -%}
        {%- assign p_price     = product.price_min | money -%}
        {%- assign p_list_raw  = product.metafields.custom.list.value | default: '' -%}
        {%- assign p_tag_one   = product.metafields.custom.tag_one.value | default: '' -%}
        {%- assign p_tag_two   = product.metafields.custom.tag_two.value | default: '' -%}
        {%- assign p_variant   = product.first_available_variant -%}
        {%- assign p_data_tags = p_tag_one | downcase | append: '|||' | append: p_tag_two | downcase -%}

        <div
          class="c-col-new__card"
          data-tags="{{ p_data_tags | escape }}"
          data-title="{{ product.title | downcase | escape }}"
        >

          <!-- Image Box -->
          <div class="c-col-new__image-box">

            {%- if p_tag_one != blank or p_tag_two != blank -%}
              <div class="c-col-new__badges c-col-new__badges--{{ section.settings.badge_alignment }}">
                {%- if p_tag_one != blank -%}
                  <span class="c-col-new__badge">{{ p_tag_one }}</span>
                {%- endif -%}
                {%- if p_tag_two != blank -%}
                  <span class="c-col-new__badge">{{ p_tag_two }}</span>
                {%- endif -%}
              </div>
            {%- endif -%}

            {%- if p_img != blank -%}
              <a href="{{ product.url }}" class="c-col-new__image-link">
                <img
                  src="{{ p_img | image_url: width: 600 }}"
                  alt="{{ product.title | escape }}"
                  width="300"
                  height="300"
                  loading="lazy"
                />
              </a>
            {%- endif -%}

            {%- if section.settings.show_subscribe_save -%}
              <div class="c-col-new__subscribe-pill">
                {{ section.settings.subscribe_text | default: 'Subscribe & Save up to 15% OFF' }}
              </div>
            {%- endif -%}

          </div>

          <!-- Info -->
          <div class="c-col-new__info">

            <a href="{{ product.url }}" class="c-col-new__title-link">
              <h3 class="c-col-new__title">{{ p_title }}</h3>
            </a>

            {%- if p_list_raw != blank -%}
              <div class="c-col-new__list">
                {{ product.metafields.custom.list | metafield_tag }}
              </div>
            {%- endif -%}

            <div class="c-col-new__price">{{ p_price }}</div>

            <div class="c-col-new__actions">
              {%- if p_variant != blank -%}
                <button
                  class="c-col-new__add-btn"
                  type="button"
                  data-variant-id="{{ p_variant.id }}"
                  data-product-url="{{ product.url }}"
                  data-add-text="{{ section.settings.add_to_cart_text | default: 'ADD TO CART' | escape }}"
                >
                  {{ section.settings.add_to_cart_text | default: 'ADD TO CART' }}
                </button>
              {%- endif -%}

              <a href="{{ product.url }}" class="c-col-new__learn-more">
                {{ section.settings.learn_more_text | default: 'LEARN MORE' }}
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none">
                  <path d="M5 12H19M19 12L12 5M19 12L12 19" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </a>
            </div>

          </div>
        </div>
      {%- else -%}
        <p class="c-col-new__empty">{{ section.settings.empty_text | default: 'No products in this collection.' }}</p>
      {%- endfor -%}

    </div>

    <p class="c-col-new__no-results" id="c-col-new-no-results-{{ section_id }}" style="display:none;">
      {{ section.settings.no_results_text | default: 'No products found.' }}
    </p>
  </main>

</div>


<!-- ════════════════════════════════════════════════════════════
     STYLES
════════════════════════════════════════════════════════════ -->
<style>
#c-col-new-{{ section_id }} {
  display: flex;
  gap: 40px;
  max-width: 1440px;
  margin: 0 auto;
  padding-top: {{ section.settings.padding_top_desktop }}px;
  padding-bottom: {{ section.settings.padding_bottom_desktop }}px;
  padding-left: 40px;
  padding-right: 40px;
  background-color: {{ section.settings.bg_color }};
  font-family: 'Raleway', sans-serif;
  align-items: flex-start;
  box-sizing: border-box;
}

/* ════ SIDEBAR ════ */
#c-col-new-{{ section_id }} .c-col-new__sidebar {
  width: {{ section.settings.sidebar_width }}px;
  flex-shrink: 0;
  position: sticky;
  top: 100px;
}

/* Search box */
#c-col-new-{{ section_id }} .c-col-new__search-box {
  display: flex;
  align-items: center;
  gap: 8px;
  border: 1.5px solid #e2e8f0;
  border-radius: 8px;
  padding: 8px 12px;
  margin-bottom: 20px;
  background: #fff;
  transition: border-color 0.2s ease;
}
#c-col-new-{{ section_id }} .c-col-new__search-box:focus-within {
  border-color: {{ section.settings.heading_color }};
}
#c-col-new-{{ section_id }} .c-col-new__search-box svg {
  color: #aaa;
  flex-shrink: 0;
}
#c-col-new-{{ section_id }} .c-col-new__search-input {
  border: none;
  outline: none;
  font-family: 'Raleway', sans-serif;
  font-size: 13px;
  color: #1F2023;
  width: 100%;
  background: transparent;
}
#c-col-new-{{ section_id }} .c-col-new__search-input::placeholder { color: #bbb; }

/* Filter section — bordered box like the design */
#c-col-new-{{ section_id }} .c-col-new__filter-section {
  border: 2px solid #002C41;
  border-radius: 10px;
  padding: 16px 16px 20px;
  background: #fff;
}

#c-col-new-{{ section_id }} .c-col-new__filter-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  cursor: pointer;
  margin-bottom: 16px;
  user-select: none;
}
#c-col-new-{{ section_id }} .c-col-new__filter-label {
  font-size: 14px;
  font-weight: 700;
  letter-spacing: 0.08em;
  color: #000;
}
#c-col-new-{{ section_id }} .c-col-new__chevron {
  color: #666;
  transition: transform 0.25s ease;
}
#c-col-new-{{ section_id }} .c-col-new__filter-section.is-collapsed .c-col-new__chevron {
  transform: rotate(-90deg);
}
#c-col-new-{{ section_id }} .c-col-new__filter-section.is-collapsed .c-col-new__filters {
  display: none;
}

/* Filter items */
#c-col-new-{{ section_id }} .c-col-new__filter-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-family: 'Raleway', sans-serif;
  font-size: 14px;
  color: {{ section.settings.text_color }};
  margin-bottom: 14px;
  cursor: pointer;
  font-weight:700;
  user-select: none;
  transition: color 0.2s;
  line-height: 1.3;
}
#c-col-new-{{ section_id }} .c-col-new__filter-item:last-child { margin-bottom: 0; }
#c-col-new-{{ section_id }} .c-col-new__filter-item:hover { color: {{ section.settings.heading_color }}; }

#c-col-new-{{ section_id }} .c-col-new__radio { display: none; }

#c-col-new-{{ section_id }} .c-col-new__radio-dot {
  width: 18px;
  height: 18px;
  border-radius: 50%;
  border: 2px solid #ccc;
  flex-shrink: 0;
  transition: border-color 0.2s ease;
  position: relative;
}
#c-col-new-{{ section_id }} .c-col-new__radio-dot::after {
  content: '';
  width: 8px;
  height: 8px;
  border-radius: 50%;
  background: {{ section.settings.heading_color }};
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%) scale(0);
  transition: transform 0.2s ease;
}
#c-col-new-{{ section_id }} .c-col-new__radio:checked + .c-col-new__radio-dot {
  border-color: {{ section.settings.heading_color }};
}
#c-col-new-{{ section_id }} .c-col-new__radio:checked + .c-col-new__radio-dot::after {
  transform: translate(-50%, -50%) scale(1);
}

/* ════ MAIN & GRID ════ */
#c-col-new-{{ section_id }} .c-col-new__main {
  flex: 1;
  min-width: 0;
}

#c-col-new-{{ section_id }} .c-col-new__grid {
  display: grid;
  grid-template-columns: repeat({{ section.settings.columns_desktop }}, 1fr);
  gap: {{ section.settings.grid_gap }}px;
}

#c-col-new-{{ section_id }} .c-col-new__empty,
#c-col-new-{{ section_id }} .c-col-new__no-results {
  font-family: 'Raleway', sans-serif;
  font-size: 15px;
  color: #999;
  text-align: center;
  padding: 60px 0;
  grid-column: 1 / -1;
}

/* ════ CARD ════ */
#c-col-new-{{ section_id }} .c-col-new__card {
  display: flex;
  flex-direction: column;
  background: transparent;
  transition: transform 0.3s ease;
  height: 100%;
}
#c-col-new-{{ section_id }} .c-col-new__card:hover {
  transform: translateY(-4px);
}
#c-col-new-{{ section_id }} .c-col-new__card[data-hidden="true"] {
  display: none;
}

/* Image Box */
#c-col-new-{{ section_id }} .c-col-new__image-box {
  position: relative;
  background: #F7F7F7;
  border: 1.5px solid {{ section.settings.heading_color }};
  border-radius: 12px;
  padding: 40px 20px;
  margin-bottom: 12px;
  margin-top: 18px;
  display: flex;
  justify-content: center;
  align-items: center;
  height: {{ section.settings.image_height_desktop }}px;
}
#c-col-new-{{ section_id }} .c-col-new__image-link {
  display: block;
  width: 100%;
  height: 100%;
}
#c-col-new-{{ section_id }} .c-col-new__image-link img {
  width: 100%;
  height: 100%;
  object-fit: contain;
}

/* Badges */
#c-col-new-{{ section_id }} .c-col-new__badges {
  position: absolute;
  top: 0;
  display: flex;
  gap: 8px;
  white-space: nowrap;
  z-index: 2;
}
#c-col-new-{{ section_id }} .c-col-new__badges--left   { left: 20px; transform: translateY(-50%); }
#c-col-new-{{ section_id }} .c-col-new__badges--center { left: 50%; transform: translate(-50%, -50%); }
#c-col-new-{{ section_id }} .c-col-new__badges--right  { right: 20px; left: auto; transform: translateY(-50%); }

#c-col-new-{{ section_id }} .c-col-new__badge {
  background: #fff;
  border: 1.5px solid {{ section.settings.heading_color }};
  color: {{ section.settings.heading_color }};
  font-family: 'Raleway', sans-serif;
  font-size: 11px;
  font-weight: 700;
  padding: 6px 14px;
  border-radius: 20px;
  line-height: 1;
}

/* Subscribe pill */
#c-col-new-{{ section_id }} .c-col-new__subscribe-pill {
  position: absolute;
  bottom: 29px;
  left: 50%;
  transform: translate(-50%, 50%);
  background: #fff;
  color: #1F2023;
  font-family: 'Raleway', sans-serif;
  font-size: 10px;
  font-weight: 800;
  font-style: italic;
  padding: 6px 24px;
  border-radius: 40px;
  text-align: center;
  white-space: nowrap;
  box-shadow: 0 4px 15px rgba(0,0,0,.08);
  width: max-content;
  max-width: 90%;
  z-index: 2;
}

/* Info */
#c-col-new-{{ section_id }} .c-col-new__info {
  display: flex;
  flex-direction: column;
  flex: 1;
  gap: 12px;
  padding: 12px;
}
#c-col-new-{{ section_id }} .c-col-new__title-link { text-decoration: none; color: inherit; }
#c-col-new-{{ section_id }} .c-col-new__title {
  font-family: 'Raleway', sans-serif;
  font-size: 16px;
  font-weight: 700;
  color: {{ section.settings.heading_color }};
  margin: 0;
  line-height: 1.3;
}
#c-col-new-{{ section_id }} .c-col-new__title-link:hover .c-col-new__title { text-decoration: underline; }

#c-col-new-{{ section_id }} .c-col-new__list {
  font-family: 'Raleway', sans-serif;
  font-size: 13px;
  font-weight: 400;
  color: {{ section.settings.text_color }};
  line-height: 1.5;
}
#c-col-new-{{ section_id }} .c-col-new__list ul,
#c-col-new-{{ section_id }} .c-col-new__list ol {
  list-style: none;
  margin: 0;
  padding: 0;
}
#c-col-new-{{ section_id }} .c-col-new__list ul li,
#c-col-new-{{ section_id }} .c-col-new__list ol li {
  padding: 2px 0 2px 14px;
  position: relative;
}
#c-col-new-{{ section_id }} .c-col-new__list ul li::before,
#c-col-new-{{ section_id }} .c-col-new__list ol li::before {
  content: '\2022';
  position: absolute;
  left: 0;
  color: {{ section.settings.text_color }};
}
#c-col-new-{{ section_id }} .c-col-new__list p,
#c-col-new-{{ section_id }} .c-col-new__list h1,
#c-col-new-{{ section_id }} .c-col-new__list h2,
#c-col-new-{{ section_id }} .c-col-new__list h3 {
  margin: 0;
  font-size: 13px;
  font-weight: 400;
  color: {{ section.settings.text_color }};
}

#c-col-new-{{ section_id }} .c-col-new__price {
  font-family: 'Raleway', sans-serif;
  font-size: 20px;
  font-weight: 700;
  color: #1F2023;
  margin-top: auto;
}

/* Actions */
#c-col-new-{{ section_id }} .c-col-new__actions {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 16px;
  width: 100%;
}

#c-col-new-{{ section_id }} .c-col-new__add-btn {
  width: 100%;
  padding: 14px;
  background: {{ section.settings.btn_bg_color }};
  color: {{ section.settings.btn_text_color }};
  border: none;
  border-radius: 40px;
  font-family: 'Raleway', sans-serif;
  font-size: 14px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.5px;
  cursor: pointer;
  text-align: center;
  transition: background 0.3s ease, transform 0.3s ease;
}
#c-col-new-{{ section_id }} .c-col-new__add-btn:hover {
  background: {{ section.settings.btn_bg_hover }};
  transform: translateY(-2px);
}
#c-col-new-{{ section_id }} .c-col-new__add-btn:disabled {
  opacity: 0.7;
  cursor: not-allowed;
  transform: none;
}

#c-col-new-{{ section_id }} .c-col-new__learn-more {
  font-family: 'Raleway', sans-serif;
  font-size: 14px;
  font-weight: 800;
  color: {{ section.settings.link_color }};
  text-decoration: none;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 6px;
  transition: opacity 0.2s ease;
}
#c-col-new-{{ section_id }} .c-col-new__learn-more:hover { opacity: 0.7; }

/* ════ RESPONSIVE ════ */
@media (max-width: 1100px) {
  #c-col-new-{{ section_id }} .c-col-new__grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 768px) {
  #c-col-new-{{ section_id }} {
    display:block;
    flex-direction: column;
    padding-top: {{ section.settings.padding_top_mobile }}px;
    padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    padding-left: 20px;
    padding-right: 20px;
    gap: 20px;
  }

  #c-col-new-{{ section_id }} .c-col-new__sidebar {
    width: 100%;
    position: static;
    padding-right: 20px;
  }

  #c-col-new-{{ section_id }} .c-col-new__search-box {
    margin-bottom: 16px;
  }

  /* Filter section box stays, filters become pills */
  #c-col-new-{{ section_id }} .c-col-new__filter-header {
    margin-bottom: 12px;
  }
  #c-col-new-{{ section_id }} .c-col-new__filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  #c-col-new-{{ section_id }} .c-col-new__filter-item {
    margin-bottom: 0;
    padding: 7px 16px;
    border: 1.5px solid {{ section.settings.heading_color }};
    border-radius: 40px;
    font-size: 13px;
    transition: background 0.2s ease, color 0.2s ease;
    gap: 0;
  }
  #c-col-new-{{ section_id }} .c-col-new__filter-item.is-active-pill {
    background: {{ section.settings.heading_color }};
    color: #fff;
  }
  #c-col-new-{{ section_id }} .c-col-new__radio-dot { display: none; }

  /* Grid mobile: 1 o 2 columnas */
  #c-col-new-{{ section_id }} .c-col-new__grid {
    display: grid;
    grid-template-columns: repeat({{ section.settings.columns_mobile }}, 1fr);
    gap: 16px;
  }

  #c-col-new-{{ section_id }} .c-col-new__image-box {
    height: {{ section.settings.image_height_mobile }}px;
  }
}
</style>


<!-- ════════════════════════════════════════════════════════════
     JAVASCRIPT
════════════════════════════════════════════════════════════ -->
<script>
(function () {
  var sId      = {{ section_id | json }};
  var wrapper  = document.getElementById('c-col-new-' + sId);
  if (!wrapper) return;

  var grid        = wrapper.querySelector('.c-col-new__grid');
  var noResults   = wrapper.querySelector('.c-col-new__no-results');
  var searchInput = wrapper.querySelector('.c-col-new__search-input');
  var radios      = wrapper.querySelectorAll('.c-col-new__radio');
  var filterHdr   = wrapper.querySelector('.c-col-new__filter-header');
  var filterSec   = wrapper.querySelector('.c-col-new__filter-section');

  /* ── Read default filter set by Liquid in the HTML attribute ── */
  var defaultFilter = (wrapper.dataset.defaultFilter || 'all').trim().toLowerCase();
  var activeFilter  = defaultFilter;
  var searchQuery   = '';

  /* ── Sync checked state to default (in case Liquid didn't pre-check) ── */
  radios.forEach(function(radio) {
    var val = radio.value.trim().toLowerCase();
    if (val === activeFilter) {
      radio.checked = true;
    } else if (activeFilter !== 'all' && val === 'all') {
      radio.checked = false;
    }
  });

  /* ── Filter + Search logic ── */
  function applyFilters() {
    var visible = 0;

    grid.querySelectorAll('.c-col-new__card').forEach(function(card) {
      var tags  = (card.dataset.tags  || '').toLowerCase();
      var title = (card.dataset.title || '').toLowerCase();

      var matchFilter =
        activeFilter === 'all' ||
        tags.indexOf(activeFilter) !== -1;

      var matchSearch =
        searchQuery === '' ||
        title.indexOf(searchQuery) !== -1 ||
        tags.indexOf(searchQuery) !== -1;

      var show = matchFilter && matchSearch;
      card.setAttribute('data-hidden', show ? 'false' : 'true');
      if (show) visible++;
    });

    if (noResults) {
      noResults.style.display = visible === 0 ? 'block' : 'none';
    }

    /* Update active-pill class for mobile */
    wrapper.querySelectorAll('.c-col-new__filter-item').forEach(function(label) {
      var radio = label.querySelector('.c-col-new__radio');
      if (radio && radio.checked) {
        label.classList.add('is-active-pill');
      } else {
        label.classList.remove('is-active-pill');
      }
    });
  }

  /* ── Radio change ── */
  radios.forEach(function(radio) {
    radio.addEventListener('change', function() {
      if (this.checked) {
        activeFilter = this.value.trim().toLowerCase();
        applyFilters();
      }
    });
  });

  /* ── Search ── */
  if (searchInput) {
    searchInput.addEventListener('input', function() {
      searchQuery = this.value.trim().toLowerCase();
      applyFilters();
    });
  }

  /* ── Sidebar collapse ── */
  if (filterHdr && filterSec) {
    filterHdr.addEventListener('click', function() {
      var collapsed = filterSec.classList.toggle('is-collapsed');
      filterHdr.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
    });
  }

  /* ── Add to Cart AJAX ── */
  grid.querySelectorAll('.c-col-new__add-btn').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var variantId  = this.dataset.variantId;
      var productUrl = this.dataset.productUrl;
      var addText    = this.dataset.addText || 'ADD TO CART';

      if (!variantId || variantId === '') {
        if (productUrl) window.location.href = productUrl;
        return;
      }

      this.disabled    = true;
      this.textContent = 'ADDING...';

      try {
        var res = await fetch('/cart/add.js', {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
            'Accept': 'application/json'
          },
          body: JSON.stringify({ id: Number(variantId), quantity: 1 })
        });

        if (!res.ok) {
          var errText = await res.text();
          throw new Error(errText || 'Add to cart failed');
        }

        document.dispatchEvent(new CustomEvent('cart:updated'));
        document.dispatchEvent(new CustomEvent('cart:refresh'));
        window.location.href = productUrl || '/cart';

      } catch (err) {
        console.error('[C-Collection-New] Add to cart error:', err);
        this.textContent = 'ERROR';
        var self = this;
        setTimeout(function() {
          self.textContent = addText;
          self.disabled    = false;
        }, 1400);
      }
    });
  });

  /* ── Init ── */
  applyFilters();

})();
</script>


