<!-- ════════════════════════════════════════════════════════════
     JAVASCRIPT
════════════════════════════════════════════════════════════ -->
<script>
(function () {
  var sId     = {{ section_id | json }};
  var wrapper = document.getElementById('c-col-new-' + sId);
  if (!wrapper) return;

  var grid        = wrapper.querySelector('.c-col-new__grid');
  var noResults   = wrapper.querySelector('.c-col-new__no-results');
  var searchInput = wrapper.querySelector('.c-col-new__search-input');
  var radios      = wrapper.querySelectorAll('.c-col-new__radio');
  var filterHdr   = wrapper.querySelector('.c-col-new__filter-header');
  var filterSec   = wrapper.querySelector('.c-col-new__filter-section');

  /* ── Default filter ── */
  var defaultFilter = (wrapper.dataset.defaultFilter || 'all').trim().toLowerCase();
  var activeFilter  = defaultFilter;
  var searchQuery   = '';

  radios.forEach(function(radio) {
    var val = radio.value.trim().toLowerCase();
    if (val === activeFilter) radio.checked = true;
    else if (activeFilter !== 'all' && val === 'all') radio.checked = false;
  });

  /* ════════════════════════════════════════
     VARIANTS DATA
  ════════════════════════════════════════ */
  var variantsByProduct = {};
  document.querySelectorAll('.c-col-new__variants-json').forEach(function(el) {
    var pid = el.dataset.productId;
    try { variantsByProduct[pid] = JSON.parse(el.textContent.trim()); } catch(e) {
      console.warn('[C-Collection-New] Could not parse variants for product', pid, e);
    }
  });

  function findVariant(pid, selectedOptions) {
    var variants = variantsByProduct[pid] || [];
    return variants.find(function(v) {
      return v.options.every(function(opt, i) {
        var pos = i + 1;
        return !selectedOptions[pos] || opt === selectedOptions[pos];
      });
    }) || null;
  }

  function getOptionsForCard(card) {
    var map = {};
    card.querySelectorAll('.c-col-new__opt-radio:checked').forEach(function(r) {
      map[parseInt(r.dataset.position, 10)] = r.value;
    });
    return map;
  }

  function updateCardPrice(card) {
    var pid = card.dataset.productId;
    if (!pid) return;
    var priceEl = card.querySelector('.c-col-new__price[data-product-id]');
    if (!priceEl) return;
    var variant = findVariant(pid, getOptionsForCard(card));
    if (variant) priceEl.textContent = variant.price_money;
  }

  function updateCardBtn(card) {
    var pid = card.dataset.productId;
    if (!pid) return;
    var btn = card.querySelector('.c-col-new__add-btn');
    if (!btn) return;
    var variant = findVariant(pid, getOptionsForCard(card));
    if (variant) {
      btn.dataset.variantId = variant.id;
      btn.disabled = !variant.available;
      if (!variant.available) {
        btn.textContent = 'SOLD OUT';
      } else {
        btn.textContent = btn.dataset.addText || 'ADD TO CART';
      }
    }
  }

  /* ── Variant panel accordions ── */
  grid.querySelectorAll('.c-col-new__opt-group').forEach(function(group) {
    var hdr  = group.querySelector('.c-col-new__opt-header');
    var body = group.querySelector('.c-col-new__opt-body');
    if (!hdr || !body) return;
    hdr.addEventListener('click', function() {
      var open = body.classList.toggle('is-open');
      hdr.setAttribute('aria-expanded', open ? 'true' : 'false');
    });
  });

  /* ── Variant radio change ── */
  grid.querySelectorAll('.c-col-new__opt-radio').forEach(function(radio) {
    radio.addEventListener('change', function() {
      var card = this.closest('.c-col-new__card');
      if (!card) return;
      updateCardPrice(card);
      updateCardBtn(card);
    });
  });

  /* ── Init all cards ── */
  grid.querySelectorAll('.c-col-new__card').forEach(function(card) {
    updateCardPrice(card);
    updateCardBtn(card);
  });

  /* ════════════════════════════════════════
     CART — refreshCartUI + addItemsToCart
     (mismo patrón que c_product_page)
  ════════════════════════════════════════ */
  function refreshCartUI(response) {
    /* 1. Render sections devueltas por Shopify */
    if (response.sections) {
      Object.entries(response.sections).forEach(function(entry) {
        var id   = entry[0];
        var html = entry[1];
        var targets = document.querySelectorAll(
          '[id="shopify-section-' + id + '"], #shopify-section-' + id +
          ', [data-section-id="' + id + '"], #' + id +
          ', cart-drawer#' + id + ', cart-drawer[section="' + id + '"]'
        );
        targets.forEach(function(el) {
          var tmp   = document.createElement('div');
          tmp.innerHTML = html;
          var inner = tmp.querySelector('#shopify-section-' + id) ||
                      tmp.querySelector('#' + id) ||
                      tmp.firstElementChild;
          el.innerHTML = inner ? inner.innerHTML : html;
        });
      });
    }

    /* 2. Actualizar contador del carrito */
    if (typeof response.item_count !== 'undefined') {
      document.querySelectorAll('[data-cart-count], .cart-count, #cart-count, .header__cart-count, [aria-label*="cart"] .count').forEach(function(el) {
        el.textContent = response.item_count;
      });
      document.querySelectorAll('#cart-icon-bubble').forEach(function(el) {
        el.innerHTML = response.item_count > 0
          ? '<span class="visually-hidden">Cart</span><span class="cart-count-bubble"><span aria-hidden="true">' + response.item_count + '</span><span class="visually-hidden">' + response.item_count + ' item' + (response.item_count !== 1 ? 's' : '') + '</span></span>'
          : '';
      });
    }

    /* 3. Disparar eventos estándar */
    document.dispatchEvent(new CustomEvent('cart:updated',             { detail: response }));
    document.dispatchEvent(new CustomEvent('cart:refresh',             { detail: response }));
    document.dispatchEvent(new CustomEvent('theme:cart:added',         { detail: response }));
    document.dispatchEvent(new CustomEvent('eurus:cart:items-changed', { detail: response }));

    /* 4. Abrir el drawer — multi-fallback */
    (function openDrawer() {
      /* Alpine / Eurus / Symmetry */
      if (typeof window.Alpine !== 'undefined') {
        var miniCart = Alpine.store('xMiniCart');
        var popup    = Alpine.store('xPopup');
        if (miniCart && typeof miniCart.openCart === 'function') {
          if (popup && typeof popup.close === 'function') popup.close();
          miniCart.openCart();
          document.dispatchEvent(new CustomEvent('eurus:cart:redirect'));
          return;
        }
      }
      /* Shopify theme object */
      if (window.Shopify && window.Shopify.theme && window.Shopify.theme.cartDrawer &&
          typeof window.Shopify.theme.cartDrawer.open === 'function') {
        window.Shopify.theme.cartDrawer.open();
        return;
      }
      /* cart-drawer custom element (Dawn y similares) */
      var cartDrawer = document.querySelector('cart-drawer');
      if (cartDrawer && typeof cartDrawer.open === 'function') {
        cartDrawer.open();
        return;
      }
      /* Fallback: toggle clases/atributos */
      var drawer = document.querySelector(
        '#cart-drawer, #CartDrawer, #mini-cart, .cart-drawer, .mini-cart, [data-cart-drawer]'
      );
      if (drawer) {
        drawer.classList.add('is-open', 'active', 'open');
        drawer.removeAttribute('hidden');
        drawer.setAttribute('aria-hidden', 'false');
        drawer.setAttribute('open', '');
        document.body.classList.add('overflow-hidden');
        document.querySelectorAll('[aria-controls="mini-cart"], [aria-controls="CartDrawer"], [aria-controls="cart-drawer"]').forEach(function(btn) {
          btn.setAttribute('aria-expanded', 'true');
        });
      }
    })();
  }

  async function addItemsToCart(items) {
    /* Recopilar section IDs del drawer para que Shopify devuelva HTML actualizado */
    var sectionIds = [];
    document.querySelectorAll('[id^="shopify-section-"], cart-drawer[section], [data-section-id]').forEach(function(el) {
      var id = el.getAttribute('section') || el.dataset.sectionId || el.id.replace('shopify-section-', '');
      if (id && !sectionIds.includes(id) &&
          (el.id.includes('cart') || el.id.includes('mini') || el.getAttribute('section'))) {
        sectionIds.push(id);
      }
    });
    ['mini-cart', 'cart-drawer'].forEach(function(id) {
      if (!sectionIds.includes(id)) sectionIds.push(id);
    });

    var response = await fetch((window.Shopify.routes.root || '/') + 'cart/add.js', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json', 'X-Requested-With': 'XMLHttpRequest' },
      body: JSON.stringify({ items: items, sections: sectionIds })
    });
    var payload = await response.json();
    if (!response.ok || payload.status === 422) {
      throw new Error(payload.description || 'Add to cart failed');
    }

    /* Obtener item_count actualizado */
    try {
      var cartResp = await fetch((window.Shopify.routes.root || '/') + 'cart.js', {
        headers: { Accept: 'application/json', 'X-Requested-With': 'XMLHttpRequest' }
      });
      if (cartResp.ok) {
        var cartData = await cartResp.json();
        payload.item_count = cartData.item_count;
      }
    } catch(_) {}

    refreshCartUI(payload);
    return payload;
  }

  /* ── Add to Cart click ── */
  grid.querySelectorAll('.c-col-new__add-btn').forEach(function(btn) {
    btn.addEventListener('click', async function() {
      var variantId = this.dataset.variantId;
      var addText   = this.dataset.addText || 'ADD TO CART';
      if (!variantId) return;

      this.disabled    = true;
      this.textContent = 'ADDING...';
      var self = this;

      try {
        await addItemsToCart([{ id: Number(variantId), quantity: 1 }]);
        self.textContent = addText;
        self.disabled    = false;
      } catch(err) {
        console.error('[C-Collection-New] ATC error:', err);
        self.textContent = 'ERROR';
        setTimeout(function() {
          self.textContent = addText;
          self.disabled    = false;
        }, 1400);
      }
    });
  });

  /* ════════════════════════════════════════
     FILTER + SEARCH
  ════════════════════════════════════════ */
  function applyFilters() {
    var visible = 0;
    grid.querySelectorAll('.c-col-new__card').forEach(function(card) {
      var tags  = (card.dataset.tags  || '').toLowerCase();
      var title = (card.dataset.title || '').toLowerCase();
      var matchFilter = activeFilter === 'all' || tags.indexOf(activeFilter) !== -1;
      var matchSearch = searchQuery === '' || title.indexOf(searchQuery) !== -1 || tags.indexOf(searchQuery) !== -1;
      var show = matchFilter && matchSearch;
      card.setAttribute('data-hidden', show ? 'false' : 'true');
      if (show) visible++;
    });

    if (noResults) noResults.style.display = visible === 0 ? 'block' : 'none';

    wrapper.querySelectorAll('.c-col-new__filter-item').forEach(function(label) {
      var radio = label.querySelector('.c-col-new__radio');
      if (radio && radio.checked) label.classList.add('is-active-pill');
      else label.classList.remove('is-active-pill');
    });
  }

  radios.forEach(function(radio) {
    radio.addEventListener('change', function() {
      if (this.checked) {
        activeFilter = this.value.trim().toLowerCase();
        applyFilters();
      }
    });
  });

  if (searchInput) {
    searchInput.addEventListener('input', function() {
      searchQuery = this.value.trim().toLowerCase();
      applyFilters();
    });
  }

  /* ── Sidebar collapse ── */
  if (filterHdr && filterSec) {
    filterHdr.addEventListener('click', function() {
      var collapsed = filterSec.classList.toggle('is-collapsed');
      filterHdr.setAttribute('aria-expanded', collapsed ? 'false' : 'true');
    });
  }

  /* ── Init ── */
  applyFilters();

})();
</script>


