<div class="video-section" style="
  max-width: {{ section.settings.max_width }}px;
  margin: 0 auto;
  padding: {{ section.settings.padding_top }}px {{ section.settings.padding_horizontal }}px {{ section.settings.padding_bottom }}px;
  text-align: {{ section.settings.text_alignment }};
">

  {% if section.settings.heading != blank %}
    <h2 style="
      color: {{ section.settings.heading_color }};
      font-size: {{ section.settings.heading_size }}px;
      margin-bottom: {{ section.settings.heading_spacing }}px;
    ">
      {{ section.settings.heading }}
    </h2>
  {% endif %}

  <div class="video-wrapper" style="
    position: relative;
    width: 100%;
    padding-bottom: 56.25%;
    height: 0;
    border-radius: {{ section.settings.border_radius }}px;
    background: {{ section.settings.background_color }};
    overflow: hidden;
  ">
    {% if section.settings.video_source == 'upload' and section.settings.video_file != blank %}
      <video
        style="position:absolute;top:0;left:0;width:100%;height:100%;"
        controls
        {% if section.settings.autoplay %}autoplay{% endif %}
        {% if section.settings.loop %}loop{% endif %}
        {% if section.settings.muted %}muted{% endif %}
        playsinline
        preload="metadata"
      >
        {% for source in section.settings.video_file.sources %}
          <source src="{{ source.url }}" type="video/{{ source.format }}">
        {% endfor %}
      </video>

    {% elsif section.settings.video_source == 'youtube' and section.settings.youtube_url != blank %}
      {% assign youtube_id = section.settings.youtube_url | split: 'v=' | last | split: '&' | first %}
      {% if youtube_id == section.settings.youtube_url %}
        {% assign youtube_id = section.settings.youtube_url | split: 'youtu.be/' | last | split: '?' | first %}
      {% endif %}

      <iframe
        src="https://www.youtube.com/embed/{{ youtube_id }}?rel=0{% if section.settings.autoplay %}&autoplay=1{% endif %}{% if section.settings.loop %}&loop=1&playlist={{ youtube_id }}{% endif %}{% if section.settings.muted %}&mute=1{% endif %}"
        style="position:absolute;top:0;left:0;width:100%;height:100%;border:0;"
        allow="autoplay; encrypted-media; picture-in-picture"
        allowfullscreen
        loading="lazy"
      ></iframe>

    {% else %}
      <div style="
        position:absolute;top:0;left:0;width:100%;height:100%;
        display:flex;align-items:center;justify-content:center;
        background:#f3f3f3;
        color:#777;
        font-size:14px;
      ">
        Add a video to get started
      </div>
    {% endif %}
  </div>

  {% if section.settings.description != blank %}
    <div style="
      margin-top: {{ section.settings.description_spacing }}px;
      color: {{ section.settings.description_color }};
      font-size: {{ section.settings.description_size }}px;
    ">
      {{ section.settings.description }}
    </div>
  {% endif %}

</div>

{% schema %}
{
  "name": "Video",
  "settings": [
    {
      "type": "header",
      "content": "Video source"
    },
    {
      "type": "select",
      "id": "video_source",
      "label": "Video source",
      "options": [
        { "value": "upload", "label": "Upload video" },
        { "value": "youtube", "label": "YouTube" }
      ],
      "default": "upload"
    },
    {
      "type": "video",
      "id": "video_file",
      "label": "Video file (MP4)"
    },
    {
      "type": "url",
      "id": "youtube_url",
      "label": "YouTube URL"
    },

    {
      "type": "checkbox",
      "id": "autoplay",
      "label": "Autoplay"
    },
    {
      "type": "checkbox",
      "id": "loop",
      "label": "Loop video"
    },
    {
      "type": "checkbox",
      "id": "muted",
      "label": "Mute video",
      "info": "Required for autoplay on most browsers"
    },

    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "label": "Heading"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },

    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "max_width",
      "min": 400,
      "max": 1600,
      "step": 100,
      "unit": "px",
      "label": "Max width",
      "default": 1200
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 14,
      "max": 60,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "range",
      "id": "heading_spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Heading spacing",
      "default": 20
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#525151"
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 16
    },
    {
      "type": "range",
      "id": "description_spacing",
      "min": 0,
      "max": 50,
      "step": 5,
      "unit": "px",
      "label": "Description spacing",
      "default": 20
    },

    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Top padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Bottom padding",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "label": "Horizontal padding",
      "default": 20
    }
  ],
  "presets": [
    { "name": "Video" }
  ]
}
{% endschema %}
