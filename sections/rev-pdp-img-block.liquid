<style>
#rev-img-blk.rev-img-blk-section {
  width: 100%;
}

#rev-img-blk .rev-img-blk-wrapper {
  width: 100%;
  display: flex;
  justify-content: space-between;
  gap: 30px;
}

#rev-img-blk .rev-img-blk-column {
  width: 40%; /* Each column takes up 48% of the width with some space in between */
  padding: 30px 0px; /* Adjust padding as needed */
}

#rev-img-blk .rev-img-blk-column img {
  width: 100%;
  height: auto;
  display: block;
}

/* Responsive Styles */
@media (max-width: 768px) {
  #rev-img-blk .rev-img-blk-column {
    width: 100%; /* Full width on mobile */
    margin-bottom: 20px;
  }
}
@media (max-width: 600px) {
  #rev-img-blk .rev-img-blk-wrapper {
    gap: 6px;
    flex-direction: column;
}
#rev-img-blk.rev-img-blk-section{
  background-color: {{ section.settings.sec_bg_color2 }} !important;
    background-image: linear-gradient(180deg, {{ section.settings.sec_bg_color }} 50%, transparent 50%) !important;
}
}
  </style>

<div id="rev-img-blk" class="rev-img-blk-section" style="background-color: {{ section.settings.sec_bg_color2 }};
    background-image: linear-gradient(90deg, {{ section.settings.sec_bg_color }} 50%, transparent 50%);">
  <div class="container">
    <div class="rev-img-blk-wrapper">
      {% for block in section.blocks %}
        <div class="rev-img-blk-column" >
          {% if block.settings.column_image %}
            <img src="{{ block.settings.column_image | img_url: '720x' }}" alt="Column Image" />
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "rev PDP image block",
  "settings": [
     {
          "type": "color",
          "id": "sec_bg_color",
          "label": "section Background Color 50%",
          "default": "#ffffff"
      },
     {
          "type": "color",
          "id": "sec_bg_color2",
          "label": "section Background Color 50% ",
          "default": "#ffffff"
      }
  ],
  "blocks": [
    {
      "type": "image",
      "name": "Column",
      "settings": [
        {
          "type": "image_picker",
          "id": "column_image",
          "label": "Column Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "rev PDP image block",
      "category": "Custom"
    }
  ]
}
{% endschema %}