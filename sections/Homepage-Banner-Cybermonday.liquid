<div class="Herobanner-container cyber_monday_banner">

    <div class="hero-content-bf cyber_moday_hero_content">
        <h1 class="hero-title" style="font-size: {{section.settings.heading_size}}">{{section.settings.heading}}</h1>
        <div class="bottom-container">
            
            <div class="sub-heding-contain">{{section.settings.subheading }}</div>
            <a href="{{section.settings.button_link}}" class="hero-button" style="background-color: {{section.settings.button_color}};">{{section.settings.button_text}}</a>
    
        </div>
    </div>
   
 
   

</div>

<style>
.cyber_monday_banner{
background-size: cover;
background-image: url("{{ section.settings.desktop_image | img_url: 'master' }}");
margin-top: 10.5vh;
background-position: center;
position: relative;
padding: 110px 120px;
}
.cyber_monday_banner .hero-title{
padding: 0;
line-height: 90px;
margin-bottom: 0;
color: #fff;

}
.cyber_monday_banner .hero-title span{
  font-size: 80px;
}
.cyber_monday_banner .hero-button{
  margin-left: 0
}
.cyber_monday_banner .sub-heding-contain{
  font-size: 40px;
  line-height: 70px;
  font-weight: 700;
}
.cyber_monday_banner{
  text-align: left;
  display: block !important;
  
}
.cyber_monday_banner .hero-button{
    margin-top: 20px;
    display: block;
    max-width: 277px;
    text-align: center;
}

@media screen and (max-width: 767px){
.cyber_monday_banner{
background-size: cover;
padding: 270px 0 !important;
background-image: url("{{ section.settings.mobile_image | img_url: 'master' }}") !important;
}
.cyber_monday_banner .hero-title span{
    font-size: 32px;
}
.cyber_monday_banner .sub-heding-contain{
    font-size: 24px;
    line-height: 30px;
    text-align: center;
}
.cyber_monday_banner .hero-button{
    padding: 5px 30px !important;
}

.cyber_monday_banner .hero-button{
    border-radius: 0;
    margin: 0 auto 0;
    text-align: center;
    max-width: 180px;
}

}

@media screen and (max-width: 999px) and (min-width: 767px){
    .cyber_monday_banner{
background-size: cover;
background-position: center;
    background-image: url("{{ section.settings.mobile_image | img_url: 'master' }}") !important;
    padding: 520px 0 !important;
}
.hero-content-bf .hero-title{
    margin: auto;
    text-align: center;
}
.cyber_monday_banner .hero-button{
    border-radius: 0;
    margin: 25px auto 0;
}
.cyber_monday_banner .sub-heding-contain{
    text-align: center;
    line-height: 25px !important;
}
.cyber_moday_hero_content{
    bottom: 50px !important;
}
}
.cyber_moday_hero_content{
  max-width: 700px;
}
.cyber_moday_hero_content .hero-title{
  line-height: 12vh;
}
.subheding_1{
  font-weight: 900;
  font-size: 54px;
}
.subheding_2{
  font-weight: 500;
  font-size:38px;
  margin-top: -5%
  
}

@media screen and (max-width: 1000px){
.hero-content-bf .hero-title{
font-size: 30px !important;
color: #FF6020;
text-align: center;
line-height:40px
}
.subheding_1{
font-weight: 900;
font-size: 26px;
}
.subheding_2{
  font-weight: 500;
  font-size:16px;  
}
.cyber_moday_hero_content{
position: absolute;
bottom: 0;
left: 50%;
transform: translateX(-50%);
width: 100%;
}
.cyber_monday_banner .bottom-container{
    padding-bottom: 10px !important;
}
.cyber_monday_banner{
padding: 270px 0;
}
}
</style>

{% schema %}
{
   "name": "Homepage Banner Cyber",
   "class": "home-page-cybermonday",
   "settings" : [
    {
        "type": "text",
        "id": "heading",
        "label": "Heading"
    },
    {
        "type": "select",
        "id": "heading_size",
        "label": "Heading Font Size",
        "options": [
            {
            "value": "5vw",
            "label": "5vw"
            },
            {
            "value": "5.5vw",
            "label": "5.5vw"
            },            
            {
            "value": "6vw",
            "label": "6vw"
            },
            {
            "value": "6.5vw",
            "label": "6.5vw"
            },            
            {
            "value": "7vw",
            "label": "7vw"
            },
            {
            "value": "7.5vw",
            "label": "7.5vw"
            },            
            {
            "value": "8vw",
            "label": "8vw"
            },
            {
            "value": "8.5vw",
            "label": "8.5vw"
            },            
            {
            "value": "9vw",
            "label": "9vw"
            },
            {
            "value": "9.5vw",
            "label": "9.5vw"
            },            
            {
            "value": "10vw",
            "label": "10vw"
            }                          
        ],
        "default": "6vw"

    },
    {
        "type": "text",
        "id": "subheading",
        "label": "Sub Heading"
    },
    {
        "type": "url",
        "id": "button_link",
        "label": "Button Link"
    },
    {
        "type": "text",
        "id": "button_text",
        "label": "Button Text"
    },
    {
        "type": "color",
        "id": "button_color",
        "label": "Button Color",
        "default": "#df477f"
    },
    {
        "type": "header",
        "content": "Homepage Banner Images"
    },
    {
        "type": "image_picker",
        "id": "desktop_image",
        "label": "Desktop Image"
    },
    {
        "type": "image_picker",
        "id": "mobile_image",
        "label": "Mobile Image"
    },
    {
        "type": "select",
        "id": "height_selector",
        "label": "Mobile Image Height",
        "options": [
          {
            "value": "small",
            "label": "Small 612px"
          },
          {
            "value": "large",
            "label": "Large 812px"
          }
        ]
    }
   ],
   "presets": [
    {
        "name": "Homepage Banner BF"
    }
   ]
}
{% endschema %}