<div class="banner_main" id="banner_main_{{ section.id }}">
 <div class="banner-container">
   <div class="banner-register-content-with-form">
    <div class="banner_inner">
      <div class="banner-content-inner">
        <div class="banner_content">
            {% if section.settings.icon_image != blank %}
              <div class="banner_icon_image" onclick="window.location.href = '/'">
              {{ section.settings.icon_image | image_url: width: section.settings.icon_image.width | image_tag: loading: 'lazy' }}
              </div>
            {% endif %}
            {% if section.settings.sub_headline != blank %}
              <h3>{{ section.settings.sub_headline }}</h3>
            {% endif %}
            {% if section.settings.headline != blank %}
              <h2>{{ section.settings.headline }}</h2>
            {% endif %}
             {% if section.settings.image != blank %}
               <div class="banner_image_mobile">
                 {{ section.settings.image | image_url: width: section.settings.image.width | image_tag: loading: 'lazy' }}
               </div>
             {% endif %}
            {% if section.settings.text != blank %}
              <span>{{ section.settings.text }}</span>
            {% endif %}
            {% if section.settings.btn_text != blank %}
              <a class="primary_btn" href="{{ section.settings.btn_link }}">{{ section.settings.btn_text }}</a>
            {% endif %}
        </div>
        <div class="banner_image">
          {% if section.settings.image != blank %}
            {{ section.settings.image | image_url: width: section.settings.image.width | image_tag: loading: 'lazy' }}
          {% endif %}
        </div>
      </div>
    </div>
    <div class="banner-register--form">
      <div class="banner-register-form-inner">
        <div class="text--center">
          <h2>Free Samples & CE Registration</h2>
          <p>If you are already a wholesale customer, <a href="/account/login">log in to your account
          </a></p>
        </div> 
        <!-- <div class="globo-formbuilder" data-id="=="></div>     -->
        <div class="globo-formbuilder" data-id="Njg2MTk"></div>
      </div>
   </div>
   </div>
 </div> 
</div>


{% schema %}
  {
    "name": "MM Banner",
    "settings": [
      {
        "type":"color",
        "id":"bg_color",
        "label":"Background Color",
        "default":"#E6F5F7"
      },
      {
        "type":"image_picker",
        "id":"icon_image",
        "label":"Icon Image"
      },
      {
        "type":"image_picker",
        "id":"image",
        "label":"Image"
      },
      {
        "type": "text",
        "id": "sub_headline",
        "label": "Sub Headline",
        "default": "BACKED BY OVER 25 YEARS OF DENTAL EXPERIENCE"
      },
      {
        "type": "text",
        "id": "headline",
        "label": "Headline",
        "default": "The Next Generation of Preventive Oral Care Products"
      },
      {
        "type": "richtext",
        "id": "text",
        "label": "Text",
        "default": "<p>with both 10% nHAp and fluoirde</p>"
      },
      {
        "type": "text",
        "id": "btn_text",
        "label": "Button Text",
        "default": "Shop Now"
      },
      {
        "type": "url",
        "id": "btn_link",
        "label": "Button Link"
      }
    ],
    "presets":[
      {
        "name":"MM Banner"
      }
    ]
  }
{% endschema %}

