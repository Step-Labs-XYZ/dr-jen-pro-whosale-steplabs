<div
  class="cdp-lightbox-{{ section.id }}"
  id="cdp-lightbox-{{ section.id }}"
  role="dialog"
  aria-modal="true"
  aria-label="Video"
>
  <div class="cdp-lightbox-{{ section.id }}__inner">
    <button class="cdp-lightbox-{{ section.id }}__close" aria-label="Cerrar video">
      <svg width="14" height="14" viewBox="0 0 14 14" fill="none" xmlns="http://www.w3.org/2000/svg">
        <path d="M1 1L13 13M13 1L1 13" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
      </svg>
    </button>
    <div class="cdp-lightbox-{{ section.id }}__ratio">
      <iframe
        class="cdp-lightbox-{{ section.id }}__iframe"
        allow="autoplay; fullscreen"
        allowfullscreen
        title="Video"
      ></iframe>
      <video
        class="cdp-lightbox-{{ section.id }}__video"
        playsinline
        controls
        style="display:none"
      ></video>
    </div>
  </div>
</div>

<script>
(function () {
  var sect = document.getElementById('c-dental-pros-{{ section.id }}');
  if (!sect) return;

  /* ── VIDEO LIGHTBOX ── */
  function getEmbedUrl(url) {
    var yt = url.match(/(?:youtube\.com\/watch\?v=|youtu\.be\/)([A-Za-z0-9_-]{11})/);
    if (yt) return 'https://www.youtube.com/embed/' + yt[1] + '?autoplay=1&rel=0&playsinline=1';
    var vi = url.match(/vimeo\.com\/(\d+)/);
    if (vi) return 'https://player.vimeo.com/video/' + vi[1] + '?autoplay=1&autopause=0';
    return url;
  }

  var lightbox = document.getElementById('cdp-lightbox-{{ section.id }}');
  var lbIframe  = lightbox.querySelector('.cdp-lightbox-{{ section.id }}__iframe');
  var lbVideo   = lightbox.querySelector('.cdp-lightbox-{{ section.id }}__video');
  var lbClose   = lightbox.querySelector('.cdp-lightbox-{{ section.id }}__close');

  function closeLightbox() {
    lightbox.classList.remove('is-open');
    lbIframe.src = '';
    lbVideo.pause();
    lbVideo.removeAttribute('src');
    lbVideo.innerHTML = '';
    lbVideo.style.display = 'none';
    lbIframe.style.display = '';
    document.body.style.overflow = '';
  }

  lbClose.addEventListener('click', closeLightbox);

  lightbox.addEventListener('click', function (e) {
    if (e.target === lightbox) closeLightbox();
  });

  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && lightbox.classList.contains('is-open')) closeLightbox();
  });

  sect.querySelectorAll('.c-dental-pros__video-wrap[data-video-type], .c-dental-pros__photo-wrap[data-video-type]').forEach(function (wrap) {
    wrap.addEventListener('click', function () {
      if (wrap.dataset.videoType === 'url') {
        lbIframe.style.display = '';
        lbVideo.style.display = 'none';
        lbIframe.src = getEmbedUrl(wrap.dataset.video);
      } else if (wrap.dataset.videoType === 'shopify') {
        var nv = wrap.querySelector('.c-dental-pros__native-video');
        if (nv) {
          lbIframe.style.display = 'none';
          lbVideo.style.display = '';
          lbVideo.innerHTML = nv.innerHTML;
          lbVideo.load();
          lbVideo.play().catch(function () {});
        }
      }
      lightbox.classList.add('is-open');
      document.body.style.overflow = 'hidden';
      lbClose.focus();
    });
  });

  /* ── IGUALAR ALTURAS ── */
  function equalizeHeights() {
    var isDesktop = window.innerWidth >= 768;

    /* 1. Reset */
    var slides = sect.querySelectorAll('.c-dental-pros__slide');
    slides.forEach(function (s) { s.style.height = ''; });
    var allImgWraps = sect.querySelectorAll('.c-dental-pros__photo-wrap, .c-dental-pros__video-wrap');
    allImgWraps.forEach(function (w) { w.style.height = ''; });

    /* 2. Igualar áreas de imagen/video
          Desktop: excluye slide--video .video-wrap (se estira al alto del slide via flex stretch) */
    var wrapsToEq = isDesktop
      ? sect.querySelectorAll(
          '.c-dental-pros__photo-wrap, .c-dental-pros__slide--quote .c-dental-pros__video-wrap'
        )
      : allImgWraps;

    var maxImgH = 0;
    wrapsToEq.forEach(function (w) { maxImgH = Math.max(maxImgH, w.offsetHeight); });
    if (maxImgH > 0) wrapsToEq.forEach(function (w) { w.style.height = maxImgH + 'px'; });

    /* 3. Igualar altura total de slides (ya con imágenes equalizadas) */
    var maxH = 0;
    slides.forEach(function (s) { maxH = Math.max(maxH, s.offsetHeight); });
    if (maxH > 0) slides.forEach(function (s) { s.style.height = maxH + 'px'; });
  }

  function onReady() {
    equalizeHeights();
    var timer;
    window.addEventListener('resize', function () {
      clearTimeout(timer);
      timer = setTimeout(equalizeHeights, 120);
    });
  }

  /* Espera a Flickity */
  var slider = sect.querySelector('.c-dental-pros__slider');
  if (slider && window.Flickity) {
    var flkty = Flickity.data(slider);
    if (flkty) {
      flkty.on('ready', onReady);
    } else {
      slider.addEventListener('ready.flickity', onReady);
      setTimeout(onReady, 600);
    }
  } else {
    setTimeout(onReady, 800);
  }
})();
</script>

