{%- style -%}
  @import url('https://fonts.googleapis.com/css2?family=Raleway:ital,wght@0,400;0,500;0,600;0,700;0,800;1,400;1,600&display=swap');

  /* =============================================
     C-DENTAL-PROFESSIONALS
     sl-section-dental-professionals-v1
     =============================================
     Tipos de bloque:
       photo_text  → imagen circular flotando sobre tarjeta blancaa
       video_image → imagen/video full que llena toda la tarjeta
       quote_text  → tarjeta blanca solo con cita + nombre al fondo
     ============================================= */

  #c-dental-pros-{{ section.id }} {
    --cdp-bg:              {{ section.settings.bg_color }};
    --cdp-eyebrow-color:   {{ section.settings.eyebrow_color }};
    --cdp-heading-color:   {{ section.settings.heading_color }};
    --cdp-card-bg:         {{ section.settings.card_bg }};
    --cdp-name-color:      {{ section.settings.name_color }};
    --cdp-quote-color:     {{ section.settings.quote_color }};
    --cdp-dot-active:      {{ section.settings.dot_active_color }};
    --cdp-dot-inactive:    {{ section.settings.dot_inactive_color }};
    --cdp-play-bg:         {{ section.settings.play_btn_bg }};
    --cdp-play-icon:       {{ section.settings.play_btn_icon_color }};
    --cdp-radius-mob:      {{ section.settings.card_radius_mob }}px;
    --cdp-radius-desk:     {{ section.settings.card_radius_desk }}px;
    --cdp-eyebrow-align:   {{ section.settings.eyebrow_align }};
    --cdp-heading-align:   {{ section.settings.heading_align }};
    --cdp-name-weight:     {{ section.settings.name_font_weight }};
    --cdp-name-transform:  {{ section.settings.name_text_transform }};
    --cdp-name-ls:         {{ section.settings.name_letter_spacing | divided_by: 100.0 }}em;
    --cdp-name-lh:         {{ section.settings.name_line_height | divided_by: 10.0 }};
    --cdp-quote-weight:    {{ section.settings.quote_font_weight }};
    --cdp-quote-lh:        {{ section.settings.quote_line_height | divided_by: 10.0 }};

    font-family: 'Raleway', sans-serif !important;
    background-color: var(--cdp-bg);
    padding-top: {{ section.settings.pad_top_mob }}px;
    padding-bottom: {{ section.settings.pad_bot_mob }}px;
  }

  /* ---- CONTAINER ---- */
  #c-dental-pros-{{ section.id }} .c-dental-pros__container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 20px;
  }

  /* ---- HEADER ---- */
  #c-dental-pros-{{ section.id }} .c-dental-pros__header {
    margin-bottom: {{ section.settings.header_mb_mob }}px;
  }

  #c-dental-pros-{{ section.id }} .c-dental-pros__eyebrow {
    display: block;
    font-family: 'Playfair Display', Georgia, serif !important;
    font-size: {{ section.settings.eyebrow_size_mob }}px;
    font-style: italic;
    font-weight: 400;
    color: var(--cdp-eyebrow-color);
    margin: 0 0 8px 0;
    line-height: 1.3;
    text-align: var(--cdp-eyebrow-align);
  }

  #c-dental-pros-{{ section.id }} .c-dental-pros__heading {
    font-family: 'Raleway', sans-serif !important;
    font-size: {{ section.settings.heading_size_mob }}px;
    font-weight: 600;
    color: var(--cdp-heading-color);
    margin: 0;
    line-height: 1.2;
    letter-spacing: -0.01em;
    text-align: var(--cdp-heading-align);
  }

  /* ---- SLIDER ---- */
  #c-dental-pros-{{ section.id }} .c-dental-pros__slider-clip {
    overflow: hidden;
  }

  #c-dental-pros-{{ section.id }} .c-dental-pros__slider {
    outline: none;
  }

  #c-dental-pros-{{ section.id }} .c-dental-pros__slider.flickity-enabled {
    overflow: visible;
  }

  /* ---- SLIDE BASE ---- */
  #c-dental-pros-{{ section.id }} .c-dental-pros__slide {
    width: calc(82% - 16px);
    margin: 0 8px 20px 8px;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    box-sizing: border-box;
  }

  /* ==============================================
     TIPO 1 — FOTO CIRCULAR + TARJETA TEXTO
     ============================================== */

  /* TIPO 1: tarjeta unificada en mobile — oval sin fondo + texto con fondo separado */
  #c-dental-pros-{{ section.id }} .c-dental-pros__slide--photo {
    background: transparent;
    border-radius: 0;
    overflow: visible;
    align-items: stretch;
    gap: 30px;
  }

  /* Contenedor imagen — ovalado en mobile también */
  #c-dental-pros-{{ section.id }} .c-dental-pros__photo-wrap {
    width: 100%;
    height: var(--cdp-ph-h-mob, 200px);
    border-radius: 100px;
    overflow: hidden;
    position: relative;
    flex-shrink: 0;
  }

  /* Imagen dentro del oval */
  #c-dental-pros-{{ section.id }} .c-dental-pros__photo {
    position: absolute;
    inset: 0;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover;
    object-position: center top;
    display: block;
  }

  /* Tarjeta texto — CON fondo propio en mobile */
  #c-dental-pros-{{ section.id }} .c-dental-pros__photo-card {
    background-color: var(--cdp-card-bg);
    border-radius: var(--cdp-radius-mob);
    padding: 24px;
    box-sizing: border-box;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    gap: 12px;
    flex: 1;
  }

  /* ==============================================
     TIPO 2 — IMAGEN / VIDEO + TEXTO (lado a lado)
     MOBILE: igual que photo_text → oval sin fondo + tarjeta con fondo + gap 30px
     ============================================== */

  #c-dental-pros-{{ section.id }} .c-dental-pros__slide--video {
    background: transparent;
    border-radius: 0;
    overflow: visible;
    flex-direction: column;
    gap: 30px;
  }

  /* Panel imagen/video — full-width en mobile con bordes ovalados */
  #c-dental-pros-{{ section.id }} .c-dental-pros__video-wrap {
    position: relative;
    width: 100%;
    flex-shrink: 0;
    padding-bottom: 0;
    min-height: var(--cdp-vw-h-mob, 220px);
    overflow: hidden;
    cursor: pointer;
    background: #1a3446;
    border-radius: 100px;
  }

  /* Poster image */
  #c-dental-pros-{{ section.id }} .c-dental-pros__poster {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: opacity 0.3s ease;
  }

  /* ── POSTER / PHOTO RESPONSIVE: móvil vs escritorio ── */
  #c-dental-pros-{{ section.id }} .c-dental-pros__poster--mob,
  #c-dental-pros-{{ section.id }} .c-dental-pros__photo--mob {
    display: block;
  }

  #c-dental-pros-{{ section.id }} .c-dental-pros__poster--desk,
  #c-dental-pros-{{ section.id }} .c-dental-pros__photo--desk {
    display: none;
  }

  /* Iframe YouTube/Vimeo */
  #c-dental-pros-{{ section.id }} .c-dental-pros__iframe {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
    display: none;
  }

  /* Video nativo Shopify */
  #c-dental-pros-{{ section.id }} .c-dental-pros__native-video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    border: none;
    display: none;
    background: #000;
  }

  /* Estado reproduciendo */
  #c-dental-pros-{{ section.id }} .c-dental-pros__video-wrap.is-playing .c-dental-pros__poster,
  #c-dental-pros-{{ section.id }} .c-dental-pros__video-wrap.is-playing .c-dental-pros__play-btn {
    opacity: 0;
    pointer-events: none;
  }

  #c-dental-pros-{{ section.id }} .c-dental-pros__video-wrap.is-playing .c-dental-pros__iframe,
  #c-dental-pros-{{ section.id }} .c-dental-pros__video-wrap.is-playing .c-dental-pros__native-video {
    display: block;
  }

  /* Estado reproduciendo — photo-wrap con video */
  #c-dental-pros-{{ section.id }} .c-dental-pros__photo-wrap[data-video-type] {
    cursor: pointer;
  }

  #c-dental-pros-{{ section.id }} .c-dental-pros__photo-wrap.is-playing .c-dental-pros__photo,
  #c-dental-pros-{{ section.id }} .c-dental-pros__photo-wrap.is-playing .c-dental-pros__play-btn {
    opacity: 0;
    pointer-events: none;
  }

  #c-dental-pros-{{ section.id }} .c-dental-pros__photo-wrap.is-playing .c-dental-pros__iframe,
  #c-dental-pros-{{ section.id }} .c-dental-pros__photo-wrap.is-playing .c-dental-pros__native-video {
    display: block;
  }

  /* Placeholder sin imagen */
  #c-dental-pros-{{ section.id }} .c-dental-pros__poster-placeholder {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #1a3446 0%, #2a4d60 100%);
    color: rgba(255,255,255,0.3);
    font-family: 'Raleway', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-align: center;
    padding: 20px;
  }

  /* Placeholder secundario para mobile */
  #c-dental-pros-{{ section.id }} .c-dental-pros__poster-placeholder::before {
    content: '';
    position: absolute;
    inset: 0;
    background-image: 
      radial-gradient(circle at 20% 30%, rgba(255,255,255,0.05) 1px, transparent 1px);
    background-size: 40px 40px;
    background-position: 0 0;
    pointer-events: none;
  }

  /* Botón play */
  #c-dental-pros-{{ section.id }} .c-dental-pros__play-btn {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width:  {{ section.settings.play_btn_size_mob }}px;
    height: {{ section.settings.play_btn_size_mob }}px;
    border-radius: 50%;
    background: var(--cdp-play-bg);
    display: flex;
    align-items: center;
    justify-content: center;
    transition: opacity 0.3s ease, transform 0.2s ease;
    pointer-events: none;
    z-index: 2;
  }

  #c-dental-pros-{{ section.id }} .c-dental-pros__video-wrap:hover .c-dental-pros__play-btn {
    transform: translate(-50%, -50%) scale(1.08);
  }

  #c-dental-pros-{{ section.id }} .c-dental-pros__play-btn svg {
    width: 40%;
    height: 40%;
    fill: var(--cdp-play-icon);
    margin-left: 4px;
  }

  /* Panel de texto (tipo 2) — CON fondo y radio propios en mobile */
  #c-dental-pros-{{ section.id }} .c-dental-pros__video-text {
    flex: 1;
    background-color: var(--cdp-card-bg);
    border-radius: var(--cdp-radius-mob);
    padding: 32px;
    box-sizing: border-box;
    display: flex;
    gap: 20px;
    flex-direction: column;
    justify-content: center;
  }

  /* ==============================================
     TIPO 3 — SOLO CITA (TEXTO)
     ============================================== */

  #c-dental-pros-{{ section.id }} .c-dental-pros__slide--quote {
    border-radius: var(--cdp-radius-mob);
    overflow: hidden;
    background-color: var(--cdp-card-bg);
    gap: 16px;
  }

  #c-dental-pros-{{ section.id }} .c-dental-pros__quote-card {
    padding: 32px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    height: 100%;
    box-sizing: border-box;
    flex: 1;
  }

  /* ---- TEXTOS COMUNES ---- */
  #c-dental-pros-{{ section.id }} .c-dental-pros__name {
    font-family: 'Raleway', sans-serif !important;
    font-size: {{ section.settings.name_size_mob }}px;
    font-weight: var(--cdp-name-weight);
    color: var(--cdp-name-color);
    text-transform: var(--cdp-name-transform);
    letter-spacing: var(--cdp-name-ls);
    margin: 0;
    line-height: var(--cdp-name-lh);
  }

  #c-dental-pros-{{ section.id }} .c-dental-pros__quote {
    font-family: 'Raleway', sans-serif !important;
    font-size: {{ section.settings.quote_size_mob }}px;
    font-weight: var(--cdp-quote-weight);
    color: var(--cdp-quote-color);
    margin: 0;
    line-height: var(--cdp-quote-lh);
  }

  /* ---- FLICKITY DOTS ---- */
  #c-dental-pros-{{ section.id }} .flickity-page-dots {
    position: relative;
    bottom: auto;
    text-align: center;
    margin-top: 20px;
  }

  #c-dental-pros-{{ section.id }} .flickity-page-dots .dot {
    width: 24px;
    height: 4px;
    border-radius: 2px;
    background: var(--cdp-dot-inactive);
    opacity: 1;
    margin: 0 3px;
    transition: background 0.3s ease, width 0.3s ease;
  }

  #c-dental-pros-{{ section.id }} .flickity-page-dots .dot.is-selected {
    background: var(--cdp-dot-active);
    width: 36px;
  }

  #c-dental-pros-{{ section.id }} .flickity-prev-next-button {
    display: none;
  }

  /* =============================================
     DESKTOP — 768px+
     ============================================= */
  @media (min-width: 768px) {
    #c-dental-pros-{{ section.id }} {
      padding-top:    {{ section.settings.pad_top_desk }}px;
      padding-bottom: {{ section.settings.pad_bot_desk }}px;
    }

    #c-dental-pros-{{ section.id }} .c-dental-pros__container {
      padding: 0 48px;
    }

    #c-dental-pros-{{ section.id }} .c-dental-pros__header {
      margin-bottom: {{ section.settings.header_mb_desk }}px;
    }

    #c-dental-pros-{{ section.id }} .c-dental-pros__eyebrow {
      font-size: {{ section.settings.eyebrow_size_desk }}px;
    }

    #c-dental-pros-{{ section.id }} .c-dental-pros__heading {
      font-size: {{ section.settings.heading_size_desk }}px;
    }

    /* peek carousel — video=50vw, foto/cita=25vw
       Los slides miden contra el viewport; el container tiene padding
       propio → card 3 arranca antes del borde derecho y queda cortado */
    #c-dental-pros-{{ section.id }} .c-dental-pros__slide {
      width: calc(25vw - 20px);
      margin: 0 10px 24px 10px;
    }

    #c-dental-pros-{{ section.id }} .c-dental-pros__slide--video {
      width: calc(50vw - 20px);
    }

    /* Tipo 1 desktop — restaurar dos piezas (oval + tarjeta gris separada) */
    #c-dental-pros-{{ section.id }} .c-dental-pros__slide--photo {
      background: transparent;
      border-radius: 0;
      overflow: visible;
      gap: var(--cdp-ph-gap-desk, 0px);
    }

    #c-dental-pros-{{ section.id }} .c-dental-pros__photo-wrap {
      border-radius: 200px;  /* pill oval solo en desktop */
      height: var(--cdp-ph-h-desk, 220px);
    }

    #c-dental-pros-{{ section.id }} .c-dental-pros__photo-card {
      background-color: var(--cdp-card-bg);
      border-radius: var(--cdp-radius-desk);
      padding: 32px;
      gap: 12px;
    }

    /* Tipo 2 desktop — imagen izquierda, texto derecha */
    #c-dental-pros-{{ section.id }} .c-dental-pros__slide--video {
      border-radius: var(--cdp-radius-desk);
      flex-direction: row;
      gap: var(--cdp-vi-gap-desk, 0px);
      background-color: transparent;
      overflow: visible;
    }

    #c-dental-pros-{{ section.id }} .c-dental-pros__slide--video .c-dental-pros__video-wrap {
      width: {{ section.settings.video_panel_width_desk }}%;
      min-height: var(--cdp-vw-h-desk, 300px);
      border-radius: var(--cdp-radius-desk);
    }

    #c-dental-pros-{{ section.id }} .c-dental-pros__video-text {
      border-radius: 8px;
    }

    #c-dental-pros-{{ section.id }} .c-dental-pros__play-btn {
      width:  {{ section.settings.play_btn_size_desk }}px;
      height: {{ section.settings.play_btn_size_desk }}px;
    }

    /* Tipo 3 desktop */
    #c-dental-pros-{{ section.id }} .c-dental-pros__slide--quote {
      border-radius: var(--cdp-radius-desk);
    }

    #c-dental-pros-{{ section.id }} .c-dental-pros__quote-card {
      padding: 32px;
    }

    /* Textos */
    #c-dental-pros-{{ section.id }} .c-dental-pros__name {
      font-size: {{ section.settings.name_size_desk }}px;
    }

    #c-dental-pros-{{ section.id }} .c-dental-pros__quote {
      font-size: {{ section.settings.quote_size_desk }}px;
    }

    #c-dental-pros-{{ section.id }} .flickity-page-dots {
      text-align: right;
    }

    /* Poster / photo responsive: en desktop mostrar --desk, ocultar --mob */
    #c-dental-pros-{{ section.id }} .c-dental-pros__poster--mob,
    #c-dental-pros-{{ section.id }} .c-dental-pros__photo--mob {
      display: none;
    }

    #c-dental-pros-{{ section.id }} .c-dental-pros__poster--desk,
    #c-dental-pros-{{ section.id }} .c-dental-pros__photo--desk {
      display: block;
    }
  }

  @media (min-width: 1200px) {
    #c-dental-pros-{{ section.id }} .c-dental-pros__container {
      padding: 0 60px;
    }
  }

  /* ── VIDEO LIGHTBOX ── */
  .cdp-lightbox-{{ section.id }} {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 9999;
    background: rgba(0, 0, 0, 0.88);
    align-items: center;
    justify-content: center;
    padding: 16px;
    box-sizing: border-box;
  }

  .cdp-lightbox-{{ section.id }}.is-open {
    display: flex;
  }

  .cdp-lightbox-{{ section.id }}__inner {
    position: relative;
    width: 100%;
    max-width: 960px;
  }

  .cdp-lightbox-{{ section.id }}__ratio {
    position: relative;
    padding-bottom: 56.25%;
    height: 0;
    background: #000;
    border-radius: 8px;
    overflow: hidden;
  }

  .cdp-lightbox-{{ section.id }}__ratio iframe,
  .cdp-lightbox-{{ section.id }}__ratio video {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    border: none;
  }

  .cdp-lightbox-{{ section.id }}__close {
    position: absolute;
    top: -48px;
    right: 0;
    width: 36px;
    height: 36px;
    background: rgba(255, 255, 255, 0.15);
    border: 1.5px solid rgba(255, 255, 255, 0.35);
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #fff;
    padding: 0;
    transition: background 0.2s ease;
  }

  .cdp-lightbox-{{ section.id }}__close:hover {
    background: rgba(255, 255, 255, 0.3);
  }
{%- endstyle -%}

<section
  id="c-dental-pros-{{ section.id }}"
  class="c-dental-pros"
  data-sl-id="sl-section-dental-professionals-v1"
>
  <div class="c-dental-pros__container">

    {%- comment -%} ── HEADER ── {%- endcomment -%}
    <div class="c-dental-pros__header">
      {%- if section.settings.eyebrow != blank -%}
        <span class="c-dental-pros__eyebrow">{{ section.settings.eyebrow }}</span>
      {%- endif -%}
      {%- if section.settings.heading != blank -%}
        <h2 class="c-dental-pros__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    {%- comment -%} ── SLIDER ── {%- endcomment -%}
    <div class="c-dental-pros__slider-clip">
      <div
        class="c-dental-pros__slider"
        data-flickity='{
          "wrapAround": true,
          "imagesLoaded": true,
          "contain": false,
          "cellAlign": "left",
          "pageDots": true,
          "prevNextButtons": false,
          "draggable": true,
          "adaptiveHeight": false
        }'
      >

        {%- for block in section.blocks -%}

          {%- comment -%} ━━ TIPO 1: FOTO CIRCULAR + TEXTO ━━ {%- endcomment -%}
          {%- if block.type == 'photo_text' -%}
            {%- assign pt_has_shopify_video = false -%}
            {%- assign pt_has_url_video     = false -%}
            {%- assign pt_has_any_video     = false -%}
            {%- if block.settings.shopify_video != blank -%}
              {%- assign pt_has_shopify_video = true -%}
              {%- assign pt_has_any_video     = true -%}
            {%- endif -%}
            {%- if block.settings.video_url != blank and pt_has_shopify_video == false -%}
              {%- assign pt_has_url_video = true -%}
              {%- assign pt_has_any_video = true -%}
            {%- endif -%}

            <div class="c-dental-pros__slide c-dental-pros__slide--photo" style="--cdp-ph-gap: {{ block.settings.gap_mob }}px; --cdp-ph-gap-desk: {{ block.settings.gap_desk }}px" {{ block.shopify_attributes }}>

              <div class="c-dental-pros__photo-wrap"
                style="--cdp-ph-h-mob: {{ block.settings.img_height_mob }}px; --cdp-ph-h-desk: {{ block.settings.img_height_desk }}px"
                {%- if pt_has_url_video -%}
                  data-video="{{ block.settings.video_url | escape }}"
                  data-video-type="url"
                {%- elsif pt_has_shopify_video -%}
                  data-video-type="shopify"
                {%- endif -%}
              >
                {%- if block.settings.image_mob != blank -%}
                  {{
                    block.settings.image_mob
                    | image_url: width: 400
                    | image_tag:
                      class: 'c-dental-pros__photo c-dental-pros__photo--mob',
                      alt: block.settings.name,
                      loading: 'lazy',
                      widths: '200, 300, 400'
                  }}
                {%- endif -%}
                {%- if block.settings.image != blank -%}
                  {%- if block.settings.image_mob != blank -%}
                    {%- assign pt_desk_img_class = 'c-dental-pros__photo c-dental-pros__photo--desk' -%}
                  {%- else -%}
                    {%- assign pt_desk_img_class = 'c-dental-pros__photo' -%}
                  {%- endif -%}
                  {{
                    block.settings.image
                    | image_url: width: 400
                    | image_tag:
                      class: pt_desk_img_class,
                      alt: block.settings.name,
                      loading: 'lazy',
