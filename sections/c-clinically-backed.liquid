    {
      "type": "header",
      "content": "Estadística 2"
    },
    {
      "type": "text",
      "id": "stat2_label",
      "label": "Super-título (Encima de la línea)",
      "default": "FULL FORMULA STRENGTH"
    },
    {
      "type": "text",
      "id": "stat2_value",
      "label": "Valor Principal (Número grande)",
      "default": "free"
    },
    {
      "type": "text",
      "id": "stat2_desc",
      "label": "Descripción Inferior",
      "default": "from harsh chemicals"
    },
    {
      "type": "header",
      "content": "Bloque Detalle Inferior"
    },
    {
      "type": "text",
