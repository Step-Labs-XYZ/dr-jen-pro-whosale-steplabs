  endcapture
-%}

{% style %}
  .ss-custom-section__inner {
    width: 100%;
    display: flex;
    flex-direction: var(--ss-style-panel-flex-direction, row);
    flex-wrap: var(--ss-style-panel-flex-wrap, nowrap);
    align-items: var(--ss-style-panel-align-items, stretch);
    justify-content: var(--ss-style-panel-justify-content, flex-start);
  }
  .ss-custom-section__inner--boxed {
    max-width: var(--ss-page-width, 1200px);
    margin-left: auto;
    margin-right: auto;
  }
{% endstyle %}

<div
  class='
    ss-section
    ss-background-image-panel
    {{ section.settings.class_list }}
    {{ section.settings | class_list }}
    ss-color-{{ section.settings.color_scheme }}
    sm:ss-color-{{ section.settings.color_scheme_mobile }}
  '
  style='{{ style_background_image_vars }}'
>
  {% comment %}
    TODO: Jeshua we need to now check media type, and accept either an image or a video
    - add video to background schema file
    - add video snippet copying how we do it for the video block
  {% endcomment %}
  {% render 'ss-background-media-v-2-0', settings: section.settings %}

  <div
    class='
      ss-size-panel
      ss-spacing-panel
      ss-section-content-wrapper{% if section.settings.section_width == 'page-width' %} ss-section-content-wrapper--boxed{% endif %}
      ss-layout-panel
      ss-position-panel
      ss-custom-section__inner{% if section.settings.section_width == 'page-width' %} ss-custom-section__inner--boxed{% endif %}
    '
    style='{{ style_panel_vars }}'
  >
    {% content_for 'blocks' %}
  </div>
</div>

