		{% capture start %}{{ '20-12-2022 10:00' | date: "%s" }}{% endcapture%}
		{% capture finish %}{{ '03-01-2023 23:59' | date: "%s" }}{% endcapture%}

		{% assign actual = actual | plus: 0 %}
		{% assign start = start | plus: 0 %}
		{% assign finish = finish | plus: 0 %}

		
		{% if actual > start and finish > actual %}
			<style>
        .home-page-banner-original{
          display: none;
        }
      </style>
           
		{% else %}

    <style>
