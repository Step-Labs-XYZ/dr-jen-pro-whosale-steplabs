{% stylesheet %}
  .swiper-pagination-bullet-active {
    scale: var(--active-pagination-size);
  }
{% endstylesheet %}

<div
  class='
    ss-visibility-{{ block.settings.ss-visibility }}
    {{ block.settings.class_list }}
     swiper-pagination
  '
  style='
    --swiper-pagination-bullet-width: {{ block.settings.bullet_width }}px;
    --swiper-pagination-bullet-height: {{ block.settings.bullet_height }}px;
    --swiper-pagination-bullet-border-radius: {{ block.settings.bullet_border_radius }}%;
    --swiper-pagination-bullet-inactive-color: {{ block.settings.bullet_inactive_color }};
    --swiper-pagination-bullet-inactive-opacity: {{ block.settings.bullet_inactive_opacity }};
    --swiper-pagination-color: {{ block.settings.bullet_color }};
    --active-pagination-size: {{ block.settings.active_pagination_size }};
    {% if block.settings.clickable == false %}
        pointer-events: none;
    {% endif %}
  '
  {{ block.shopify_attributes }}
></div>

