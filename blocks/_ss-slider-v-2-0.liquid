{% comment %} This file is auto-generated. Do not edit this file. {% endcomment %}
<style>
  .swiper {
    position: static;
  }
  .swiper * {
    z-index: 1;
  }
</style>
<link
  rel='stylesheet'
  href='https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css'
>

<script id='ss-swiper-cdn' src='https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js'></script>

{%- liquid
  capture style_panel_vars
    render 'ss-style-panel-v-2-0', settings: block.settings, type: 'spacing,size'
  endcapture
-%}

<!-- Slider main container -->
<div
  class='
    swiper
    {{ block.settings.class_list }}
    ss-block
    ss-slider
    ss-size-panel
    ss-spacing-panel
  '
  style='{{ style_panel_vars }}'
  {{ block.shopify_attributes }}
  data-name='{{ block.type }}, {{ block.name }}'
  id='ss-slider-{{ block.id }}'
>
  {% content_for 'block', type: '_ss-swiper-pagination-v-2-0', id: 'swiper-pagination' %}
  {% content_for 'block', type: '_ss-swiper-navigation-v-2-0', id: 'swiper-navigation' %}

  <div class='swiper-wrapper'>
    <!-- Slides -->
    {% content_for 'blocks' %}
  </div>
</div>

<script>
  function initSlider() {
      const swiper = new Swiper('#ss-slider-{{ block.id }}', {
          direction: 'horizontal',
          // Optional parameters
          loop: {{ block.settings.loop }},
          autoplay: {
              delay: {{ block.settings.autoplay_speed }} * 1000,
              pauseOnMouseEnter: {{ block.settings.autoplay_pause_on_hover }},
          },
          // If we need pagination
          pagination: {
              el: '.swiper-pagination',
              clickable: true,
          },

          // Navigation arrows
          navigation: {
              nextEl: '.swiper-button-next',
              prevEl: '.swiper-button-prev',
          },

          // And if we need scrollbar
          scrollbar: {
              el: '.swiper-scrollbar',
          },
          slidesPerView: {{ block.settings.slides_per_view_mobile }},
          spaceBetween: 30,
          breakpoints: {
              750: {
                  slidesPerView: {{ block.settings.slides_per_view }},
              },
          },
          on: {
              init: function() {
                  console.log('Swiper initialized');
              },
          },
      });
  }
  initSlider();
  ['shopify:section:load'].forEach(event => {
      window.addEventListener(event, initSlider);
  });
</script>

