      --italic-text-color: {{ block.settings.italic_color | default: 'inherit' }};
      {% endunless %}
      {% if block.settings.remove_italic_font_style %}
        --italic-text-font-style: normal;
      {% endif %}
      --italic-text-background-color: {{ block.settings.italic_background_color | default: 'transparent' }};
    {% endif %}
  '
  {{ block.shopify_attributes }}
>
