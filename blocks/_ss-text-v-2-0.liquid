<div
  class='
    ss-size-panel
    ss-spacing-panel
    ss-color-panel
    ss-typography-panel
    {{ block.settings.class_list }}
    ss-block
    ss-text-block
    ss-{{ block.settings.text_style }}
    ss-text-{{ block.settings.alignment }}
  '
  {{ block.settings.attributes }}
  style='
    {{ style_panel_vars }}
    {% if block.settings.text_max_width == 'narrow' %}
      max-width: var(--ss-narrow-text-width, 40ch);
    {% endif %}
    {% if block.settings.customize_italic_text %}
      {% unless
        block.settings.italic_color == blank or
        block.settings.italic_color == 'transparent' or
        block.settings.italic_color == 'rgba(0,0,0,0)'
