{% comment %} This file is auto-generated. Do not edit this file. {% endcomment %}
{%- liquid
  assign blockIndex = 0
  for sectionBlock in section.blocks
    assign blockIndex = blockIndex | plus: 1
    if block.id == sectionBlock.id
      break
    endif
  endfor
-%}

{%- liquid
  capture style_panel_vars
    render 'ss-style-panel-v-2-0', settings: block.settings, type: 'spacing,size,layout'
  endcapture
-%}

<div
  id='ss-slide-{{ block.id }}'
  class='ss-slideshow__slide ss-block'
  aria-hidden='{% if blockIndex == 1 %}false{% else %}true{% endif %}'
  {{ block.shopify_attributes }}
>
  {% style %}
    {%- if section.settings.slide_height == 'adapt_image' and blockIndex == 1 and block.settings.image != blank -%}
      #ss-slideshow-{{ section.id }} .ss-slideshow__slides,
      #ss-slideshow-{{ section.id }} .ss-slideshow__slide {
        min-height: {{ 1 | divided_by: block.settings.image.aspect_ratio | times: 100 }}vw;
      }
    {%- endif -%}
  {% endstyle %}

  <div class='ss-slide__image-container'>
    {%- if block.settings.image -%}
      {%- liquid
        assign height = block.settings.image.width | divided_by: block.settings.image.aspect_ratio | round
        assign sizes = '100vw'
        assign widths = '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840'
        assign style = '--ss-image-position: ' | append: block.settings.image_position | append: ';'

        assign ss_mobile_image = block.settings.ss_mobile_image | default: block.settings.image
        assign mobile_height = ss_mobile_image.width | divided_by: ss_mobile_image.aspect_ratio | round
        assign mobile_sizes = '100vw'
        assign mobile_widths = '375, 550, 750, 1100, 1500'

        assign loading = 'lazy'
        if blockIndex == 1 and section.index == 1
          assign loading = 'eager'
        endif
      -%}
      {{
        block.settings.image
        | image_url: width: 3840
        | image_tag:
          height: height,
          sizes: sizes,
          widths: widths,
          loading: loading,
          class: 'ss-visibility-desktop',
          style: style
      }}
      {{
        ss_mobile_image
        | image_url: width: 1500
        | image_tag:
          height: mobile_height,
          sizes: mobile_sizes,
          widths: mobile_widths,
          loading: loading,
          class: 'ss-visibility-mobile',
          style: style
      }}
    {%- else -%}
      {%- assign placeholder_slide = blockIndex | modulo: 2 -%}
      {%- if placeholder_slide == 1 -%}
        {{ 'hero-apparel-2' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- else -%}
        {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
      {%- endif -%}
    {%- endif -%}
  </div>
  <div
    class='
      ss-slide__content
      ss-size-panel
      ss-spacing-panel
      ss-layout-panel
    '
    style='{{ style_panel_vars }}'
  >
    {% content_for 'blocks' %}
  </div>
</div>

