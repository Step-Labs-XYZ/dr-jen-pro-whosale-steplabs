{% comment %} This file is auto-generated. Do not edit this file. {% endcomment %}
{% liquid
  if block.settings.product != blank
    assign target = block.settings.product
  endif
%}

{%- liquid
  capture style_panel_vars
    render 'ss-style-panel-v-2-0', settings: block.settings, type: 'spacing,size'
  endcapture
-%}

<div
  class='
    ss-size-panel
    ss-spacing-panel
    ss-description-block
    ss-block
  '
  style='{{ style_panel_vars }}'
  {{ block.shopify_attributes }}
>
  {{ target.description }}
</div>

{% schema %}
{
  "name": "Description 2-0",
  "tag": null,
  "settings": [
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "header",
      "content": "Size"
    },

    {
      "type": "select",
      "id": "section_width",
      "label": "Width",
      "options": [
        {
          "value": "fit-content",
          "label": "Fit"
        },
        {
          "value": "full-width",
          "label": "Fill"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "full-width"
    },

    {
      "type": "select",
      "id": "size_width_type",
      "label": "Type",
      "options": [
        {
          "value": "percent",
          "label": "%"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "percent",

      "visible_if": "{{ block.settings.section_width == 'custom' }}"
    },
    {
      "type": "range",
      "id": "size_width",
      "label": "Width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,

      "visible_if": "{{ block.settings.section_width == 'custom' and block.settings.size_width_type == 'percent' }}"
    },
    {
      "type": "text",
      "id": "size_width_custom",
      "label": "Width",
      "default": "100",

      "visible_if": "{{ block.settings.section_width == 'custom' and block.settings.size_width_type == 'custom' }}"
    },
    {
      "type": "select",
      "id": "size_height-type",
      "label": "Height",
      "options": [
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        },
        {
          "value": "xlarge",
          "label": "XLarge"
        },
        {
          "value": "full",
          "label": "Full Screen"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "auto"
    },
    {
      "type": "text",
      "id": "size_height",
      "label": "Custom Height",
      "default": "auto",

      "visible_if": "{{ block.settings.size_height-type == 'custom' }}"
    },
    {
      "type": "checkbox",
      "id": "view_advanced_height_rules",
      "label": "More Height Rules",
      "default": false
    },
    {
      "type": "text",
      "id": "size_min-height",
      "label": "Min Height",
      "default": "auto",

      "visible_if": "{{ block.settings.view_advanced_height_rules }}"
    },
    {
      "type": "text",
      "id": "size_max-height",
      "label": "Max Height",
      "default": "none",

      "visible_if": "{{ block.settings.view_advanced_height_rules }}"
    },
    {
      "type": "header",
      "content": "Size - Mobile"
    },
    {
      "type": "checkbox",
      "id": "view_mobile_size",
      "label": "Customize Mobile Size",
      "default": false
    },

    {
      "type": "select",
      "id": "section_width-mobile",
      "label": "Width",
      "options": [
        {
          "value": "fit-content",
          "label": "Fit"
        },
        {
          "value": "full-width",
          "label": "Fill"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "full-width",

      "visible_if": "{{ block.settings.view_mobile_size }}"
    },

    {
      "type": "select",
      "id": "size_width-type-mobile",
      "label": "Type",
      "options": [
        {
          "value": "percent",
          "label": "%"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "percent",

      "visible_if": "{{ block.settings.section_width-mobile == 'custom' and block.settings.view_mobile_size }}"
    },
    {
      "type": "range",
      "id": "size_width-mobile",
      "label": "Width",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100,

      "visible_if": "{{ block.settings.view_mobile_size and block.settings.section_width-mobile == 'custom' and block.settings.size_width-type-mobile == 'percent' }}"
