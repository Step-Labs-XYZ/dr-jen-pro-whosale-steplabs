    },
    {
      "type": "select",
      "id": "size_height-type-mobile",
      "label": "Height",
      "options": [
        {
          "value": "auto",
          "label": "Auto"
        },
        {
          "value": "small",
          "label": "Small"
        },
        {
          "value": "medium",
          "label": "Medium"
        },
        {
          "value": "large",
          "label": "Large"
        },
        {
          "value": "xlarge",
          "label": "XLarge"
        },
        {
          "value": "full",
          "label": "Full Screen"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "auto",

      "visible_if": "{{ block.settings.view_mobile_size }}"
    },
    {
      "type": "text",
      "id": "size_height-mobile",
      "label": "Height",

      "visible_if": "{{ block.settings.view_mobile_size and block.settings.size_height-type-mobile == 'custom' }}"
    },
    {
      "type": "checkbox",
      "id": "view_advanced_height_rules-mobile",
      "label": "More Height Rules",
      "default": false,

      "visible_if": "{{ block.settings.view_mobile_size }}"
    },
    {
      "type": "text",
      "id": "size_min-height-mobile",
      "label": "Min Height",

      "visible_if": "{{ block.settings.view_advanced_height_rules-mobile }}"
    },
    {
      "type": "text",
      "id": "size_max-height-mobile",
      "label": "Max Height",

      "visible_if": "{{ block.settings.view_advanced_height_rules-mobile }}"
    },
    {
      "type": "header",
      "content": "Spacing - Desktop"
    },
    {
      "type": "text",
      "id": "spacing_padding",
      "label": "Padding",
      "default": "0px",
      "info": "Accepts CSS"
    },
    {
      "type": "text",
      "id": "spacing_margin",
      "label": "Margin",
      "default": "0px",
      "info": "Accepts CSS"
    },
    {
      "type": "header",
      "content": "Spacing - Mobile"
    },
    {
      "type": "paragraph",
      "content": "Leave fields blank to use the desktop value"
    },
    {
      "type": "text",
      "id": "spacing_padding-mobile",
      "label": "Padding",

      "info": "Accepts CSS"
    },
    {
      "type": "text",
      "id": "spacing_margin-mobile",
      "label": "Margin",

      "info": "Accepts CSS"
    }
  ],
  "presets": [
    {
      "name": "Description 2-0",
      "category": "Product",
      "settings": { "product": "{{ closest.product }}" }
    }
  ]
}
