  }
{% endstylesheet %}

<div
  class='
    ss-swiper-navigation
    ss-visibility-{{ block.settings.ss-visibility }}
    {{ block.settings.container_class_list }}
  '
  style='
    --swiper-navigation-size: {{ block.settings.button_size }}rem;
    --swiper-navigation-top-offset: {{ block.settings.top_offset }}%;
    --swiper-navigation-sides-offset: {{ block.settings.sides_offset }}px;
    --swiper-navigation-color: {{ block.settings.arrow_color | default: 'var(--swiper-theme-color)' }};
    --navigation-button-background: {{ block.settings.arrow_background | default: 'var(--swiper-theme-color)' }};
  '
  {{ block.shopify_attributes }}
>
