{% comment %} This file is auto-generated. Do not edit this file. {% endcomment %}
{% if block.settings.custom_font_embed_code != blank %}
  {{ block.settings.custom_font_embed_code }}
{% endif %}
<style>
  {{ block.settings.type_body_font | font_face: font_display: 'swap' }}
  {{ block.settings.type_body_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ block.settings.type_body_font | font_modify: 'weight', 'bold' | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
  {{ block.settings.type_body_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  {{ block.settings.type_header_font | font_face: font_display: 'swap' }}
  {{ block.settings.type_header_font | font_modify: 'weight', 'bold' | font_face: font_display: 'swap' }}
  {{ block.settings.type_header_font | font_modify: 'weight', 'bold' | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}
  {{ block.settings.type_header_font | font_modify: 'style', 'italic' | font_face: font_display: 'swap' }}

  :root {
      --ss-font-body-family: {% if block.settings.custom_body_font != blank %}{{ block.settings.custom_body_font }}{% else %}{{ block.settings.type_body_font.family }}, {{ block.settings.type_body_font.fallback_families }}{% endif %};
      --ss-font-body-style: {% if block.settings.custom_body_font_style != blank %}{{ block.settings.custom_body_font_style }}{% else %}{{ block.settings.type_body_font.style }}{% endif %};
      --ss-font-body-weight: {% if block.settings.custom_body_font_weight != blank %}{{ block.settings.custom_body_font_weight }}{% else %}{{ block.settings.type_body_font.weight }}{% endif %};

      --ss-font-heading-family: {% if block.settings.custom_header_font != blank %}{{ block.settings.custom_header_font }}{% else %}{{ block.settings.type_header_font.family }}, {{ block.settings.type_header_font.fallback_families }}{% endif %};
      --ss-font-heading-style: {% if block.settings.custom_header_font_style != blank %}{{ block.settings.custom_header_font_style }}{% else %}{{ block.settings.type_header_font.style }}{% endif %};
      --ss-font-heading-weight: {% if block.settings.custom_header_font_weight != blank %}{{ block.settings.custom_header_font_weight }}{% else %}{{ block.settings.type_header_font.weight }}{% endif %};

      --ss-font-body-scale: {{ block.settings.body_scale | divided_by: 100.0 }};
      --ss-font-heading-scale: {{ block.settings.heading_scale | times: 1.0 | divided_by: block.settings.body_scale }};
  }
</style>

