{% comment %} This file is auto-generated. Do not edit this file. {% endcomment %}
{% stylesheet %}
  .ss-image-floating img {
    object-fit: var(--ss-object-fit, cover);
    height: 100%;
  }
{% endstylesheet %}

{% capture style_panel_vars %}
  {% render 'ss-style-panel-v-2-0',
    settings: block.settings,
    type: 'size,spacing,absolute-positioning'
  %}
{% endcapture %}

<div
  class='
    ss-size-panel
    ss-spacing-panel
    ss-absolute-positioning-panel
    ss-block
    ss-image-floating
    ss-visibility-{{ block.settings.ss-visibility }}
  '
  style='
    {{ style_panel_vars }}
    --ss-object-fit: {{ block.settings.object_fit }};
  '
  {{ block.shopify_attributes }}
>
  {%- liquid
    assign image_desktop = block.settings.image
    assign image_mobile = block.settings.image_mobile | default: image_desktop
  -%}
  {%- if image_desktop or image_mobile -%}
    {{
      image_mobile
      | image_url: width: 1500
      | image_tag:
        width: image_mobile.width,
        widths: '375, 550, 750, 1100, 1500',
        loading: 'lazy',
        class: 'ss-visibility-mobile'
    }}
    {{
      image_desktop
      | image_url: width: 3840
      | image_tag:
        width: image_desktop.width,
        widths: '375, 550, 750, 1100, 1500, 1780, 2000, 3000, 3840',
        loading: 'lazy',
        class: 'ss-visibility-desktop'
    }}
  {%- else -%}
    <div class='ss-placeholder-image'>
      {{ 'detailed-apparel-1' | placeholder_svg_tag: 'image-placeholder-svg' }}
    </div>
  {%- endif -%}
</div>

