{% stylesheet %}
  .ss-link-block {
    display: inline-flex;
  }

  .ss-link-block-icon-right {
    flex-direction: row-reverse;
    justify-content: flex-end;
  }

  .ss-link-block svg {
    fill: rgb(var(--ss-fill-link-icon-color));
    flex-shrink: 0;
  }

  .ss-link--with-icon {
    gap: 5px;
  }
{% endstylesheet %}

{% capture style_panel_vars %}
  {% render 'ss-style-panel-v-2-0',
    settings: block.settings,
    type: 'size,spacing'
  %}
{% endcapture %}

<a
  href='{{ block.settings.link }}'
  class='
    ss-size-panel
    ss-spacing-panel
    {{ block.settings.class_list }}
    ss-block
    ss-link-block
    ss-link-block-icon-{{ block.settings.icon_position }}
    ss-{{ block.settings.style_class }}
    {% if block.settings.icon != "none" %}
    ss-link--with-icon
    {% endif %}
  '
  style='{{ style_panel_vars }}'
  {%- if block.settings.open_in_new_tab -%}
    target='_blank' rel='noopener noreferrer'
  {%- endif -%}
  {{ block.shopify_attributes }}
  {%- if block.settings.on_click_action -%}
    onclick='{{ block.settings.on_click_action }}'
  {%- endif -%}
>
  {%- if block.settings.icon != 'none' -%}
    {% assign icon_width = block.settings.icon_width | default: '20' %}
    {% assign icon_height = block.settings.icon_height | default: '20' %}
    {% assign icon_view_box = block.settings.icon_view_box | default: '0 0 20 20' %}
    {%- render 'ss-icon-v-2-0',
      icon: block.settings.icon,
      width: icon_width,
      height: icon_height,
      view_box: icon_view_box,
      other_attributes: block.shopify_attributes
    %}
  {%- endif -%}
  {{ block.settings.label }}
</a>

