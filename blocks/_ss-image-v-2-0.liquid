{% comment %} This file is auto-generated. Do not edit this file. {% endcomment %}
{% stylesheet %}
  .ss-image-block img {
    height: 100%;
    border-radius: var(--ss-image-corner-radius, 0px);
  }

  .ss-image-block--cover img {
    object-position: var(--ss-image-position);
  }

  .ss-image-block--cover img {
    object-fit: cover;
  }

  .ss-image-block--contain img {
    object-fit: contain;
  }
{% endstylesheet %}

{% capture style_panel_vars %}
  {% render 'ss-style-panel-v-2-0',
    settings: block.settings,
    type: 'size, spacing'
  %}
{% endcapture %}

<div
  {{ block.shopify_attributes }}
  class='
    ss-block
    ss-image-block
    ss-size-panel
    ss-spacing-panel
    ss-image-block--{{ block.settings.object_fit }}
    {{ block.settings.class_list }}
  '
  style='
      {% if block.settings.corner_radius != -1 %}
      --ss-image-corner-radius: {{ block.settings.corner_radius }}px;
    {% endif %}
  '
>
  {%- liquid
    assign image_desktop = block.settings.image
    assign image_mobile = block.settings.image_mobile | default: image_desktop
    assign style = '--ss-image-position: ' | append: block.settings.image_position | append: ';'

    assign width = image_desktop.width
    assign height = image_desktop.height
    assign width_mobile = image_mobile.width
    assign height_mobile = image_mobile.height
    assign loading = 'lazy'
    assign preload = block.settings.preload
    assign fetch_priority = 'auto'
    if section.index == 1 or preload == true
      assign loading = 'eager'
      assign preload = true
      assign fetch_priority = 'high'
    endif
  -%}
  {%- if image_desktop or image_mobile -%}
    {% if block.settings.link != blank %}
      <a href='{{ block.settings.link }}' class='ss-image-block__link'>
    {% endif %}
    <img
      srcset='
        {% if image_mobile.width >= 350 %}{{ image_mobile | image_url: width: 350 }} 350w,{% endif %}
        {% if image_mobile.width >= 750 %}{{ image_mobile | image_url: width: 750 }} 750w,{% endif %}
        {% if image_mobile.width >= 1100 %}{{ image_mobile | image_url: width: 1100 }} 1100w,{% endif %}
        {% if image_mobile.width >= 1500 %}{{ image_mobile | image_url: width: 1500 }} 1500w,{% endif %}
        {{ image_mobile | image_url }} {{ image_mobile.width }}w
      '
      src='{{ image_mobile | image_url: width: 300 }}'
      loading='{{ loading }}'
      fetchpriority='{{ fetch_priority }}'
      width='{{ width_mobile }}'
      height='{{ height_mobile }}'
      widths='375, 550, 750'
      sizes='(min-width: 750px) calc(100vw - 22rem), 1100px, 1500px'
      alt='{{ image_mobile.alt | escape }}'
      class='
        ss-visibility-mobile
        ss-size-panel
        ss-spacing-panel
        ss-image-block__image
      '
      style='{{ style_panel_vars }} {{ style }}'
      preload='{{ preload }}'
    >
    <img
      srcset='
        {% if image_desktop.width >= 350 %}{{ image_desktop | image_url: width: 350 }} 350w,{% endif %}
        {% if image_desktop.width >= 750 %}{{ image_desktop | image_url: width: 750 }} 750w,{% endif %}
        {% if image_desktop.width >= 1100 %}{{ image_desktop | image_url: width: 1100 }} 1100w,{% endif %}
        {% if image_desktop.width >= 1500 %}{{ image_desktop | image_url: width: 1500 }} 1500w,{% endif %}
        {% if image_desktop.width >= 2200 %}{{ image_desktop | image_url: width: 2200 }} 2200w,{% endif %}
        {% if image_desktop.width >= 3000 %}{{ image_desktop | image_url: width: 3000 }} 3000w,{% endif %}
        {{ image_desktop | image_url }} {{ image_desktop.width }}w
      '
      src='{{ image_desktop | image_url: width: 700 }}'
      loading='{{ loading }}'
      fetchpriority='{{ fetch_priority }}'
      width='{{ width }}'
      height='{{ height }}'
      class='
        ss-visibility-desktop
        ss-size-panel
        ss-spacing-panel
        ss-image-block__image
      '
      style='{{ style_panel_vars }} {{ style }}'
      preload='{{ preload }}'
      sizes='(min-width: 750px) calc(100vw - 22rem), 1100px, 1500px'
      alt='{{ image_desktop.alt | escape }}'
    >
    {% if block.settings.link != blank %}
      </a>
    {% endif %}
  {%- else -%}
    <div class='ss-placeholder-image'>
      {{ 'detailed-apparel-1' | placeholder_svg_tag: 'image-placeholder-svg' }}
    </div>
  {%- endif -%}
</div>

