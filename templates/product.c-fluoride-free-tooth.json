    "c_dr_jen_difference_yWMcpP": {
      "type": "c-dr-jen-difference",
      "name": "C Dr. Jen Difference",
      "settings": {
        "heading": "<p>Premium Grade nHAp</p>",
        "description": "<p>Premium-grade Nanohydroxyapatite is proven to deliver optimal levels of protection, reduction in acid-causing bacteria, and hypersensitivity management when used at concentrations of 10%</p>",
        "bold_text": "<p><strong>While cheaper formulations source lower grade Nanohydroxyapatite, Dr. Jen's sources premium grade Nanohydroxyapatite for higher performance.</strong></p>",
        "secondary_text": "<p>That's the exact specification the Scientific Committee on Consumer Safety (SCCS) has officially recognized as safe:</p>",
        "scientific_image": "shopify://shop_images/logo-2.png",
        "scientific_quote": "<p><em>\"Based on the data provided, the SCCS considers hydroxyapatite (nano) safe when used at concentrations up to 10% in toothpaste — composed of rod-shaped particles.\"</em></p>",
        "crystal_heading": "Does quality of the crystal matter?",
        "crystal_description": "<p>Crystals have to be 'Nano' in size to be able to penetrate the enamel surface pores and dentin tubules.</p>",
        "low_grade_image": "shopify://shop_images/Group_1000007150.png",
        "low_grade_label": "Low-Grade nHAp",
        "premium_grade_image": "shopify://shop_images/Group_1000007167.png",
        "premium_grade_label": "Premium Grade nHAp",
        "bg_color": "#ffffff",
