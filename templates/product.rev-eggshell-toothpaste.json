    "rev_pdp_overlapp_img_UMrR69": {
      "type": "rev-egg-overlap-image",
      "blocks": {
        "text_jQPqdx": {
          "type": "text",
          "settings": {
            "heading": "Proven Ingredients",
            "content": "<ul><li><strong>10% Nano Hydroxyapatite from Eggshells</strong>: Helps enamel, restore its natural structure, and reduce sensitivity.</li><li><strong>Foam-free</strong>. Gentle for people who suffer from mouth ulcers or sensitive gums. </li><li><strong>Magnesium & Zinc</strong>: Magnesium strengthens enamel by enhancing calcium absorption, while zinc helps reduce plaque buildup, fight bacteria, and maintain gum health.</li><li><strong>Naturally Derived from Eggshells</strong>: Eggshells provide a unique blend of nano hydroxyapatite, <strong>magnesium</strong>, and <strong>zinc</strong>—essential minerals that enhance the toothpaste’s effectiveness.</li><li><strong>Superior to Synthetic Hydroxyapatite</strong>: Eggshell-derived hydroxyapatite is naturally richer in minerals like magnesium and zinc, which contribute to better oral health than synthetic versions of nano Hydroxyapatite. </li><li><strong>Xylitol for Cavity Protection</strong>: Xylitol helps reduce the growth of cavity-causing bacteria, aids in saliva production, and helps enamel.</li></ul>"
          }
        },
        "image_6w6hKX": {
          "type": "image",
          "settings": {
            "column_image": "shopify://shop_images/eggshellcollage.png"
          }
