    "1658221842286d2dd8": {
      "type": "Image-w-text-AB",
      "settings": {
        "section_image": "shopify://shop_images/splanding5050left.png",
        "section_title": "Dr.Jens Super Paste with  Nano-Hydroxyapatite  & Flouride",
        "section_text": "<p>• Made with all-natural ingredients<br/>• Paraben-free, vegan & cruelty-free<br/>• No harsh foaming agents: SLS & sulfate-free<br/>• Double remineralizing to strengthen and restore tooth enamel<br/>• Naturally whitening and ideal for sensitive teeth<br/>• Natural oils to restore mouth microbiome</p>",
        "main_container_background": "#e7f8f8",
        "section_second_text": "<p>• No Sodium Lauryl Sulfate<br/>• No Titanium Dioxide<br/>• No Propylene Glycol<br/>• No\tArtificial Color<br/>• Parabens Free</p>",
        "second_text_font_color": "#ffffff",
        "second_text_background": "#fc7157",
        "bottom_container_title": "Ingredients:",
        "bottom_container_text": "<p>Active Ingredient: 0.22% Sodium Fluoride. Inactive Ingredients: Aqua, Glycerin (soothes and moisturizes, derived from coconut), Silica (polishes teeth), Calcium Carbonate (helps whiten teeth), Xylitol (reduces the risk of dental decay), Nano-Hydroxyapatite (strengthens enamel), Cellulose Gum (thickens paste), Potassium Cocoate (foams paste from coconut oil), Peppermint Oil, Spearmint Oil, Citric Acid (preserves naturally), Black Cherry (provides powerful antioxidants and reduces inflammation), Papaya (provides powerful antioxidants), Glycyrrhiza Glabra (flavors with licorice root), Spirulina (provides powerful antioxidants and coloring)</p>",
        "url": "#featuredProductsSaving",
        "button_text": "Add to Cart",
        "bottom_container_background": "#ffffff"
      }
    },
