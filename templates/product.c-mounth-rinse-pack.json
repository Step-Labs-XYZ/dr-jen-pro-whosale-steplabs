    "c_faq_EEe7Md": {
      "type": "c-faq",
      "blocks": {
        "faq_item_9QefQB": {
          "type": "faq_item",
          "settings": {
            "question": "What makes Dr. Jen’s Mouth Rinse different from traditional mouthwash?",
            "answer": "<p>Mouth Rinse with Wellness Pre-Rinse goes beyond simply masking bad breath. It was formulated to support healthier enamel, healthier gums, and overall oral wellness using science-backed ingredients and soothing botanicals, without harsh ingredients.</p>"
          }
        },
        "faq_item_X9HyFN": {
          "type": "faq_item",
          "settings": {
            "question": "Does this mouth rinse contain alcohol?",
            "answer": "<p>No. Mouth Rinse with Wellness Pre-Rinse is completely alcohol-free, making it gentle enough for everyday use without the harsh burn often associated with traditional mouthwashes.</p>"
          }
        },
        "faq_item_DaTcTz": {
          "type": "faq_item",
          "settings": {
            "question": "Are the ingredients natural?",
            "answer": "<p>We use a proprietary blend of essential oils, no synthetic flavoring. Our mint paste contains essential oils with coconut oil-based foaming, while our strawberry paste is naturally foam-free. You'll never find sodium lauryl sulfate (SLS) in any Dr. Jen's formula.</p>"
          }
        },
        "faq_item_HQ84kE": {
          "type": "faq_item",
          "settings": {
            "question": "What exactly is Nanohydroxyapatite?",
            "answer": "<p>Nano-hydroxyapatite (nHAp) is composed of calcium and phosphate minerals, the same minerals that make up 97% of your tooth enamel and the mineral portion of your bones. The \"nano\" means the particles are extremely small, measured in nanometers, allowing them to behave like your natural enamel crystals.  </p><p><strong>How it works:</strong></p><ul><li>Absorbs and removes dental plaque</li><li>Replenishes lost calcium and phosphate minerals</li><li>Fills in micro-fissures on tooth surfaces</li><li>Reduces sensitivity by sealing exposed dentinal tubules</li></ul><p>Think of it as giving your teeth the building blocks they need to stay strong.<br/><br/><br/></p>"
          }
        },
        "faq_item_mFfdaE": {
          "type": "faq_item",
          "settings": {
            "question": "How does this rinse support enamel health?",
            "answer": "<p>The formula contains nanohydroxyapatite, a biomimetic mineral naturally found in teeth, designed to help support healthy enamel and provide daily protection from everyday acids.</p>"
          }
        },
        "faq_item_MEG9f3": {
          "type": "faq_item",
          "settings": {
            "question": "Can this help support gum health?",
            "answer": "<p>Yes. The formula includes soothing ingredients like aloe vera and calendula, selected to help comfort and nourish delicate gum tissues.</p>"
          }
        }
      },
