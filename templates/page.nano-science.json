        "dekstop_image": "shopify://shop_images/image_10_2.png",
        "img_card_link": "<p><a href=\"https://www.ncbi.nlm.nih.gov/pmc/articles/ PMC5390120/pdf/joddd-11-14.pdf\" title=\"https://www.ncbi.nlm.nih.gov/pmc/articles/ PMC5390120/pdf/joddd-11-14.pdf\">https://www.ncbi.nlm.nih.gov/pmc/articles/ PMC5390120/pdf/joddd-11-14.pdf</a><br/><a href=\"https://www.ncbi.nlm.nih.gov/pmc/articles/ PMC5390120/\" title=\"https://www.ncbi.nlm.nih.gov/pmc/articles/ PMC5390120/\">https://www.ncbi.nlm.nih.gov/pmc/articles/ PMC5390120/ </a></p>",
        "card_top_text": "Double the Proven Remineralizing Ingredients",
        "card_headline": "Nano-hydroxyapatite + Fluoride",
        "card_desc": "<p>Dr. Jen’s Super Paste with Triple the clinically proven remineralizing ingredients using 10% nHAp with Fluoride and Xylitol. Clinically proven ingredients to outperform fluoride-alone toothpaste. Recommended for patients suffering from xerostomia, weak enamel, and hypersensitivity. Higher levels of remineralizing without the need for a prescription and enough to use twice a day.<br/><br/><strong>NHA toothpaste:</strong> 7% NHA + NaF<br/><strong>F toothpaste:</strong> contains only NaF</p>",
        "mobile_image": "shopify://shop_images/image_10_2.png",
        "card_link": "",
        "card_bottom_text": ""
      }
